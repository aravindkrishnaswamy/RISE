RISE ASCII SCENE 5
#############################################################################################################
#                                 R.I.S.E Ascii Scene File                                                  #
#                                                                                                           #
#   File:           diacaustic_pt_sms.RISEscene                                                             #
#   Description:    Scene with a diacaustic (caustic caused by reflection).                                 #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 26, 2026.                                                                         #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       4

	pathguiding                   false
	pathguiding_sampling_type     RIS
	pathguiding_iterations        6
	pathguiding_spp               12
	pathguiding_alpha             0.5
	pathguiding_max_depth         8

	sms_enabled                   TRUE
	sms_max_iterations            20
	sms_threshold                 1e-5
	sms_max_chain_depth           10
	sms_biased                    TRUE
	sms_multi_trials				16
#	sms_seeding						uniform
}

file_rasterizeroutput
{
	pattern				rendered/diacaustic_pt_sms
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

pinhole_camera
{
	location			0 0 200
	lookat				0 0 0
	up					0 1 0
	width				640
	height				480
	fov					45.0
	theta				60
}

##################################################
# Painters
##################################################

> run scenes/colors.RISEscript

png_painter
{
	name				pnt_tex
	file				textures/wood.png
	color_space			sRGB
}

uniformcolor_painter
{
	name				pnt_refl
	color				1.0 0.625 0.29
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			color_white
}

lambertian_material
{
	name				wood
	reflectance			pnt_tex
}

perfectreflector_material
{
	name				metal
	reflectance			pnt_refl
}

lambertian_luminaire_material
{
	name				light
	exitance			color_white
	scale				5000
	material			white
}

##################################################
# Geometry
##################################################

rawmesh2_geometry
{
	name				geom_box
	file				models/raw/ring-caustic01_box.rawmesh2
	maxpolygons			10
	maxdepth			6
}

rawmesh2_geometry
{
	name				geom_tube
	file				models/raw/ring-caustic01_tube.rawmesh2
	maxpolygons			10
	maxdepth			6
}

clippedplane_geometry
{
	name				geom_light
	pta					-10 -120 100
	ptb					10 -120 100
	ptc					10 -130 100
	ptd					-10 -130 100
}

##################################################
# Objects
##################################################

standard_object
{
	name				box
	geometry			geom_box
	material			wood
	orientation			-90 0 0
}

standard_object
{
	name				tube
	geometry			geom_tube
	material			metal
	orientation			-90 0 0
}

standard_object
{
	name				light
	geometry			geom_light
	material			light
	orientation			-90 0 0
}

