#############################################################################################################


uniformcolor_painter
{
	name		color_white
	color		1.0 1.0 1.0
}

uniformcolor_painter
{
	name		color_red
	color		1.0 0.0 0.0
}

uniformcolor_painter
{
	name		color_green
	color		0.0 1.0 0.0
}

uniformcolor_painter
{
	name		color_blue
	color		0.0 0.0 1.0
}










