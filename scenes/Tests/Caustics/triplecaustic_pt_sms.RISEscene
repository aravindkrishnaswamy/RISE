RISE ASCII SCENE 6
#############################################################################################################
#                                 R.I.S.E Ascii Scene File                                                  #
#                                                                                                           #
#   File:           triplecaustic_pt_sms.RISEscene                                                         #
#   Description:    Triple caustic scene rendered with path tracing + SMS (no photon mapping)               #
#   Author:         Aravind Krishnaswamy                                                                    #
#                                                                                                           #
#############################################################################################################

##################################################
# MIS Path Tracer with SMS
#
# MISPathTracingShaderOp is a self-contained integrator: NEE
# (mesh + non-mesh lights), BSDF sampling, emission, and SMS
# with proper MIS weights — all in one shaderop.  It replaces
# the entire DefaultDirectLighting + PathTracing + SMS chain.
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       256
	sms_enabled                   TRUE
	sms_max_iterations            20
	sms_threshold                 1e-5
	sms_max_chain_depth           10
	sms_biased                    TRUE
}

file_rasterizeroutput
{
	pattern				rendered/triplecaustic_pt_sms
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

film
{
	width			512
	height			512
}

pinhole_camera
{
	location			0 0.0 3.0
	lookat				0 0 0
	up					0 1 0
	fov					30.0
}

##################################################
# Painters
##################################################

