RISE ASCII SCENE 5
#############################################################################################################
#   Torture test: 100-light corridor, 10000 units long, 200 wide, 200 tall.                                #
#   100 point lights at equal spacing (every 100 units).  At 64spp with global                              #
#   alias table, each light gets ~0.64 samples on average.  From any shading                                #
#   point, only the 2-3 nearest lights matter (1/d^2), so ~97% of the budget                                #
#   is wasted.  This should show severe noise/fireflies compared to spatial                                 #
#   selection.                                                                                              #
#############################################################################################################

> set accelerator B 10 8

pathtracing_shaderop
{
	name		pt
}

standard_shader
{
	name		global
	shaderop	pt
}

pixelpel_rasterizer
{
	max_recursion		5
	min_importance		0.01
	samples				64
	lum_samples			1
}

file_rasterizeroutput
{
	pattern				rendered/corridor_100lights_alias
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			100 100 200
	lookat				100 80 5000
	up					0 1 0
	width				512
	height				512
	fov					70.0
}

> run scenes/colors.RISEscript

uniformcolor_painter
{
	name				pnt_warm_white
	color				0.73 0.71 0.68
}

uniformcolor_painter
{
	name				pnt_lightgray
	color				0.6 0.6 0.6
}

lambertian_material
{
	name				white
	reflectance			pnt_warm_white
}

lambertian_material
{
	name				gray
	reflectance			pnt_lightgray
}

