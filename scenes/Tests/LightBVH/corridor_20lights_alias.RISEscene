##################################################
# Corridor geometry: 200 wide, 200 tall, 4000 deep
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					200 0 0
	ptb					0 0 0
	ptc					0 0 4000
	ptd					200 0 4000
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					200 200 0
	ptb					200 200 4000
	ptc					0 200 4000
	ptd					0 200 0
}

clippedplane_geometry
{
	name				leftwallgeom
	pta					0 0 4000
	ptb					0 0 0
	ptc					0 200 0
	ptd					0 200 4000
}

clippedplane_geometry
{
	name				rightwallgeom
	pta					200 0 0
	ptb					200 0 4000
	ptc					200 200 4000
	ptd					200 200 0
}

clippedplane_geometry
{
	name				backwallgeom
	pta					200 0 0
	ptb					200 200 0
	ptc					0 200 0
	ptd					0 0 0
}

clippedplane_geometry
{
	name				farwallgeom
	pta					0 0 4000
	ptb					0 200 4000
	ptc					200 200 4000
	ptd					200 0 4000
}

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				leftwall
	geometry			leftwallgeom
	material			gray
}

standard_object
{
	name				rightwall
	geometry			rightwallgeom
	material			gray
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	material			white
}

standard_object
{
	name				farwall
	geometry			farwallgeom
	material			white
}
