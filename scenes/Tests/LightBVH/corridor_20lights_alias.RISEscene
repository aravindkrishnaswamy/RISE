RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           torture_corridor_pt.RISEscene                                                           #
#   Description:    Torture test: long corridor (4000 units) with 20 equally-spaced                         #
#                   point lights.  From any shading point, only 2-3 nearby lights                           #
#                   contribute significantly (1/d^2), but the alias table distributes                       #
#                   samples uniformly across all 20.  ~85% of sampling budget wasted.                       #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 30, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       64
	lum_samples                   1
}

file_rasterizeroutput
{
	pattern				rendered/corridor_20lights_alias
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera near start of corridor
##################################################

pinhole_camera
{
	location			100 100 200
	lookat				100 80 2000
	up					0 1 0
	width				512
	height				512
	fov					70.0
}

##################################################
# Painters
##################################################
> run scenes/colors.RISEscript

uniformcolor_painter
{
	name				pnt_warm_white
	color				0.73 0.71 0.68
}

uniformcolor_painter
{
	name				pnt_lightgray
	color				0.6 0.6 0.6
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			pnt_warm_white
}

lambertian_material
{
	name				gray
	reflectance			pnt_lightgray
}

##################################################
# 20 point lights evenly spaced along corridor ceiling
# Corridor: x=[0,200], y=[0,200], z=[0,4000]
# Lights at y=190 (near ceiling), spacing=200
##################################################

omni_light
{
	name		light_01
	power		80000.0
	color		1.0 0.95 0.85
	position	100 190 100
}

omni_light
{
	name		light_02
	power		80000.0
	color		1.0 0.95 0.85
	position	100 190 300
