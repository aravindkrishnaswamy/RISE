RISE ASCII SCENE 6
#############################################################################################################
#   File:           phase3_dielectric_iscalarpainter.RISEscene                                              #
#   Description:    Cornell-box dispersive glass sphere using the new IScalarPainter pipeline.              #
#                   Proves Phase 3 of the IScalarPainter refactor: dielectric tau/ior/scattering route      #
#                   through `IScalarPainter` (physical scalars, no JH spectral uplift), so spectral         #
#                   rasterizers no longer mangle inline-numeric scattering values.                          #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      May 14, 2026                                                                            #
#############################################################################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

bdpt_spectral_rasterizer
{
	samples					128
	max_eye_depth			5
	max_light_depth			5
	nmbegin					405
	nmend					705
	num_wavelengths			8
	spectral_samples		1
	hwss					true
}

file_rasterizeroutput
{
	pattern				rendered/phase3_dielectric_iscalarpainter
	type				PNG
	bpp				16
	color_space			ProPhotoRGB
}

film
{
	width			192
	height			192
}

pinhole_camera
{
	location			0.278 0.273 -0.800
	lookat				0.278 0.273 0
	up					0 1 0
	fov					37.0
}

##################################################
# Cornell-box wall reflectance (still IPainter)
##################################################

spectral_painter
{
	name				pnt_green
	file				colors/cornellbox_green.spectra
	nmbegin				400
	nmend				700
	scale				4
}

spectral_painter
{
	name				pnt_red
	file				colors/cornellbox_red.spectra
	nmbegin				400
	nmend				700
	scale				4
}

spectral_painter
{
	name				pnt_white
	file				colors/cornellbox_white.spectra
	nmbegin				400
	nmend				700
	scale				4
}

spectral_painter
{
	name				pnt_light
	file				colors/cornellbox_light.spectra
	nmbegin				386
	nmend				711
	scale				4
}

##################################################
# Scalar painters (IScalarPainter) — the new pipe.
# Phase 3 proof: these are physical scalars, not
# colors.  tau is per-wavelength piecewise-linear,
# ior is analytic (Sellmeier crown glass BK7),
# scattering stays inline numeric (resolved to a
# UniformScalarPainter by Job::AddDielectricMaterial).
##################################################

scalar_painter
{
	name				tau_glass
	file				colors/flat_1.spectra
}

scalar_painter
{
	name				ior_bk7
	sellmeier			1.03961212 0.231792344 1.01046945 0.00600069867 0.0200179144 103.560653
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			pnt_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

lambertian_luminaire_material
{
	name				white_lum
	exitance			pnt_light
	scale				10.0
	material			none
}

dielectric_material
{
	name				glass
	tau					tau_glass
	ior					ior_bk7
	scattering			1000000
}

##################################################
# Geometry
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					0.5528 0 0
	ptb					0 0 0
	ptc					0 0 0.5592
	ptd					0.5496 0 0.5592
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					0.556 0.5488 0.0
	ptb					0.556 0.5488 0.5592
	ptc					0 0.5488 0.5592
	ptd					0.0 0.5488 0.0
}

clippedplane_geometry
{
	name				bwallgeom
	pta					0.5496 0 0.5592
	ptb					0 0 0.5592
	ptc					0 0.5488 0.5592
	ptd					0.556 0.5488 0.5592
}

clippedplane_geometry
{
	name				rwallgeom
	pta					0 0 0.5592
	ptb					0 0 0
	ptc					0 0.5488 0.0
	ptd					0 0.5488 0.5592
}

clippedplane_geometry
{
	name				lwallgeom
	pta					0.5528 0 0
	ptb					0.5496 0 0.5592
	ptc					0.556 0.5488 0.5592
	ptd					0.556 0.5488 0
}

clippedplane_geometry
{
	name				lightgeom
	pta					0.3430 0.5487999 0.2270
	ptb					0.3430 0.5487999 0.3320
	ptc					0.2130 0.5487999 0.3320
	ptd					0.2130 0.5487999 0.2270
}

sphere_geometry
{
	name				spheregeom
	radius				0.12
}

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				bwall
	geometry			bwallgeom
	material			white
}

standard_object
{
	name				rwall
	geometry			rwallgeom
	material				green
}

standard_object
{
	name				lwall
	geometry			lwallgeom
	material			red
}

standard_object
{
	name				light
	geometry			lightgeom
	material			white_lum
}

standard_object
{
	name				sphere
	geometry			spheregeom
	position			0.273 0.12 0.2
	material			glass
}
