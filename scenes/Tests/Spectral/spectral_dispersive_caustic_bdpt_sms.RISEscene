RISE ASCII SCENE 5
#############################################################################################################
#                                                                                                           #
#   File:           spectral_dispersive_caustic_bdpt_sms.RISEScene                                          #
#   Description:    Spectral BDPT + SMS counterpart to spectral_dispersive_caustic_pt_sms.                  #
#                                                                                                           #
#   Use: validate that BDPT spectral SMS (EvaluateSMSStrategiesNM delegating to                             #
#         ManifoldSolver::EvaluateAtShadingPointNM with the G_x_v1 · |det| geometry formula) produces a     #
#         dispersion caustic matching the PT counterpart.  Before the P1-A fix BDPT spectral SMS used an    #
#         obsolete `cosAtLight · chainGeom / jacobianDet` formula that over-weighted wavelengths whose      #
#         chain distances were large, biasing the spectral tint of the caustic.                             #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

bdpt_spectral_rasterizer
{
	max_eye_depth		8
	max_light_depth		6
	samples				256
	nmbegin				405
	nmend				705
	num_wavelengths		8
	spectral_samples	4
	sms_enabled			TRUE
	sms_max_iterations	20
	sms_threshold		1e-5
	sms_max_chain_depth	10
	sms_biased			TRUE
}

file_rasterizeroutput
{
	pattern				rendered/spectral_dispersive_caustic_bdpt_sms
	type				PNG
	bpp				16
	color_space			ProPhotoRGB
}

##################################################
# Cameras
##################################################

pinhole_camera
{
	location			0.278 0.273 -0.800
	lookat				0.278 0.273 0
	up					0 1 0
	width				256
	height				256
	fov					37.0
}


##################################################
# Painters
##################################################

spectral_painter
{
	name				pnt_green
	file				colors/cornellbox_green.spectra
	nmbegin				400
	nmend				700
	scale				3
}

spectral_painter
{
	name				pnt_red
	file				colors/cornellbox_red.spectra
	nmbegin				400
	nmend				700
	scale				3
}

spectral_painter
{
	name				pnt_white
	file				colors/cornellbox_white.spectra
	nmbegin				400
	nmend				700
	scale				3
}

spectral_painter
{
	name				pnt_light_xenon_flash
	file				colors/nikon_sb16_xenon_flash.spectra
	nmbegin				386
	nmend				711
}

spectral_painter
{
	name				pnt_trans
	file				colors/flat_1.spectra
	nmbegin				380
	nmend				720
}

spectral_painter
{
	name				linear_ior
	file				colors/linear.ior
	nmbegin				380
	nmend				720
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			pnt_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

lambertian_luminaire_material
{
	name				white_lum
	exitance			pnt_light_xenon_flash
	scale				6.0
	material			none
}

dielectric_material
{
	name				glass
	tau					pnt_trans
	ior					linear_ior
	scattering			1000000
}


##################################################
# Objects - walls
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					0.5528 0 0
	ptb					0 0 0
	ptc					0 0 0.5592
	ptd					0.5496 0 0.5592
}

clippedplane_geometry
{
	name				bwallgeom
	pta					0.5496 0 0.5592
	ptb					0 0 0.5592
	ptc					0 0.5488 0.5592
	ptd					0.556 0.5488 0.5592
}

clippedplane_geometry
{
	name				lightgeom
	pta					0.3430 0.5487999 0.2270
	ptb					0.3430 0.5487999 0.3320
	ptc					0.2130 0.5487999 0.3320
	ptd					0.2130 0.5487999 0.2270
}


standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				bwall
	geometry			bwallgeom
	material			white
}

standard_object
{
	name				light
	geometry			lightgeom
	material			white_lum
}

##################################################
# Objects - One sphere
##################################################
sphere_geometry
{
	name				spheregeom
	radius				0.12
}

standard_object
{
	name				sphere
	geometry			spheregeom
	position			0.273 0.23	0.2
	material			glass
}
