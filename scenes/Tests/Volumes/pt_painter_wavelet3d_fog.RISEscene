RISE ASCII SCENE 5
# Wavelet noise 3D driven heterogeneous medium in a Cornell box.

> set accelerator B 10 8

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       64
}

file_rasterizeroutput
{
	pattern				rendered/pt_painter_wavelet3d_fog
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			278 273 -280
	lookat				278 273 280
	up					0 1 0
	width				256
	height				256
	fov					65.0
}

uniformcolor_painter
{
	name				pnt_dense
	color				1.0 1.0 1.0
}

uniformcolor_painter
{
	name				pnt_sparse
	color				0.0 0.0 0.0
}

wavelet3d_painter
{
	name				pnt_density
	tile_size			32
	persistence			0.65
	octaves				4
	colora				pnt_dense
	colorb				pnt_sparse
	scale				0.02 0.02 0.02
	shift				0 0 0
}

painter_heterogeneous_medium
{
	name			wavelet_fog
	absorption		0.004 0.004 0.004
	scattering		0.035 0.035 0.035
	phase			isotropic
	density_painter	pnt_density
	resolution		64
	color_to_scalar	luminance
	bbox_min		80 0 100
	bbox_max		476 400 500
}

> set global_medium wavelet_fog

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.9
}

uniformcolor_painter
{
	name				pnt_white
	color				0.73 0.73 0.73
}

uniformcolor_painter
{
	name				pnt_green
	color				0.12 0.45 0.15
}

uniformcolor_painter
{
	name				pnt_red
	color				0.63 0.06 0.04
}

uniformcolor_painter
{
	name				pnt_yellow
	color				0.8 0.7 0.1
}

uniformcolor_painter
{
	name				pnt_blue
	color				0.1 0.15 0.7
}

lambertian_material
{
	name				white
	reflectance			pnt_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

lambertian_material
{
	name				yellow
	reflectance			pnt_yellow
}

lambertian_material
{
	name				blue
	reflectance			pnt_blue
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				120.0
	material			none
}

clippedplane_geometry
{
	name				floorgeom
	pta					556 0 0
	ptb					0 0 0
	ptc					0 0 556
	ptd					556 0 556
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					0 548 0
	ptb					556 548 0
	ptc					556 548 556
	ptd					0 548 556
}

