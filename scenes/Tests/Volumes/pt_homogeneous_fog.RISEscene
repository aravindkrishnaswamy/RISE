RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           pt_homogeneous_fog.RISEscene                                                            #
#   Description:    Cornell box filled with homogeneous participating medium (isotropic fog).               #
#                                                                                                           #
#                   Tests basic volumetric scattering, absorption, and shadow attenuation                   #
#                   through participating media.  The fog should produce visible light                       #
#                   shafts and soften shadows.                                                               #
#                                                                                                           #
#                   sigma_a = 0.0005 (low absorption)                                                       #
#                   sigma_s = 0.002  (moderate scattering for 500-unit box)                                 #
#                   phase   = isotropic                                                                     #
#                   optical depth across box ≈ 0.0025 * 560 ≈ 1.4                                          #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 31, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Renderer -- Unidirectional Path Tracing
##################################################

pathtracing_shaderop
{
	name		pt
	branch		false
}

standard_shader
{
	name		global
	shaderop	pt
}

pixelpel_rasterizer
{
	max_recursion		10
	samples				256
	lum_samples			1
	ior_stack			TRUE
}

file_rasterizeroutput
{
	pattern				rendered/pt_homogeneous_fog
	type				HDR
	bpp					16
	color_space			ROMMRGB_Linear
}

file_rasterizeroutput
{
	pattern				rendered/pt_homogeneous_fog
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera
##################################################

pinhole_camera
{
	location			278 273 -280
	lookat				278 273 280
	up					0 1 0
	width				512
	height				512
	fov					65.0
}

##################################################
# Participating Medium
##################################################

homogeneous_medium
{
	name		fog
	absorption	0.0005 0.0005 0.0003
	scattering	0.001 0.001 0.0001
	phase		isotropic
}

> set global_medium fog

##################################################
# Painters
##################################################

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_white
	color				0.73 0.73 0.73
}

uniformcolor_painter
{
	name				pnt_green
	color				0.12 0.45 0.15
}

uniformcolor_painter
{
	name				pnt_red
	color				0.63 0.06 0.04
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			pnt_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				150.0
	material			none
}

##################################################
# Geometry -- Cornell Box
#
# Standard Cornell box: x=[0,556], y=[0,549], z=[0,560]
##################################################

# --- Floor ---
clippedplane_geometry
{
	name				floorgeom
	pta					556 0 0
	ptb					0 0 0
	ptc					0 0 560
	ptd					556 0 560
}

# --- Ceiling ---
clippedplane_geometry
{
	name				ceilinggeom
	pta					556 549 0
	ptb					556 549 560
	ptc					0 549 560
	ptd					0 549 0
}

# --- Back wall (z=560) ---
clippedplane_geometry
{
	name				backwallgeom
	pta					0 0 560
	ptb					0 549 560
	ptc					556 549 560
	ptd					556 0 560
}

# --- Left wall (x=0) ---
clippedplane_geometry
{
	name				leftwallgeom
	pta					0 0 560
	ptb					0 0 0
	ptc					0 549 0
	ptd					0 549 560
}

# --- Right wall (x=556) ---
clippedplane_geometry
{
	name				rightwallgeom
	pta					556 0 0
	ptb					556 0 560
	ptc					556 549 560
	ptd					556 549 0
}

# --- Ceiling light ---
clippedplane_geometry
{
	name				lightgeom
	pta					343 548.8 227
	ptb					343 548.8 332
	ptc					213 548.8 332
	ptd					213 548.8 227
}

# --- Tall box ---
box_geometry
{
	name				tallboxgeom
	width				100
	height				330
	depth				100
}

# --- Short box ---
box_geometry
{
	name				shortboxgeom
	width				100
	height				165
	depth				100
}

##################################################
# Objects
##################################################

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	material			white
}

standard_object
{
	name				leftwall
	geometry			leftwallgeom
	material			red
}

standard_object
{
	name				rightwall
	geometry			rightwallgeom
	material			green
}

standard_object
{
	name				light
	geometry			lightgeom
	material			light_mat
}

standard_object
{
	name				tallbox
	geometry			tallboxgeom
	position			368 165 351
	orientation			0 -17 0
	material			white
}

standard_object
{
	name				shortbox
	geometry			shortboxgeom
	position			186 82.5 169
	orientation			0 17 0
	material			white
}
