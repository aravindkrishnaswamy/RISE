RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           pt_fog_sphere.RISEscene                                                                 #
#   Description:    Glass sphere with colored fog interior (per-object participating medium).               #
#                                                                                                           #
#                   Tests IORStack-based medium tracking.  The glass sphere refracts                        #
#                   rays into/out of its interior, and the interior medium absorbs and                      #
#                   scatters light with a warm orange tint.  Outside the sphere is vacuum.                  #
#                                                                                                           #
#                   Interior: sigma_a = (0.02, 0.06, 0.12) — blue absorbs most, warm tint                  #
#                             sigma_s = (0.03, 0.03, 0.03) — neutral scattering                            #
#                             phase   = hg 0.0  (isotropic)                                                 #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 31, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Renderer -- Unidirectional Path Tracing
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       256
}

file_rasterizeroutput
{
	pattern				rendered/pt_fog_sphere
	type				HDR
	bpp					16
	color_space			ROMMRGB_Linear
}

file_rasterizeroutput
{
	pattern				rendered/pt_fog_sphere
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera
##################################################

pinhole_camera
{
	location			0 0 -5
	lookat				0 0 0
	up					0 1 0
	width				512
	height				512
	fov					45.0
}

##################################################
# Per-object participating medium (sphere interior)
##################################################

homogeneous_medium
{
	name		sphere_fog
	absorption	0.2 0.6 1.2
	scattering	0.1 0.1 0.1
	phase		hg 0.0
}

##################################################
# Painters
##################################################

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.9
}

uniformcolor_painter
{
	name				pnt_white
	color				0.73 0.73 0.73
}

uniformcolor_painter
{
	name				pnt_green
	color				0.12 0.45 0.15
}

uniformcolor_painter
{
	name				pnt_red
	color				0.63 0.06 0.04
}

uniformcolor_painter
{
	name				pnt_glass_tau
	color				0.99 0.99 0.99
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			pnt_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

perfectrefractor_material
{
	name				glass
	refractance			pnt_glass_tau
	ior					1.5
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				100.0
	material			none
}

##################################################
# Geometry
##################################################

# --- Floor ---
clippedplane_geometry
{
	name				floorgeom
	pta					4 -1.5 -2
	ptb					-4 -1.5 -2
	ptc					-4 -1.5 6
	ptd					4 -1.5 6
}

# --- Back wall ---
clippedplane_geometry
{
	name				backwallgeom
	pta					-4 -1.5 4
	ptb					-4 4 4
	ptc					4 4 4
	ptd					4 -1.5 4
}

# --- Ceiling light ---
clippedplane_geometry
{
	name				lightgeom
	pta					1.5 3.99 -1
	ptb					1.5 3.99 2
	ptc					-1.5 3.99 2
	ptd					-1.5 3.99 -1
}

# --- Glass sphere ---
sphere_geometry
{
	name				spheregeom
	radius				1.2
}

# --- Small diffuse sphere for reference ---
sphere_geometry
{
	name				smallspheregeom
	radius				0.4
}

##################################################
# Objects
##################################################

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	material			white
}

standard_object
{
	name				light
	geometry			lightgeom
	material			light_mat
}

# Glass sphere with fog interior
standard_object
{
	name				glass_sphere
	geometry			spheregeom
	position			0 0 0
	material			glass
	interior_medium		sphere_fog
}

# Small diffuse sphere beside it for reference (no medium)
standard_object
{
	name				ref_sphere
	geometry			smallspheregeom
	position			-2.0 -1.1 0.5
	material			red
}
