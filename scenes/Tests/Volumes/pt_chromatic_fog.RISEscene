RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           pt_chromatic_fog.RISEscene                                                               #
#   Description:    Chromatic fog with different absorption/scattering per RGB channel.                     #
#                   Tests per-channel correctness of ratio tracking transmittance and                        #
#                   delta tracking with majorant grid.                                                       #
#                                                                                                           #
#                   Red channel: low absorption, high scattering (fog appears reddish)                      #
#                   Green channel: moderate absorption and scattering                                       #
#                   Blue channel: high absorption, low scattering (blue is absorbed fastest)                #
#                                                                                                           #
#                   A point light illuminates the scene to exercise equiangular MIS with                    #
#                   per-channel varying coefficients.                                                        #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 8, 2026                                                                           #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       256
	lum_samples                   1
	ior_stack                     TRUE
}

file_rasterizeroutput
{
	pattern				rendered/pt_chromatic_fog
	type				PNG
	bpp					8
	color_space			sRGB
}

file_rasterizeroutput
{
	pattern				rendered/pt_chromatic_fog
	type				HDR
	bpp					16
	color_space			ROMMRGB_Linear
}

##################################################
# Camera
##################################################

pinhole_camera
{
	location			278 273 -280
	lookat				278 273 280
	up					0 1 0
	width				512
	height				512
	fov					65.0
}

##################################################
# Chromatic Participating Medium
##################################################

homogeneous_medium
{
	name		fog
	absorption	0.0003 0.001 0.003
	scattering	0.004 0.002 0.0005
	phase		isotropic
}

> set global_medium fog

##################################################
# Point Light
##################################################

omni_light
{
	name				pointlight
	power				50000.0
	color				1.0 1.0 1.0
	position			278 280 280
}

##################################################
# Painters
##################################################

uniformcolor_painter
{
	name				pnt_white
	color				0.73 0.73 0.73
}

uniformcolor_painter
{
	name				pnt_green
	color				0.12 0.45 0.15
}

uniformcolor_painter
{
	name				pnt_red
	color				0.63 0.06 0.04
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			pnt_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

##################################################
# Cornell Box Geometry
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					556 0 0
	ptb					0 0 0
	ptc					0 0 560
	ptd					556 0 560
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					556 549 0
	ptb					556 549 560
	ptc					0 549 560
	ptd					0 549 0
}

clippedplane_geometry
{
	name				backwallgeom
	pta					0 0 560
	ptb					0 549 560
	ptc					556 549 560
	ptd					556 0 560
}

clippedplane_geometry
{
	name				leftwallgeom
	pta					0 0 560
	ptb					0 0 0
	ptc					0 549 0
	ptd					0 549 560
}

clippedplane_geometry
{
	name				rightwallgeom
	pta					556 0 0
	ptb					556 0 560
	ptc					556 549 560
	ptd					556 549 0
}

box_geometry
{
	name				tallboxgeom
	width				100
	height				330
	depth				100
}

box_geometry
{
	name				shortboxgeom
	width				100
	height				165
	depth				100
}

##################################################
# Objects
##################################################

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	material			white
}

standard_object
{
	name				leftwall
	geometry			leftwallgeom
	material			red
}

standard_object
{
	name				rightwall
	geometry			rightwallgeom
	material			green
}

standard_object
{
	name				tallbox
	geometry			tallboxgeom
	position			368 165 351
	orientation			0 -17 0
	material			white
}

standard_object
{
	name				shortbox
	geometry			shortboxgeom
	position			186 82.5 169
	orientation			0 17 0
	material			white
}
