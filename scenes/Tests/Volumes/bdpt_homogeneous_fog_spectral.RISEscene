RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           bdpt_homogeneous_fog_spectral.RISEscene                                                 #
#   Description:    Spectral (per-wavelength NM) twin of bdpt_homogeneous_fog: a Cornell box filled with    #
#                   homogeneous participating medium (isotropic fog), rendered with spectral bidirectional  #
#                   path tracing.                                                                            #
#                                                                                                           #
#                   Exists to exercise BDPTIntegrator::EvalConnectionTransmittanceNM (the single-wavelength #
#                   connection-edge transmittance walk) in a production render path.  The spectral BDPT     #
#                   rasterizer drives EvaluateAllStrategiesNM -> ConnectAndEvaluateNM ->                     #
#                   EvalConnectionTransmittanceNM at every per-wavelength NEE / interior / splat            #
#                   connection through the fog.  No existing scene covered this NM path, so the Phase-2c    #
#                   transmittance templatization had no spectral regression fixture without it.             #
#                                                                                                           #
#                   Medium/geometry/materials are byte-identical to bdpt_homogeneous_fog.RISEscene; only    #
#                   the rasterizer (pel -> spectral) and the output pattern names differ.                   #
#                                                                                                           #
#                   sigma_a = 0.0005 (low absorption)                                                       #
#                   sigma_s = 0.001  (moderate scattering for 500-unit box)                                 #
#                   phase   = isotropic                                                                     #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      June 1, 2026                                                                            #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Renderer -- Spectral Bidirectional Path Tracing
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

bdpt_spectral_rasterizer
{
	max_eye_depth		10
	max_light_depth		10
	samples				24
	max_volume_bounce	64
	nmbegin				405
	nmend				705
	num_wavelengths		8
	spectral_samples	8
}

file_rasterizeroutput
{
	pattern				rendered/bdpt_homogeneous_fog_spectral
	type				HDR
	bpp					16
	color_space			ROMMRGB_Linear
}

file_rasterizeroutput
{
	pattern				rendered/bdpt_homogeneous_fog_spectral
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera
##################################################

film
{
	width			256
	height			256
}

pinhole_camera
{
	location			278 273 -280
	lookat				278 273 280
	up					0 1 0
	fov					65.0
}

##################################################
# Participating Medium
##################################################

homogeneous_medium
{
	name		fog
	absorption	0.0005 0.0005 0.0003
	scattering	0.001 0.001 0.0001
	phase		isotropic
}

> set global_medium fog

##################################################
# Painters
##################################################

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_white
	color				0.73 0.73 0.73
}

uniformcolor_painter
{
	name				pnt_green
	color				0.12 0.45 0.15
}

uniformcolor_painter
{
	name				pnt_red
	color				0.63 0.06 0.04
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			pnt_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				150.0
	material			none
}

##################################################
# Geometry -- Cornell Box
#
# Standard Cornell box: x=[0,556], y=[0,549], z=[0,560]
##################################################

# --- Floor ---
clippedplane_geometry
{
	name				floorgeom
	pta					556 0 0
	ptb					0 0 0
	ptc					0 0 560
	ptd					556 0 560
}

# --- Ceiling ---
clippedplane_geometry
{
	name				ceilinggeom
	pta					556 549 0
	ptb					556 549 560
	ptc					0 549 560
	ptd					0 549 0
}

# --- Back wall (z=560) ---
clippedplane_geometry
{
	name				backwallgeom
	pta					0 0 560
	ptb					0 549 560
	ptc					556 549 560
	ptd					556 0 560
}

# --- Left wall (x=0) ---
clippedplane_geometry
{
	name				leftwallgeom
	pta					0 0 560
	ptb					0 0 0
	ptc					0 549 0
	ptd					0 549 560
}

# --- Right wall (x=556) ---
clippedplane_geometry
{
	name				rightwallgeom
	pta					556 0 0
	ptb					556 0 560
	ptc					556 549 560
	ptd					556 549 0
}

# --- Ceiling light ---
clippedplane_geometry
{
	name				lightgeom
	pta					343 548.8 227
	ptb					343 548.8 332
	ptc					213 548.8 332
	ptd					213 548.8 227
}

# --- Tall box ---
box_geometry
{
	name				tallboxgeom
	width				100
	height				330
	depth				100
}

# --- Short box ---
box_geometry
{
	name				shortboxgeom
	width				100
	height				165
	depth				100
}

##################################################
# Objects
##################################################

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	material			white
}

standard_object
{
	name				leftwall
	geometry			leftwallgeom
	material			red
}

standard_object
{
	name				rightwall
	geometry			rightwallgeom
	material			green
}

standard_object
{
	name				light
	geometry			lightgeom
	material			light_mat
}

standard_object
{
	name				tallbox
	geometry			tallboxgeom
	position			368 165 351
	orientation			0 -17 0
	material			white
}

standard_object
{
	name				shortbox
	geometry			shortboxgeom
	position			186 82.5 169
	orientation			0 17 0
	material			white
}
