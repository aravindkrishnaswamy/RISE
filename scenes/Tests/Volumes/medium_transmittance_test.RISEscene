RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           medium_transmittance_test.RISEscene                                                     #
#   Description:    Analytically verifiable medium transmittance test.                                      #
#                                                                                                           #
#                   A standard Cornell box with a pure-absorbing medium (sigma_s = 0).                      #
#                   With no scattering, the only medium effect is Beer-Lambert attenuation                  #
#                   along direct light paths and camera paths.                                              #
#                                                                                                           #
#                   sigma_a = 0.002, sigma_s = 0.0, sigma_t = 0.002                                        #
#                   Box depth ≈ 560 units                                                                   #
#                   Expected transmittance across box: T = exp(-0.002 * 560) = exp(-1.12) ≈ 0.326           #
#                                                                                                           #
#                   Compare to the same scene without medium to verify the attenuation                      #
#                   ratio matches the analytic value.                                                        #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 31, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Renderer -- Unidirectional Path Tracing
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       64
	lum_samples                   1
	ior_stack                     TRUE
}

file_rasterizeroutput
{
	pattern				rendered/medium_transmittance_test
	type				HDR
	bpp					16
	color_space			ROMMRGB_Linear
}

file_rasterizeroutput
{
	pattern				rendered/medium_transmittance_test
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera -- inside the box
##################################################

pinhole_camera
{
	location			278 273 -280
	lookat				278 273 280
	up					0 1 0
	width				256
	height				256
	fov					65.0
}

##################################################
# Pure absorbing medium (no scattering)
# With sigma_s=0 no scatter events contribute;
# only Beer-Lambert attenuation on direct/camera paths.
##################################################

homogeneous_medium
{
	name		absorber
	absorption	0.002 0.002 0.002
	scattering	0.0 0.0 0.0
	phase		isotropic
}

> set global_medium absorber

##################################################
# Painters
##################################################

uniformcolor_painter
{
	name				pnt_white
	color				0.73 0.73 0.73
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_green
	color				0.12 0.45 0.15
}

uniformcolor_painter
{
	name				pnt_red
	color				0.63 0.06 0.04
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			pnt_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				80.0
	material			none
}

##################################################
# Geometry -- Standard Cornell Box
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					556 0 0
	ptb					0 0 0
	ptc					0 0 560
	ptd					556 0 560
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					556 549 0
	ptb					556 549 560
	ptc					0 549 560
	ptd					0 549 0
}

clippedplane_geometry
{
	name				backwallgeom
	pta					0 0 560
	ptb					0 549 560
	ptc					556 549 560
	ptd					556 0 560
}

clippedplane_geometry
{
	name				leftwallgeom
	pta					0 0 560
	ptb					0 0 0
	ptc					0 549 0
	ptd					0 549 560
}

clippedplane_geometry
{
	name				rightwallgeom
	pta					556 0 0
	ptb					556 0 560
	ptc					556 549 560
	ptd					556 549 0
}

clippedplane_geometry
{
	name				lightgeom
	pta					343 548.8 227
	ptb					343 548.8 332
	ptc					213 548.8 332
	ptd					213 548.8 227
}

##################################################
# Objects
##################################################

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	material			white
}

standard_object
{
	name				leftwall
	geometry			leftwallgeom
	material			red
}

standard_object
{
	name				rightwall
	geometry			rightwallgeom
	material			green
}

standard_object
{
	name				light
	geometry			lightgeom
	material			light_mat
}
