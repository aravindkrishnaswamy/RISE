RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           pt_thick_fog_corridor.RISEscene                                                         #
#   Description:    Long corridor with dense fog and a point light near the middle.                        #
#                                                                                                           #
#                   Stresses equiangular MIS and NEE through deep fog.  The corridor is                    #
#                   2000 units long, 200 wide, 200 tall; the camera sits just outside one                  #
#                   end (z = -50) and the omni_light is at z = 1200 (about 60% down the                    #
#                   corridor), not at the far end.  The camera ray through the image centre                #
#                   passes directly through the light position, so equiangular sampling is                 #
#                   essential for bounded variance.                                                        #
#                                                                                                           #
#                   sigma_a = (0.0003, 0.0003, 0.0002)  sigma_s = (0.001, 0.001, 0.0008)                  #
#                   sigma_t ~= (0.0013, 0.0013, 0.0010)                                                   #
#                   optical depth camera -> far wall ~= 0.0013 * 2050 ~= 2.7                              #
#                   optical depth camera -> light    ~= 0.0013 * 1250 ~= 1.6                              #
#                   Blue has lower sigma_t, so distant surfaces are slightly blue-biased                   #
#                   but the central bloom is warm because in-scattering is sigma_s*L_e-                    #
#                   dominated and the light is warm (1.0, 0.9, 0.7).                                       #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 8, 2026                                                                           #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       256
	# Clamp single-path NEE contributions.  Same rationale as
	# pt_chromatic_fog: equiangular MIS tames the 1/r^2 singularity at
	# the omni_light so the estimator is finite-variance, but rare
	# camera-ray -> scatter-through-light paths can still deposit a
	# very bright single-sample NEE.  This light is 400x brighter than
	# the one in pt_chromatic_fog (power 20M vs 50K), so the clamp is
	# scaled accordingly (5 * 400 = 2000) to preserve the same effective
	# outlier-truncation ratio without dimming the legitimate bright
	# bloom at the image centre.
	#
	# Note: clamp=2000 catches the worst firefly spikes (off-center max
	# 5.6 -> 2.8) but much of the visible speckle at 256 spp is inherent
	# MC noise from the central ray passing directly through the light
	# position at D=0.  Bump samples to 1024+ for a cleaner image, or
	# disable the clamp for ground-truth convergence work.
	direct_clamp                  2000
}

file_rasterizeroutput
{
	pattern				rendered/pt_thick_fog_corridor
	type				PNG
	bpp					8
	color_space			sRGB
}

file_rasterizeroutput
{
	pattern				rendered/pt_thick_fog_corridor
	type				HDR
	bpp					16
	color_space			ROMMRGB_Linear
}

##################################################
# Camera at near end of corridor
##################################################

pinhole_camera
{
	location			100 100 -50
	lookat				100 100 1000
	up					0 1 0
	width				512
	height				256
	fov					60.0
}

##################################################
# Dense Participating Medium
##################################################

homogeneous_medium
{
	name		fog
	absorption	0.0003 0.0003 0.0002
	scattering	0.001 0.001 0.0008
	phase		isotropic
}

> set global_medium fog

##################################################
# Point Light ~60% down the corridor (z = 1200)
##################################################

omni_light
{
	name				farlight
	power				20000000.0
	color				1.0 0.9 0.7
	position			100 100 1200
}

##################################################
# Painters
##################################################

uniformcolor_painter
{
	name				pnt_white
	color				0.8 0.8 0.8
}

uniformcolor_painter
{
	name				pnt_grey
	color				0.5 0.5 0.5
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				walls
	reflectance			pnt_white
}

lambertian_material
{
	name				floor_mat
	reflectance			pnt_grey
}

##################################################
# Corridor Geometry (200 x 200 x 2000)
##################################################

# Floor (y=0)
clippedplane_geometry
{
	name				floorgeom
	pta					200 0 0
	ptb					0 0 0
	ptc					0 0 2000
	ptd					200 0 2000
}

# Ceiling (y=200)
clippedplane_geometry
{
	name				ceilinggeom
	pta					0 200 0
	ptb					200 200 0
	ptc					200 200 2000
	ptd					0 200 2000
}

# Left wall (x=0)
clippedplane_geometry
{
	name				leftwallgeom
	pta					0 0 0
	ptb					0 200 0
	ptc					0 200 2000
	ptd					0 0 2000
}

# Right wall (x=200)
clippedplane_geometry
{
	name				rightwallgeom
	pta					200 0 2000
	ptb					200 200 2000
	ptc					200 200 0
	ptd					200 0 0
}

# Far wall (z=2000)
clippedplane_geometry
{
	name				farwallgeom
	pta					0 0 2000
	ptb					0 200 2000
	ptc					200 200 2000
	ptd					200 0 2000
}

##################################################
# Objects
##################################################

standard_object
{
	name				floor
	geometry			floorgeom
	material			floor_mat
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			walls
}

standard_object
{
	name				leftwall
	geometry			leftwallgeom
	material			walls
}

standard_object
{
	name				rightwall
	geometry			rightwallgeom
	material			walls
}

standard_object
{
	name				farwall
	geometry			farwallgeom
	material			walls
}
