RISE ASCII SCENE 5
#############################################################################################################
#   File:           pt_painter_gabor3d_grid.RISEscene                                                        #
#   Description:    3x3 grid of Gabor noise fog volumes.                                                   #
#                   Row 1: Vary ORIENTATION  Row 2: Vary FREQUENCY  Row 3: Vary BANDWIDTH                  #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 13, 2026                                                                          #
#############################################################################################################

> set accelerator B 10 8

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       64
}

file_rasterizeroutput
{
	pattern				rendered/pt_painter_gabor3d_grid
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			0 210 -500
	lookat				0 210 0
	up					0 1 0
	width				512
	height				512
	fov					50.0
}

uniformcolor_painter
{
	name		pnt_dense
	color		1.0 1.0 1.0
}

uniformcolor_painter
{
	name		pnt_sparse
	color		0.0 0.0 0.0
}

# Row 1: Vary ORIENTATION
gabor3d_painter
{
	name		pnt_r1c1
	frequency	4.0
	bandwidth	1.5
	orientation	1 0 0
	impulse_density	4.0
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.015 0.015 0.015
	shift		0 0 0
}

gabor3d_painter
{
	name		pnt_r1c2
	frequency	4.0
	bandwidth	1.5
	orientation	0 1 0
	impulse_density	4.0
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.015 0.015 0.015
	shift		0 0 0
}

gabor3d_painter
{
	name		pnt_r1c3
	frequency	4.0
	bandwidth	1.5
	orientation	1 1 1
	impulse_density	4.0
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.015 0.015 0.015
	shift		0 0 0
}

# Row 2: Vary FREQUENCY
gabor3d_painter
{
	name		pnt_r2c1
	frequency	1.0
	bandwidth	1.5
	orientation	0 1 0
	impulse_density	4.0
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.015 0.015 0.015
	shift		0 0 0
}

gabor3d_painter
{
	name		pnt_r2c2
	frequency	4.0
	bandwidth	1.5
	orientation	0 1 0
	impulse_density	4.0
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.015 0.015 0.015
	shift		0 0 0
}

gabor3d_painter
{
	name		pnt_r2c3
	frequency	12.0
	bandwidth	1.5
	orientation	0 1 0
	impulse_density	4.0
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.015 0.015 0.015
	shift		0 0 0
}

# Row 3: Vary BANDWIDTH
gabor3d_painter
{
	name		pnt_r3c1
	frequency	4.0
	bandwidth	0.5
	orientation	0 1 0
	impulse_density	4.0
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.015 0.015 0.015
	shift		0 0 0
}

gabor3d_painter
{
	name		pnt_r3c2
	frequency	4.0
	bandwidth	1.5
	orientation	0 1 0
	impulse_density	4.0
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.015 0.015 0.015
	shift		0 0 0
}

gabor3d_painter
{
	name		pnt_r3c3
	frequency	4.0
	bandwidth	4.0
	orientation	0 1 0
	impulse_density	4.0
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.015 0.015 0.015
	shift		0 0 0
}

# Media
painter_heterogeneous_medium
{
	name		med_r1c1
	absorption	0.005 0.008 0.012
	scattering	0.065 0.05 0.035
	phase		isotropic
	density_painter	pnt_r1c1
	resolution	48
	color_to_scalar	luminance
	bbox_min	-210 0 -60
	bbox_max	-90 120 60
}

painter_heterogeneous_medium
{
	name		med_r1c2
	absorption	0.008 0.008 0.008
	scattering	0.06 0.06 0.06
	phase		isotropic
	density_painter	pnt_r1c2
	resolution	48
	color_to_scalar	luminance
	bbox_min	-60 0 -60
	bbox_max	60 120 60
}

painter_heterogeneous_medium
{
	name		med_r1c3
	absorption	0.012 0.008 0.005
	scattering	0.035 0.05 0.065
	phase		isotropic
	density_painter	pnt_r1c3
	resolution	48
	color_to_scalar	luminance
	bbox_min	90 0 -60
	bbox_max	210 120 60
}

painter_heterogeneous_medium
{
	name		med_r2c1
	absorption	0.005 0.008 0.012
	scattering	0.065 0.05 0.035
	phase		isotropic
	density_painter	pnt_r2c1
	resolution	48
	color_to_scalar	luminance
	bbox_min	-210 150 -60
	bbox_max	-90 270 60
}

painter_heterogeneous_medium
{
	name		med_r2c2
	absorption	0.008 0.008 0.008
	scattering	0.06 0.06 0.06
	phase		isotropic
	density_painter	pnt_r2c2
	resolution	48
	color_to_scalar	luminance
	bbox_min	-60 150 -60
	bbox_max	60 270 60
}

painter_heterogeneous_medium
{
	name		med_r2c3
	absorption	0.012 0.008 0.005
	scattering	0.035 0.05 0.065
	phase		isotropic
	density_painter	pnt_r2c3
	resolution	48
	color_to_scalar	luminance
	bbox_min	90 150 -60
	bbox_max	210 270 60
}

painter_heterogeneous_medium
{
	name		med_r3c1
	absorption	0.005 0.008 0.012
	scattering	0.065 0.05 0.035
	phase		isotropic
	density_painter	pnt_r3c1
	resolution	48
	color_to_scalar	luminance
	bbox_min	-210 300 -60
	bbox_max	-90 420 60
}

painter_heterogeneous_medium
{
	name		med_r3c2
	absorption	0.008 0.008 0.008
	scattering	0.06 0.06 0.06
	phase		isotropic
	density_painter	pnt_r3c2
	resolution	48
	color_to_scalar	luminance
	bbox_min	-60 300 -60
	bbox_max	60 420 60
}

painter_heterogeneous_medium
{
	name		med_r3c3
	absorption	0.012 0.008 0.005
	scattering	0.035 0.05 0.065
	phase		isotropic
	density_painter	pnt_r3c3
	resolution	48
	color_to_scalar	luminance
	bbox_min	90 300 -60
	bbox_max	210 420 60
}

# Materials & Geometry
uniformcolor_painter
{
	name		pnt_white
	color		1.0 1.0 1.0
}

uniformcolor_painter
{
	name		pnt_light
	color		1.0 0.95 0.9
}

uniformcolor_painter
{
	name		pnt_sphere
	color		0.9 0.9 0.9
}

perfectrefractor_material
{
	name		air
	refractance	pnt_white
	ior			1.0002
}

lambertian_material
{
	name		sphere_mat
	reflectance	pnt_sphere
}

lambertian_luminaire_material
{
	name		light_mat
	exitance	pnt_light
	scale		55.0
	material	none
}

box_geometry
{
	name		boxgeom
	width		120
	height		120
	depth		120
}

sphere_geometry
{
	name		spheregeom
	radius		20.0
}

clippedplane_geometry
{
	name		lightgeom
	pta			300 0 120
	ptb			-300 0 120
	ptc			-300 450 120
	ptd			300 450 120
}

standard_object
{
	name		vol_r1c1
	geometry	boxgeom
	material	air
	position	-150 60 0
	interior_medium	med_r1c1
	casts_shadows	FALSE
}

standard_object
{
	name		vol_r1c2
	geometry	boxgeom
	material	air
	position	0 60 0
	interior_medium	med_r1c2
	casts_shadows	FALSE
}

