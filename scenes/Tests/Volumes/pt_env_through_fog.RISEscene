RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           pt_env_through_fog.RISEscene                                                            #
#   Description:    PT reference twin for vcm_env_through_fog.RISEscene.  Identical geometry, fog,          #
#                   and env-IBL setup; replaces the rasterizer with PT at higher SPP for the                #
#                   reference image used to validate the VCM fix.                                           #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      May 31, 2026                                                                            #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Painters (declared FIRST so the rasterizer's
# radiance_map reference resolves at finalize time)
##################################################

uniformcolor_painter
{
	name				pnt_env
	color				1.0 1.0 1.0
}

##################################################
# Renderer -- Path Tracing reference
##################################################

standard_shader
{
	name		global
	shaderop	DefaultDirectLighting
}

pathtracing_pel_rasterizer
{
	samples				256
	max_volume_bounce	16
	pixel_filter		box
	radiance_map		pnt_env
	radiance_scale		1.0
	radiance_background	TRUE
}

file_rasterizeroutput
{
	pattern				rendered/pt_env_through_fog
	type				HDR
	bpp					16
	color_space			Rec709RGB_Linear
}

file_rasterizeroutput
{
	pattern				rendered/pt_env_through_fog
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera
##################################################

film
{
	width			128
	height			128
}

pinhole_camera
{
	location			278 273 -600
	lookat				278 273 280
	up					0 1 0
	fov					50.0
}

##################################################
# Participating Medium
##################################################

homogeneous_medium
{
	name		fog
	absorption	0.0003 0.0003 0.0003
	scattering	0.0007 0.0007 0.0007
	phase		isotropic
}

> set global_medium fog

uniformcolor_painter
{
	name				pnt_white
	color				0.73 0.73 0.73
}

uniformcolor_painter
{
	name				pnt_green
	color				0.12 0.45 0.15
}

uniformcolor_painter
{
	name				pnt_red
	color				0.63 0.06 0.04
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			pnt_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

##################################################
# Geometry
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					556 0 0
	ptb					0 0 0
	ptc					0 0 560
	ptd					556 0 560
}

clippedplane_geometry
{
	name				backwallgeom
	pta					0 0 560
	ptb					0 549 560
	ptc					556 549 560
	ptd					556 0 560
}

clippedplane_geometry
{
	name				leftwallgeom
	pta					0 0 560
	ptb					0 0 0
	ptc					0 549 0
	ptd					0 549 560
}

clippedplane_geometry
{
	name				rightwallgeom
	pta					556 0 0
	ptb					556 0 560
	ptc					556 549 560
	ptd					556 549 0
}

##################################################
# Objects
##################################################

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	material			white
}

standard_object
{
	name				leftwall
	geometry			leftwallgeom
	material			red
}

standard_object
{
	name				rightwall
	geometry			rightwallgeom
	material			green
}
