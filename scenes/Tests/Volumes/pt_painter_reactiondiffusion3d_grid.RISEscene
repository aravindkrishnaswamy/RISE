RISE ASCII SCENE 5
# 3x3 grid of Reaction-Diffusion fog volumes.
# Row 1: Vary FEED/KILL (spots / mixed / stripes)
# Row 2: Vary ITERATIONS (less evolved / medium / well evolved)
# Row 3: Vary GRID_SIZE (coarse / medium / fine)

> set accelerator B 10 8

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       64
}

file_rasterizeroutput
{
	pattern				rendered/pt_painter_reactiondiffusion3d_grid
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			0 210 -500
	lookat				0 210 0
	up					0 1 0
	width				512
	height				512
	fov					50.0
}

uniformcolor_painter
{
	name		pnt_dense
	color		1.0 1.0 1.0
}

uniformcolor_painter
{
	name		pnt_sparse
	color		0.0 0.0 0.0
}

# Row 1: Vary FEED/KILL pattern type
reactiondiffusion3d_painter
{
	name		pnt_r1c1
	grid_size	24
	da			0.2
	db			0.1
	feed		0.03
	kill		0.055
	iterations	1500
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.01 0.01 0.01
	shift		0 0 0
}

reactiondiffusion3d_painter
{
	name		pnt_r1c2
	grid_size	24
	da			0.2
	db			0.1
	feed		0.037
	kill		0.06
	iterations	1500
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.01 0.01 0.01
	shift		0 0 0
}

reactiondiffusion3d_painter
{
	name		pnt_r1c3
	grid_size	24
	da			0.2
	db			0.1
	feed		0.04
	kill		0.065
	iterations	1500
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.01 0.01 0.01
	shift		0 0 0
}

