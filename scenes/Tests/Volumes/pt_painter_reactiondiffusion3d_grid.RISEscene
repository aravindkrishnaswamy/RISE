# Materials & Geometry
uniformcolor_painter
{
	name		pnt_white
	color		1.0 1.0 1.0
}

uniformcolor_painter
{
	name		pnt_light
	color		1.0 0.95 0.9
}

uniformcolor_painter
{
	name		pnt_sphere
	color		0.9 0.9 0.9
}

perfectrefractor_material
{
	name		air
	refractance	pnt_white
	ior			1.0002
}

lambertian_material
{
	name		sphere_mat
	reflectance	pnt_sphere
}

lambertian_luminaire_material
{
	name		light_mat
	exitance	pnt_light
	scale		4.0
	material	none
}

box_geometry
{
	name		boxgeom
	width		120
	height		120
	depth		120
}

sphere_geometry
{
	name		spheregeom
	radius		20.0
}

clippedplane_geometry
{
	name		lightgeom
	pta			300 0 120
	ptb			-300 0 120
	ptc			-300 450 120
	ptd			300 450 120
}

