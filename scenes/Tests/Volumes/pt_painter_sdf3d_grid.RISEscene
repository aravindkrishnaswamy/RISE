RISE ASCII SCENE 5
#############################################################################################################
#                                                                                                           #
#   File:           pt_painter_sdf3d_grid.RISEscene                                                         #
#   Description:    3x3 grid of SDF primitive fog volumes.                                                 #
#                                                                                                           #
#                   Row 1 (bottom): Vary TYPE           -- Sphere / Box / Torus                             #
#                   Row 2 (middle): Vary NOISE_AMP      -- 0 / 0.08 / 0.2                                  #
#                   Row 3 (top):    Vary SHELL_THICKNESS -- 0 (solid) / 0.05 / 0.15                         #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 13, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       64
}

file_rasterizeroutput
{
	pattern				rendered/pt_painter_sdf3d_grid
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			0 210 -500
	lookat				0 210 0
	up					0 1 0
	width				512
	height				512
	fov					50.0
}

uniformcolor_painter
{
	name		pnt_dense
	color		1.0 1.0 1.0
}

uniformcolor_painter
{
	name		pnt_sparse
	color		0.0 0.0 0.0
}

# Each SDF operates in a centered coordinate system.
# Scale maps from world-space bbox to SDF space.
# For a 120-unit box, scale = 1/120 * 2 = 0.0167 centers the [-1,1] range.

# --- Row 1: Vary TYPE (no noise, solid) ---
sdf3d_painter
{
	name		pnt_r1c1
	type		sphere
	param1		0.4
	param2		0
	param3		0
	shell_thickness	0
	noise_amplitude	0
	noise_frequency	1
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.0167 0.0167 0.0167
	shift		0 0 0
}

sdf3d_painter
{
	name		pnt_r1c2
	type		box
	param1		0.35
	param2		0.35
	param3		0.35
	shell_thickness	0
	noise_amplitude	0
	noise_frequency	1
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.0167 0.0167 0.0167
	shift		0 0 0
}

sdf3d_painter
{
	name		pnt_r1c3
	type		torus
	param1		0.35
	param2		0.15
	param3		0
	shell_thickness	0
	noise_amplitude	0
	noise_frequency	1
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.0167 0.0167 0.0167
	shift		0 0 0
}

# --- Row 2: Vary NOISE_AMPLITUDE (sphere, solid) ---
sdf3d_painter
{
	name		pnt_r2c1
	type		sphere
	param1		0.4
	param2		0
	param3		0
	shell_thickness	0
	noise_amplitude	0
	noise_frequency	4
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.0167 0.0167 0.0167
	shift		0 0 0
}

sdf3d_painter
{
	name		pnt_r2c2
	type		sphere
	param1		0.4
	param2		0
	param3		0
	shell_thickness	0
	noise_amplitude	0.08
	noise_frequency	4
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.0167 0.0167 0.0167
	shift		0 0 0
}

sdf3d_painter
{
	name		pnt_r2c3
	type		sphere
	param1		0.4
	param2		0
	param3		0
	shell_thickness	0
	noise_amplitude	0.2
	noise_frequency	4
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.0167 0.0167 0.0167
	shift		0 0 0
}

# --- Row 3: Vary SHELL_THICKNESS (sphere, no noise) ---
sdf3d_painter
{
	name		pnt_r3c1
	type		sphere
	param1		0.4
	param2		0
	param3		0
	shell_thickness	0
	noise_amplitude	0
	noise_frequency	1
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.0167 0.0167 0.0167
	shift		0 0 0
}

sdf3d_painter
{
	name		pnt_r3c2
	type		sphere
	param1		0.4
	param2		0
	param3		0
	shell_thickness	0.05
	noise_amplitude	0
	noise_frequency	1
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.0167 0.0167 0.0167
	shift		0 0 0
}

sdf3d_painter
{
	name		pnt_r3c3
	type		sphere
	param1		0.4
	param2		0
	param3		0
	shell_thickness	0.15
	noise_amplitude	0
	noise_frequency	1
	colora		pnt_dense
	colorb		pnt_sparse
	scale		0.0167 0.0167 0.0167
	shift		0 0 0
}

##################################################
# Media
##################################################

painter_heterogeneous_medium
{
	name		med_r1c1
	absorption	0.005 0.008 0.012
	scattering	0.08 0.06 0.04
	phase		isotropic
	density_painter	pnt_r1c1
	resolution	48
	color_to_scalar	luminance
	bbox_min	-210 0 -60
	bbox_max	-90 120 60
}

painter_heterogeneous_medium
{
	name		med_r1c2
	absorption	0.008 0.008 0.008
	scattering	0.07 0.07 0.07
	phase		isotropic
	density_painter	pnt_r1c2
	resolution	48
	color_to_scalar	luminance
	bbox_min	-60 0 -60
	bbox_max	60 120 60
}

painter_heterogeneous_medium
{
	name		med_r1c3
	absorption	0.012 0.008 0.005
	scattering	0.04 0.06 0.08
	phase		isotropic
	density_painter	pnt_r1c3
	resolution	48
	color_to_scalar	luminance
	bbox_min	90 0 -60
	bbox_max	210 120 60
}

painter_heterogeneous_medium
{
	name		med_r2c1
	absorption	0.005 0.008 0.012
	scattering	0.08 0.06 0.04
	phase		isotropic
	density_painter	pnt_r2c1
	resolution	48
	color_to_scalar	luminance
	bbox_min	-210 150 -60
	bbox_max	-90 270 60
}

painter_heterogeneous_medium
{
	name		med_r2c2
	absorption	0.008 0.008 0.008
	scattering	0.07 0.07 0.07
	phase		isotropic
	density_painter	pnt_r2c2
	resolution	48
	color_to_scalar	luminance
	bbox_min	-60 150 -60
	bbox_max	60 270 60
}

painter_heterogeneous_medium
{
	name		med_r2c3
	absorption	0.012 0.008 0.005
	scattering	0.04 0.06 0.08
	phase		isotropic
	density_painter	pnt_r2c3
	resolution	48
	color_to_scalar	luminance
	bbox_min	90 150 -60
	bbox_max	210 270 60
}

painter_heterogeneous_medium
{
	name		med_r3c1
	absorption	0.005 0.008 0.012
	scattering	0.08 0.06 0.04
	phase		isotropic
	density_painter	pnt_r3c1
	resolution	48
	color_to_scalar	luminance
	bbox_min	-210 300 -60
	bbox_max	-90 420 60
}

painter_heterogeneous_medium
{
	name		med_r3c2
	absorption	0.008 0.008 0.008
	scattering	0.07 0.07 0.07
	phase		isotropic
	density_painter	pnt_r3c2
	resolution	48
	color_to_scalar	luminance
	bbox_min	-60 300 -60
	bbox_max	60 420 60
}

painter_heterogeneous_medium
{
	name		med_r3c3
	absorption	0.012 0.008 0.005
	scattering	0.04 0.06 0.08
	phase		isotropic
	density_painter	pnt_r3c3
	resolution	48
	color_to_scalar	luminance
	bbox_min	90 300 -60
	bbox_max	210 420 60
}

##################################################
# Materials & Geometry
##################################################

uniformcolor_painter
{
	name		pnt_white
	color		1.0 1.0 1.0
}

uniformcolor_painter
{
	name		pnt_light
	color		1.0 0.95 0.9
}

uniformcolor_painter
{
	name		pnt_sphere
	color		0.9 0.9 0.9
}

perfectrefractor_material
{
	name		air
	refractance	pnt_white
	ior			1.0002
}

lambertian_material
{
	name		sphere_mat
	reflectance	pnt_sphere
}

lambertian_luminaire_material
{
	name		light_mat
	exitance	pnt_light
	scale		55.0
	material	none
}

box_geometry
{
	name		boxgeom
	width		120
	height		120
	depth		120
}

sphere_geometry
{
	name		spheregeom
	radius		20.0
}

clippedplane_geometry
{
	name		lightgeom
	pta			300 0 120
	ptb			-300 0 120
	ptc			-300 450 120
	ptd			300 450 120
}

standard_object
{
	name		vol_r1c1
	geometry	boxgeom
	material	air
	position	-150 60 0
	interior_medium	med_r1c1
	casts_shadows	FALSE
}

