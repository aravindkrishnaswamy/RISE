RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           ggx_vs_cooktorrance.RISEscene                                                          #
#   Description:    Side-by-side comparison of GGX (height-correlated G2) vs CookTorrance (separable G1*G1)#
#                   at matching roughness values. Both use GGX NDF, VNDF sampling, and Kulla-Conty.         #
#                   The GGX material should be slightly brighter at mid-roughness due to less masking loss.  #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 6, 2026                                                                           #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       64
}

file_rasterizeroutput
{
	pattern				rendered/ggx_vs_cooktorrance
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

pinhole_camera
{
	location			278 273 -800
	lookat				278 273 200
	up					0 1 0
	width				512
	height				512
	fov					39.0
}

##################################################
# Painters
##################################################
> run scenes/colors.RISEscript

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_black
	color				0.0 0.0 0.0
}

uniformcolor_painter
{
	name				pnt_gold_spec
	color				1.0 0.85 0.35
}

##################################################
# GGX Materials (height-correlated G2) - Left column
##################################################

ggx_material
{
	name				ggx_01
	rd					pnt_black
	rs					pnt_gold_spec
	alphax				0.1
	alphay				0.1
	ior					2.5
	extinction			3.0
}

ggx_material
{
	name				ggx_03
	rd					pnt_black
	rs					pnt_gold_spec
	alphax				0.3
	alphay				0.3
	ior					2.5
	extinction			3.0
}

ggx_material
{
	name				ggx_06
	rd					pnt_black
	rs					pnt_gold_spec
	alphax				0.6
	alphay				0.6
	ior					2.5
	extinction			3.0
}

ggx_material
{
	name				ggx_10
	rd					pnt_black
	rs					pnt_gold_spec
	alphax				1.0
	alphay				1.0
	ior					2.5
	extinction			3.0
}

##################################################
# CookTorrance Materials (separable G1*G1) - Right column
##################################################

cooktorrance_material
{
	name				ct_01
	rd					pnt_black
	rs					pnt_gold_spec
	facets				0.1
	ior					2.5
	extinction			3.0
}

cooktorrance_material
{
	name				ct_03
	rd					pnt_black
	rs					pnt_gold_spec
	facets				0.3
	ior					2.5
	extinction			3.0
}

cooktorrance_material
{
	name				ct_06
	rd					pnt_black
	rs					pnt_gold_spec
	facets				0.6
	ior					2.5
	extinction			3.0
}

cooktorrance_material
{
	name				ct_10
	rd					pnt_black
	rs					pnt_gold_spec
	facets				1.0
	ior					2.5
	extinction			3.0
}

##################################################
# Wall materials
##################################################

lambertian_material
{
	name				white
	reflectance			color_white
}

lambertian_material
{
	name				green
	reflectance			color_cornellgreen
}

lambertian_material
{
	name				red
	reflectance			color_cornellred
}

lambertian_luminaire_material
{
	name				white_lum
	exitance			pnt_light
	scale				70.0
	material			none
}

##################################################
# Cornell box walls
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					552.8 0 0
	ptb					0 0 0
	ptc					0 0 559.2
	ptd					549.6 0 559.2
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					556.0 548.8 0.0
	ptb					556.0 548.8 559.2
	ptc					0 548.8 559.2
	ptd					0.0 548.8 0.0
}

clippedplane_geometry
{
	name				bwallgeom
	pta					549.6 0 559.2
	ptb					0 0 559.2
	ptc					0 548.8 559.2
	ptd					556.0 548.8 559.2
}

clippedplane_geometry
{
	name				rwallgeom
	pta					0 0 559.2
	ptb					0 0 0
	ptc					0 548.8 0.0
	ptd					0 548.8 559.2
}

clippedplane_geometry
{
	name				lwallgeom
	pta					552.8 0 0
	ptb					549.6 0 559.2
	ptc					556.0 548.8 559.2
	ptd					556.0 548.8 0
}

clippedplane_geometry
{
	name				lightgeom
	pta					393.0 548.7999 177.0
	ptb					393.0 548.7999 382.0
	ptc					163.0 548.7999 382.0
	ptd					163.0 548.7999 177.0
}

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				bwall
	geometry			bwallgeom
	material			white
}

standard_object
{
	name				rwall
	geometry			rwallgeom
	material			green
}

standard_object
{
	name				lwall
	geometry			lwallgeom
	material			red
}

standard_object
{
	name				light
	geometry			lightgeom
	material			white_lum
}

##################################################
# Sphere geometry
##################################################

sphere_geometry
{
	name				spheregeom
	radius				52.0
}

##################################################
# Left column: GGX (height-correlated)
# Right column: CookTorrance (separable)
# Rows: alpha = 0.1, 0.3, 0.6, 1.0 (top to bottom)
##################################################

# alpha = 0.1
standard_object
{
	name				sphere_ggx_01
	geometry			spheregeom
	position			190 430 300
	material			ggx_01
}

standard_object
{
	name				sphere_ct_01
	geometry			spheregeom
	position			370 430 300
	material			ct_01
}

# alpha = 0.3
standard_object
{
	name				sphere_ggx_03
	geometry			spheregeom
	position			190 320 290
	material			ggx_03
}

standard_object
{
	name				sphere_ct_03
	geometry			spheregeom
	position			370 320 290
	material			ct_03
}

# alpha = 0.6
standard_object
{
	name				sphere_ggx_06
	geometry			spheregeom
	position			190 210 280
	material			ggx_06
}

standard_object
{
	name				sphere_ct_06
	geometry			spheregeom
	position			370 210 280
	material			ct_06
}

# alpha = 1.0
standard_object
{
	name				sphere_ggx_10
	geometry			spheregeom
	position			190 100 270
	material			ggx_10
}

standard_object
{
	name				sphere_ct_10
	geometry			spheregeom
	position			370 100 270
	material			ct_10
}
