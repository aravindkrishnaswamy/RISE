RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           dielectrics_changing_ior.RISEscene                                                      #
#   Description:    Shows the dielectric material with changing index of refraction values.  The scattering #
#                   is left entirely coherent by setting it to 10000, which is effectively infinity.        #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      August 7, 2002                                                                          #
#                                                                                                           #
#############################################################################################################

> echo warning Warning! This scene is CPU intensive and may take a few minutes to render on slower machines.

##################################################
# Setup a renderer
##################################################

pathtracing_shaderop
{
	name			pathtracer_noreflections
	refractions		true
	diffuse			false
}

pathtracing_shaderop
{
	name			pathtracer
}

# We want to setup an advanced shader to only do reflections on the first couple of bounces
# so that we can avoid total internal reflection.  The flexibility of the advanced shader
# lets us do this
advanced_shader
{
	name			global
	shaderop		pathtracer					0 1			+
	shaderop		pathtracer_noreflections	1 10		+
}

pixelpel_rasterizer
{
	max_recursion		10
	samples				256
	lum_samples			4
	pixel_filter		tent
	pixel_filter_width	1.7
	pixel_filter_height	1.7
}

file_rasterizeroutput
{
	pattern				rendered/dielectrics_changing_ior
	type				HDR
	bpp					16
	color_space			ROMMRGB_Linear
}

##################################################
# Cameras
##################################################

pinhole_camera
{
	location			0 -0.2 3.2
	lookat				0 -0.2 1.0
	up					0 1 0
	width				1280
	height				480
	fov					30.0
	theta				15
}

##################################################
# Painters
##################################################

> run scenes/colors.RISEscript

checker_painter
{
	name				pnt_check
	size				0.5
	colora				color_white
	colorb				color_black
}

##################################################
# Materials
##################################################

dielectric_material
{
	name				dieA
	tau					color_white
	ior					1.000292
	scattering				100000
}

dielectric_material
{
	name				dieB
	tau					color_white
	ior					1.33
	scattering				100000
}

dielectric_material
{
	name				dieC
	tau					color_white
	ior					1.51
	scattering				100000
}

dielectric_material
{
	name				dieD
	tau					color_white
	ior					1.71
	scattering				100000
}

dielectric_material
{
	name				dieE
	tau					color_white
	ior					2.47
	scattering				100000
}

lambertian_material
{
	name				white
	reflectance			color_white
}

lambertian_luminaire_material
{
	name				white_lum
	exitance			color_white
	scale				40.0
	material			white
}

lambertian_material
{
	name				checker
	reflectance			pnt_check
}

##################################################
# Objects
##################################################

infiniteplane_geometry
{
	name				planegeom
	xtile				0.1
	ytile				0.1
}

standard_object
{
	name				planeA
	geometry			planegeom
	position			0.0 -0.3 0.0
	orientation			-90.0 0.0 45.0
	material			checker
}

clippedplane_geometry
{
	name				lightgeom
	pta					-1.0 0.0 1.0
	ptb					-1.0 0.0 -1.0
	ptc					1.0 0.0 -1.0
	ptd					1.0 0.0 1.0
}

standard_object
{
	name				light
	geometry			lightgeom
	position			0 4.0 0.0
	material			white_lum
}



sphere_geometry
{
	name				spheregeom
	radius				0.2
}

standard_object
{
	name				sphereA
	geometry			spheregeom
	position			-1.0 0 1.2
	material			dieA
}

standard_object
{
	name				sphereB
	geometry			spheregeom
	position			-0.5 0 1.2
	material			dieB
}


standard_object
{
	name				sphereC
	geometry			spheregeom
	position			0.0 0 1.2
	material			dieC
}


standard_object
{
	name				sphereD
	geometry			spheregeom
	position			0.5 0 1.2
	material			dieD
}


standard_object
{
	name				sphereE
	geometry			spheregeom
	position			1.0 0 1.2
	material			dieE
}
