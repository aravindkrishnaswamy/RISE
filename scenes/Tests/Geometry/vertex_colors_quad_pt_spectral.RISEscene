RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           vertex_colors_quad_pt_spectral.RISEscene                                                #
#   Description:    Spectral (NM) unidirectional PATH-TRACED reference for the vertex-color quad.  PT      #
#                   shades through the LIVE RayIntersectionGeometric (vColor always populated by the       #
#                   geometry at the hit), so this is the ground-truth the spectral BDPT render must match. #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      2026-06-01                                                                              #
#                                                                                                           #
#############################################################################################################

standard_shader
{
	name			global
	shaderop		DefaultPathTracing
}

pathtracing_spectral_rasterizer
{
	samples				64
	pixel_filter        box
}

file_rasterizeroutput
{
	pattern				rendered/vertex_colors_quad_pt_spectral
	type				PNG
	bpp					8
	color_space			sRGB
}

film
{
	width			128
	height			128
}

pinhole_camera
{
	location			0 0 3.5
	lookat				0 0 0
	up					0 1 0
	fov					30.0
}

vertex_color_painter
{
	name				pnt_vcolor
	fallback			1.0 1.0 1.0
	colorspace			sRGB
}

lambertian_material
{
	name				vcolor_lambert
	reflectance			pnt_vcolor
}

plymesh_geometry
{
	name				vcolor_quad_geom
	file				scenes/Tests/Geometry/vertex_colors_quad.ply
	double_sided		TRUE
}

standard_object
{
	name				vcolor_quad
	geometry			vcolor_quad_geom
	material			vcolor_lambert
	receives_shadows	FALSE
	casts_shadows		FALSE
}

omni_light
{
	name				key
	power				4.0
	color				1.0 1.0 1.0
	position			0.0 0.0 5.0
}
