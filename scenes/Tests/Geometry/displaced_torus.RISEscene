RISE ASCII SCENE 6
# Displaced torus test scene.  Exercises u- and v-seam handling.

> set accelerator B 10 8

standard_shader
{
	name			global
	shaderop		DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion		6
	samples				4
	lum_samples			1
}

file_rasterizeroutput
{
	pattern				rendered/displaced_torus
	type				PNG
	bpp					8
	color_space			sRGB
}

film
{
	width			256
	height			256
}

pinhole_camera
{
	location			0 2.5 3.5
	lookat				0 0 0
	up					0 1 0
	fov					30.0
}

