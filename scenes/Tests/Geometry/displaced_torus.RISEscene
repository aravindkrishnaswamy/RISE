#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################















#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           povray_colors.RISEscene                                                                 #
#   Description:    Contains colors taken from POV-Ray                                                      #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################
















uniformcolor_painter
{
	name		color_gold
	color		0.8 0.498039 0.196078 
}






	
	

	




































































png_painter
{
	name				pnt_bump
	file				textures/waterbump.png
}

lambertian_material
{
	name				lambert_gold
	reflectance			color_gold
}

torus_geometry
{
	name				base_torus
	majorradius			1.0
	minorratio			0.3
}

displaced_geometry
{
	name				disp_torus
	base_geometry		base_torus
	detail				128
	displacement		pnt_bump
	disp_scale			0.07
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

standard_object
{
	name				the_torus
	geometry			disp_torus
	material			lambert_gold
	position			0 0 0
}

directional_light
{
	name				light
	power				3.14
	color				1.0 1.0 1.0
	direction			0.3 0.5 1.0
}


