RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           vertex_colors_quad.RISEscene                                                            #
#   Description:    Tests per-vertex color support: four-vertex quad with R/G/B/W vertex colors driving    #
#                   a Lambertian albedo via vertex_color_painter.  Loaded from a Stanford PLY.              #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      2026-04-28                                                                              #
#                                                                                                           #
#############################################################################################################

standard_shader
{
	name			global
	shaderop		DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion		2
	samples				4
	lum_samples			1
}

file_rasterizeroutput
{
	pattern				rendered/vertex_colors_quad
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			0 0 3.5
	lookat				0 0 0
	up					0 1 0
	width				256
	height				256
	fov					30.0
}

##################################################
# Painters
##################################################

# Drives Lambertian albedo from per-vertex color.  Falls back to
# white for any hit on a surface without per-vertex colors.
vertex_color_painter
{
	name				pnt_vcolor
	fallback			1.0 1.0 1.0
	colorspace			sRGB
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				vcolor_lambert
	reflectance			pnt_vcolor
}

##################################################
# Objects
##################################################

# The PLY ships R/G/B/W in the four corners.  Loader converts each
# uchar triple from sRGB to linear ROMM RGB; the BVH-traversed hit
# barycentric-interpolates over the triangle for the painter to read.
plymesh_geometry
{
	name				vcolor_quad_geom
	file				scenes/Tests/Geometry/vertex_colors_quad.ply
	double_sided		TRUE
}

standard_object
{
	name				vcolor_quad
	geometry			vcolor_quad_geom
	material			vcolor_lambert
	receives_shadows	FALSE
	casts_shadows		FALSE
}

omni_light
{
	name				key
	power				4.0
	color				1.0 1.0 1.0
	position			0.0 0.0 5.0
}
