RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           csg.RISEscene                                                                           #
#   Description:    A test scene that tests the different CSG operations                                    #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      January 23, 2002                                                                        #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name				global
	shaderop			DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion		10
	samples				4
	lum_samples			1
}

file_rasterizeroutput
{
	pattern				rendered/csg
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

film
{
	width			512
	height			512
}

pinhole_camera
{
	location			0 0 1.5
	lookat				0 0 0
	up					0 1 0
	fov					39.0
}

##################################################
# Painters
##################################################

#############################################################################################################
#									RISE Ascii Scene File													#
#																											#
#	File: 			colors.scn																				#
#   Description:	Contains commonly used colors from all scenes											#
#	Author: 		Aravind Krishnaswamy																	#
#	Birthdate:		November 14, 2003																		#
#																											#
#############################################################################################################
#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           standard_colors.RISEscene                                                               #
#   Description:    Contains some standard colors                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################



uniformcolor_painter
{
	name		color_red
	color		1.0 0.0 0.0
}

uniformcolor_painter
{
	name		color_green
	color		0.0 1.0 0.0
}

uniformcolor_painter
{
	name		color_blue
	color		0.0 0.0 1.0
}










#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           povray_colors.RISEscene                                                                 #
#   Description:    Contains colors taken from POV-Ray                                                      #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################
















uniformcolor_painter
{
	name		color_gold
	color		0.8 0.498039 0.196078 
}






	
	

	




































































##################################################
# Materials
##################################################

lambertian_material
{
	name				green
	reflectance			color_green
}

lambertian_material
{
	name				red
	reflectance			color_red
}

lambertian_material
{
	name				blue
	reflectance			color_blue
}

lambertian_material
{
	name				gold
	reflectance			color_gold
}

##################################################
# Objects - 
##################################################

infiniteplane_geometry
{
	name				planegeom
	xtile				0.6
	ytile				0.6
}

sphere_geometry
{
	name				spheregeomA
	radius				0.165
}

box_geometry
{
	name				boxgeomA
	width				0.25
	height				0.25
	depth				0.25
}

sphere_geometry
{
	name				spheregeomB
	radius				0.25
}

box_geometry
{
	name				boxgeomB
	width				0.38
	height				0.38
	depth				0.38
}

standard_object
{
	name				planeA
	geometry			planegeom
	position			0.0 -0.5 0.0
	orientation			-90.0 0.0 0.0
	material			gold
}

standard_object
{
	name				sphereA
	geometry			spheregeomA
	material			red
}

standard_object
{
	name				boxA
	geometry			boxgeomA
	material			blue
}

standard_object
{
	name				sphereB
	geometry			spheregeomB
	material			red
}

standard_object
{
	name				boxB
	geometry			boxgeomB
	material			blue
}

csg_object
{
	name				csgA
	obja				boxB
	objb				sphereB
	operation			union
	position			-0.35 0.25 -1.0
	orientation			30 30 0
}

csg_object
{
	name				csgB
	obja				boxB
	objb				sphereB
	operation			intersection
	position			0.35 0.25 -1.0
	orientation			30 30 0
}

csg_object
{
	name				csgC
	obja				boxA
	objb				sphereA
	operation			subtraction
	position			-0.25 -0.25 0
	orientation			30 30 0
}

csg_object
{
	name				csgD
	obja				sphereA
	objb				boxA
	operation			subtraction
	position			0.25 -0.25 0
	orientation			30 30 0
}

##################################################
# Lights
##################################################

omni_light
{
	name		lightA
	power		0.65
	color		1.0 1.0 1.0
	position	0 0 10
}

omni_light
{
	name		lightB
	power		0.65
	color		1.0 1.0 1.0
	position	0 10 0
}



