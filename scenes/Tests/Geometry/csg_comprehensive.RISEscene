RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           csg_comprehensive.RISEscene                                                             #
#   Description:    Comprehensive CSG test scene exercising all three operations (union, intersection,      #
#                   subtraction) across multiple geometry type combinations. Objects are arranged in a       #
#                   3x4 grid on a ground plane with labels implied by position:                              #
#                                                                                                           #
#                   Row 1 (back):   Sphere-Box    union | intersection | subtraction | subtraction(reversed)#
#                   Row 2 (mid):    Cylinder-Sphere union | intersection | subtraction | Cyl-Box subtract   #
#                   Row 3 (front):  Torus-Box subtract | Ellipsoid-Box intersect | Nested CSG | Sphere-Cyl  #
#                                                                                                           #
#   Author:         Generated for CSG validation testing                                                    #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name				global
	shaderop			DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion		10
	samples				4
	lum_samples			1
}

file_rasterizeroutput
{
	pattern				rendered/csg_comprehensive
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera - elevated view looking down at the grid
##################################################

pinhole_camera
{
	location			0 5.0 6.0
	lookat				0 0.3 -0.5
	up					0 1 0
	width				1280
	height				768
	fov					50.0
}

##################################################
# Painters
##################################################

> run scenes/colors.RISEscript

uniformcolor_painter
{
	name				pnt_white
	color				0.85 0.85 0.85
}

uniformcolor_painter
{
	name				pnt_grey
	color				0.5 0.5 0.5
}

uniformcolor_painter
{
	name				pnt_floor_light
	color				0.75 0.75 0.72
}

uniformcolor_painter
{
	name				pnt_floor_dark
	color				0.45 0.45 0.43
}

checker_painter
{
	name				pnt_floor_checker
	colora				pnt_floor_light
	colorb				pnt_floor_dark
	size				1.0
}

uniformcolor_painter
{
	name				pnt_orange
	color				0.9 0.5 0.1
}

uniformcolor_painter
{
	name				pnt_cyan
	color				0.1 0.7 0.8
}

uniformcolor_painter
{
	name				pnt_purple
	color				0.6 0.2 0.8
}

uniformcolor_painter
{
	name				pnt_yellow
	color				0.9 0.85 0.2
}

uniformcolor_painter
{
	name				pnt_pink
	color				0.9 0.4 0.5
}

uniformcolor_painter
{
	name				pnt_teal
	color				0.2 0.7 0.5
}

uniformcolor_painter
{
	name				pnt_brown
	color				0.6 0.35 0.15
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				mat_red
	reflectance			color_red
}

lambertian_material
{
	name				mat_blue
	reflectance			color_blue
}

lambertian_material
{
	name				mat_green
	reflectance			color_green
}

lambertian_material
{
	name				mat_orange
	reflectance			pnt_orange
}

lambertian_material
{
	name				mat_cyan
	reflectance			pnt_cyan
}

lambertian_material
{
	name				mat_purple
	reflectance			pnt_purple
}

lambertian_material
{
	name				mat_yellow
	reflectance			pnt_yellow
}

lambertian_material
{
	name				mat_pink
	reflectance			pnt_pink
}

lambertian_material
{
	name				mat_teal
	reflectance			pnt_teal
}

lambertian_material
{
	name				mat_brown
	reflectance			pnt_brown
}

lambertian_material
{
	name				mat_white
	reflectance			pnt_white
}

lambertian_material
{
	name				mat_grey
	reflectance			pnt_grey
}

lambertian_material
{
	name				mat_floor
	reflectance			pnt_floor_checker
}

##################################################
# Geometries
##################################################

# Ground plane
infiniteplane_geometry
{
	name				geom_ground
	xtile				1.0
	ytile				1.0
}

# Shared primitives for CSG operations
sphere_geometry
{
	name				geom_sphere_med
	radius				0.4
}

sphere_geometry
{
	name				geom_sphere_sm
	radius				0.32
}

box_geometry
{
	name				geom_box_med
	width				0.6
	height				0.6
	depth				0.6
}

box_geometry
{
	name				geom_box_sm
	width				0.5
	height				0.5
	depth				0.5
}

cylinder_geometry
{
	name				geom_cyl_y
	axis				y
	radius				0.3
	height				0.7
}

cylinder_geometry
{
	name				geom_cyl_x
	axis				x
	radius				0.22
	height				1.0
}

torus_geometry
{
	name				geom_torus
	majorradius			0.35
	minorratio			0.3
}

ellipsoid_geometry
{
	name				geom_ellipsoid
	radii				0.45 0.3 0.35
}

##################################################
# Objects
##################################################

# Ground plane
standard_object
{
	name				ground
	geometry			geom_ground
	position			0 -0.01 0
	orientation			-90 0 0
	material			mat_floor
}

########################################
# ROW 1 (back, z = -3.0): Sphere + Box
# Columns at x = -3.5, -1.17, 1.17, 3.5
########################################

# --- 1A: Sphere-Box UNION ---
standard_object
{
	name				r1a_sphere
	geometry			geom_sphere_med
	material			mat_red
}

standard_object
{
	name				r1a_box
	geometry			geom_box_sm
	material			mat_blue
}

csg_object
{
	name				csg_sphere_box_union
	obja				r1a_sphere
	objb				r1a_box
	operation			union
	position			-3.5 0.4 -3.0
	orientation			20 25 0
}

# --- 1B: Sphere-Box INTERSECTION ---
standard_object
{
	name				r1b_sphere
	geometry			geom_sphere_med
	material			mat_red
}

standard_object
{
	name				r1b_box
	geometry			geom_box_sm
	material			mat_blue
}

csg_object
{
	name				csg_sphere_box_isect
	obja				r1b_sphere
	objb				r1b_box
	operation			intersection
	position			-1.17 0.4 -3.0
	orientation			20 25 0
}

# --- 1C: Box-Sphere SUBTRACTION (box minus sphere) ---
standard_object
{
	name				r1c_box
	geometry			geom_box_med
	material			mat_blue
}

standard_object
{
	name				r1c_sphere
	geometry			geom_sphere_med
	material			mat_red
}

csg_object
{
	name				csg_box_minus_sphere
	obja				r1c_box
	objb				r1c_sphere
	operation			subtraction
	position			1.17 0.4 -3.0
	orientation			20 25 0
}

# --- 1D: Sphere-Box SUBTRACTION (sphere minus box) ---
standard_object
{
	name				r1d_sphere
	geometry			geom_sphere_med
	material			mat_red
}

standard_object
{
	name				r1d_box
	geometry			geom_box_sm
	material			mat_blue
}

csg_object
{
	name				csg_sphere_minus_box
	obja				r1d_sphere
	objb				r1d_box
	operation			subtraction
	position			3.5 0.4 -3.0
	orientation			20 25 0
}

########################################
# ROW 2 (middle, z = -0.5): Cylinder combos
# Columns at x = -3.5, -1.17, 1.17, 3.5
########################################

# --- 2A: Cylinder-Sphere UNION ---
standard_object
{
	name				r2a_cyl
	geometry			geom_cyl_y
	material			mat_orange
}

standard_object
{
	name				r2a_sphere
	geometry			geom_sphere_sm
	material			mat_cyan
}

csg_object
{
	name				csg_cyl_sphere_union
	obja				r2a_cyl
	objb				r2a_sphere
	operation			union
	position			-3.5 0.4 -0.5
	orientation			0 15 0
}

# --- 2B: Cylinder-Sphere INTERSECTION ---
standard_object
{
	name				r2b_cyl
	geometry			geom_cyl_y
	material			mat_orange
}

standard_object
{
	name				r2b_sphere
	geometry			geom_sphere_sm
	material			mat_cyan
}

csg_object
{
	name				csg_cyl_sphere_isect
	obja				r2b_cyl
	objb				r2b_sphere
	operation			intersection
	position			-1.17 0.4 -0.5
	orientation			0 15 0
}

# --- 2C: Cylinder-Sphere SUBTRACTION ---
standard_object
{
	name				r2c_cyl
	geometry			geom_cyl_y
	material			mat_orange
}

standard_object
{
	name				r2c_sphere
	geometry			geom_sphere_sm
	material			mat_cyan
}

csg_object
{
	name				csg_cyl_minus_sphere
	obja				r2c_cyl
	objb				r2c_sphere
	operation			subtraction
	position			1.17 0.4 -0.5
	orientation			0 15 0
}

# --- 2D: Cylinder-Box SUBTRACTION ---
standard_object
{
	name				r2d_cyl
	geometry			geom_cyl_y
	material			mat_orange
}

standard_object
{
	name				r2d_box
	geometry			geom_box_sm
	material			mat_purple
}

csg_object
{
	name				csg_cyl_minus_box
	obja				r2d_cyl
	objb				r2d_box
	operation			subtraction
	position			3.5 0.4 -0.5
	orientation			0 30 0
}

########################################
# ROW 3 (front, z = 2.0): Mixed geometry
# Columns at x = -3.5, -1.17, 1.17, 3.5
########################################

# --- 3A: Torus-Box SUBTRACTION ---
standard_object
{
	name				r3a_torus
	geometry			geom_torus
	material			mat_yellow
}

standard_object
{
	name				r3a_box
	geometry			geom_box_sm
	material			mat_green
}

csg_object
{
	name				csg_torus_minus_box
	obja				r3a_torus
	objb				r3a_box
	operation			subtraction
	position			-3.5 0.45 2.0
	orientation			30 0 0
}

# --- 3B: Ellipsoid-Box INTERSECTION ---
standard_object
{
	name				r3b_ellipsoid
	geometry			geom_ellipsoid
	material			mat_pink
}

standard_object
{
	name				r3b_box
	geometry			geom_box_sm
	material			mat_teal
}

csg_object
{
	name				csg_ellipsoid_box_isect
	obja				r3b_ellipsoid
	objb				r3b_box
	operation			intersection
	position			-1.17 0.4 2.0
	orientation			0 20 0
}

# --- 3C: Nested CSG (union of two subtractions) ---
# Inner CSG A: box minus sphere
standard_object
{
	name				r3c_inner_box
	geometry			geom_box_med
	material			mat_brown
}

standard_object
{
	name				r3c_inner_sphere
	geometry			geom_sphere_med
	material			mat_white
}

csg_object
{
	name				r3c_inner_csg
	obja				r3c_inner_box
	objb				r3c_inner_sphere
	operation			subtraction
}

# Inner CSG B: cylinder (no subtraction, just a plain object to union with)
standard_object
{
	name				r3c_cyl
	geometry			geom_cyl_x
	material			mat_grey
}

csg_object
{
	name				csg_nested
	obja				r3c_inner_csg
	objb				r3c_cyl
	operation			union
	position			1.17 0.4 2.0
	orientation			20 25 0
}

# --- 3D: Sphere-Cylinder SUBTRACTION ---
standard_object
{
	name				r3d_sphere
	geometry			geom_sphere_med
	material			mat_purple
}

standard_object
{
	name				r3d_cyl
	geometry			geom_cyl_x
	material			mat_yellow
}

csg_object
{
	name				csg_sphere_minus_cyl
	obja				r3d_sphere
	objb				r3d_cyl
	operation			subtraction
	position			3.5 0.4 2.0
	orientation			0 0 0
}

##################################################
# Lights - multiple lights for good coverage
##################################################

# Key light from upper right
omni_light
{
	name				key_light
	power				3.0
	color				1.0 1.0 0.95
	position			5 8 5
}

# Fill light from upper left
omni_light
{
	name				fill_light
	power				2.0
	color				0.9 0.93 1.0
	position			-5 7 4
}

# Back light for depth
omni_light
{
	name				back_light
	power				1.5
	color				1.0 1.0 1.0
	position			0 6 -6
}

# Low front fill to illuminate undersides
omni_light
{
	name				front_fill
	power				0.8
	color				1.0 1.0 1.0
	position			0 2 8
}
