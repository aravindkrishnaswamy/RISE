RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           displaced_shapes.RISEscene                                                              #
#   Description:    Each shape from shapes.RISEscene wrapped by a displaced_geometry                       #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      2026-04-18                                                                              #
#                                                                                                           #
#############################################################################################################

# Be sure to set the object manager for BSP
> set accelerator B 10 8

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name			global
	shaderop		DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion		10
	samples				4
	lum_samples			1
}

file_rasterizeroutput
{
	pattern				rendered/displaced_shapes
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

film
{
	width			800
	height			800
}

pinhole_camera
{
	location			0 0 20
	lookat				0 0 0
	up					0 1 0
	fov					30.0
}

##################################################
# Painters
##################################################

#############################################################################################################
#									RISE Ascii Scene File													#
#																											#
#	File: 			colors.scn																				#
#   Description:	Contains commonly used colors from all scenes											#
#	Author: 		Aravind Krishnaswamy																	#
#	Birthdate:		November 14, 2003																		#
#																											#
#############################################################################################################
#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           standard_colors.RISEscene                                                               #
#   Description:    Contains some standard colors                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################







uniformcolor_painter
{
	name		color_yellow
	color		1.0 1.0 0.0
}








#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           povray_colors.RISEscene                                                                 #
#   Description:    Contains colors taken from POV-Ray                                                      #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################

uniformcolor_painter
{
	name		color_aquamarine
	color		0.439216 0.858824 0.576471
}















uniformcolor_painter
{
	name		color_gold
	color		0.8 0.498039 0.196078 
}






uniformcolor_painter
{
	name		color_lightsteelblue
	color		0.560784 0.560784 0.737255 
}
	
	

	












uniformcolor_painter
{
	name		color_orange
	color		1.0 0.5 0.0 
}
























































png_painter
{
	name				pnt_bump
	file				textures/waterbump.png
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				orange
	reflectance			color_orange
}

lambertian_material
{
	name				lightsteelblue
	reflectance			color_lightsteelblue
}

lambertian_material
{
	name				gold
	reflectance			color_gold
}

lambertian_material
{
	name				aquamarine
	reflectance			color_aquamarine
}

lambertian_material
{
	name				yellow
	reflectance			color_yellow
}

##################################################
# Base geometries (same as shapes.RISEscene)
##################################################

ellipsoid_geometry
{
	name				base_ellipsoid
	radii				0.6 0.15 0.3
}

box_geometry
{
	name				base_box
	width				1
	height				1
	depth				1
}

torus_geometry
{
	name				base_torus
	majorradius			1
	minorratio			0.15
}

cylinder_geometry
{
	name				base_cylinder
	axis				y
	radius				0.7
	height				1.3
}

clippedplane_geometry
{
	name				base_cp
	pta					-0.6 0.5 0
	ptb					-0.55 -0.6 0
	ptc					0.65 -0.3 0
	ptd					0.45 0.7 0
}

##################################################
# Displaced geometries — each wraps a base shape
##################################################

displaced_geometry
{
	name				disp_ellipsoid
	base_geometry		base_ellipsoid
	detail				48
	displacement		pnt_bump
	disp_scale			0.03
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

displaced_geometry
{
	name				disp_box
	base_geometry		base_box
	detail				32
	displacement		pnt_bump
	disp_scale			0.03
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

displaced_geometry
{
	name				disp_torus
	base_geometry		base_torus
	detail				48
	displacement		pnt_bump
	disp_scale			0.02
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

displaced_geometry
{
	name				disp_cylinder
	base_geometry		base_cylinder
	detail				48
	displacement		pnt_bump
	disp_scale			0.03
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

displaced_geometry
{
	name				disp_cp
	base_geometry		base_cp
	detail				32
	displacement		pnt_bump
	disp_scale			0.03
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

##################################################
# Objects — lay out in a grid matching shapes.RISEscene
##################################################


