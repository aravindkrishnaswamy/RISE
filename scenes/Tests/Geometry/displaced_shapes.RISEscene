RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           displaced_shapes.RISEscene                                                              #
#   Description:    Each shape from shapes.RISEscene wrapped by a displaced_geometry                       #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      2026-04-18                                                                              #
#                                                                                                           #
#############################################################################################################

# Be sure to set the object manager for BSP
> set accelerator B 10 8

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name			global
	shaderop		DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion		10
	samples				4
	lum_samples			1
}

file_rasterizeroutput
{
	pattern				rendered/displaced_shapes
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

pinhole_camera
{
	location			0 0 20
	lookat				0 0 0
	up					0 1 0
	width				800
	height				800
	fov					30.0
}

##################################################
# Painters
##################################################

> run scenes/colors.RISEscript

png_painter
{
	name				pnt_bump
	file				textures/waterbump.png
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				orange
	reflectance			color_orange
}

lambertian_material
{
	name				lightsteelblue
	reflectance			color_lightsteelblue
}

lambertian_material
{
	name				gold
	reflectance			color_gold
}

lambertian_material
{
	name				aquamarine
	reflectance			color_aquamarine
}

lambertian_material
{
	name				yellow
	reflectance			color_yellow
}

##################################################
# Base geometries (same as shapes.RISEscene)
##################################################

ellipsoid_geometry
{
	name				base_ellipsoid
	radii				1.2 0.3 0.6
}

box_geometry
{
	name				base_box
	width				1
	height				1
	depth				1
}

torus_geometry
{
	name				base_torus
	majorradius			1
	minorratio			0.15
}

cylinder_geometry
{
	name				base_cylinder
	axis				y
	radius				0.7
	height				1.3
}

clippedplane_geometry
{
	name				base_cp
	pta					-0.6 0.5 0
	ptb					-0.55 -0.6 0
	ptc					0.65 -0.3 0
	ptd					0.45 0.7 0
}

##################################################
# Displaced geometries — each wraps a base shape
##################################################

displaced_geometry
{
	name				disp_ellipsoid
	base_geometry		base_ellipsoid
	detail				48
	displacement		pnt_bump
	disp_scale			0.03
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

displaced_geometry
{
	name				disp_box
	base_geometry		base_box
	detail				32
	displacement		pnt_bump
	disp_scale			0.03
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

displaced_geometry
{
	name				disp_torus
	base_geometry		base_torus
	detail				48
	displacement		pnt_bump
	disp_scale			0.02
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

displaced_geometry
{
	name				disp_cylinder
	base_geometry		base_cylinder
	detail				48
	displacement		pnt_bump
	disp_scale			0.03
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

displaced_geometry
{
	name				disp_cp
	base_geometry		base_cp
	detail				32
	displacement		pnt_bump
	disp_scale			0.03
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

##################################################
# Objects — lay out in a grid matching shapes.RISEscene
##################################################

FOR I 0 4 1

	standard_object
	{
		name			dbox!I
		geometry		disp_box
		position		$(@I*2-4) 4 0
		orientation		$(@I*35) $(@I*60) 0
		material		aquamarine
	}

	standard_object
	{
		name			dtorus!I
		geometry		disp_torus
		position		$(@I*2-4) 2 0
		orientation		$(@I*25) 0 $(@I*60)
		material		gold
	}

	standard_object
	{
		name			dellipsoid!I
		geometry		disp_ellipsoid
		position		$(@I*2-4) 0 0
		orientation		$(@I*60) 0 $(@I*35)
		material		orange
	}

	standard_object
	{
		name			dcylinder!I
		geometry		disp_cylinder
		position		$(@I*2-4) -2 0
		orientation		$(@I*20) $(@I*60) 0
		material		lightsteelblue
	}

	standard_object
	{
		name			dcp!I
		geometry		disp_cp
		position		$(@I*2-4) -4 0
		orientation		0 $(@I*15) $(@I*25)
		material		yellow
	}

ENDFOR

directional_light
{
	name		light
	power		3.14
	color		1.0 1.0 1.0
	direction	0 0 1
}
