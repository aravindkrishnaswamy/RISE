RISE ASCII SCENE 5
# Displaced box test scene.  Tests 6-face handling + face-boundary tolerance.

> set accelerator B 10 8

standard_shader
{
	name			global
	shaderop		DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion		6
	samples				4
	lum_samples			1
}

file_rasterizeroutput
{
	pattern				rendered/displaced_box
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			2.5 2.5 3.5
	lookat				0 0 0
	up					0 1 0
	width				256
	height				256
	fov					30.0
}

> run scenes/colors.RISEscript

png_painter
{
	name				pnt_bump
	file				textures/waterbump.png
}

lambertian_material
{
	name				lambert_aqua
	reflectance			color_aquamarine
}

box_geometry
{
	name				base_box
	width				1.5
	height				1.5
	depth				1.5
}

displaced_geometry
{
	name				disp_box
	base_geometry		base_box
	detail				32
	displacement		pnt_bump
	disp_scale			0.05
	maxpolygons			10
	maxdepth			8
	bsp					TRUE
}

standard_object
{
	name				the_box
	geometry			disp_box
	material			lambert_aqua
	position			0 0 0
}

directional_light
{
	name				light
	power				3.14
	color				1.0 1.0 1.0
	direction			0.3 0.5 1.0
}
