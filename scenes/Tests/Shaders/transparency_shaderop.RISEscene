##################################################
# Setup a renderer
##################################################

#############################################################################################################
#									RISE Ascii Scene File													#
#																											#
#	File: 			colors.scn																				#
#   Description:	Contains commonly used colors from all scenes											#
#	Author: 		Aravind Krishnaswamy																	#
#	Birthdate:		November 14, 2003																		#
#																											#
#############################################################################################################
#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           standard_colors.RISEscene                                                               #
#   Description:    Contains some standard colors                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################

uniformcolor_painter
{
	name		color_black
	color		0.0 0.0 0.0
}

uniformcolor_painter
{
	name		color_white
	color		1.0 1.0 1.0
}

uniformcolor_painter
{
	name		color_red
	color		1.0 0.0 0.0
}

uniformcolor_painter
{
	name		color_green
	color		0.0 1.0 0.0
}

uniformcolor_painter
{
	name		color_blue
	color		0.0 0.0 1.0
}









uniformcolor_painter
{
	name		color_50pgrey
	color		0.50 0.50 0.50
}

#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           povray_colors.RISEscene                                                                 #
#   Description:    Contains colors taken from POV-Ray                                                      #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################






















	
	

	




































































transparency_shaderop
{
	name			trans
	transparency	color_50pgrey
	one_sided		true
}

standard_shader
{
	name			global
	shaderop		DefaultDirectLighting
}

advanced_shader
{
	name			trans
	shaderop		DefaultDirectLighting		0 100	+
	shaderop		trans						0 100	=
}

pixelpel_rasterizer
{
	max_recursion		10
	samples				10
	lum_samples			1
	pixel_sampler		halton
}

file_rasterizeroutput
{
	pattern				rendered/transparency_shaderop
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

film
{
	width			800
	height			300
}

pinhole_camera
{
	location			0 0 3
	lookat				0 0 0
	up					0 1 0
	fov					20.0
	theta				30
}

##################################################
# Painters
##################################################

checker_painter
{
	name				pnt_checker
	colora				color_white
	colorb				color_black
	size				0.05
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				red
	reflectance			color_red
}

lambertian_material
{
	name				green
	reflectance			color_green
}

lambertian_material
{
	name				blue
	reflectance			color_blue
}

lambertian_material
{
	name				checker
	reflectance			pnt_checker
}

##################################################
# Objects - plane
##################################################

infiniteplane_geometry
{
	name				planegeom
	xtile				2
	ytile				2
}

standard_object
{
	name				plane
	geometry			planegeom
	position			0.0 -0.3 0.0
	orientation			-90.0 0.0 0.0
	material			checker
}

##################################################
# Objects - boxes
##################################################

sphere_geometry
{
	name				spheregeom
	radius				0.3
}

standard_object
{
	name				sphereA
	geometry			spheregeom
	position			-0.8 0.0 0.0
	material			red
	shader				trans
	casts_shadows		false
}

standard_object
{
	name				sphereB
	geometry			spheregeom
	position			0 0.0 0.0
	material			green
	shader				trans
	casts_shadows		false
}

standard_object
{
	name				sphereC
	geometry			spheregeom
	position			0.8 0.0 0.0
	material			blue
	shader				trans
	casts_shadows		false
}

omni_light
{
	name				amb
	position			0 3.5 3.5
	color				1 1 1
	power				3.14
}


