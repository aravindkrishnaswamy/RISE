RISE ASCII SCENE 6
# SDF media stress: a glowing BLOBBY SDF (smin peanut) acting as a true area
# light INSIDE a global homogeneous scattering fog, alongside a glass SDF whose
# interior holds a second, denser tinted medium, plus an analytic diffuse
# sphere and a floor.  Exercises, all at once:
#   - volume in-scattering NEE: fog scatter points draw light samples from the
#     SDF luminaire's tessellation-backed UniformRandomPoint (isVolumeScatter
#     branch -- full-sphere integration, cosSurface forced to 1)
#   - fog transmittance along shadow rays toward SDF surface samples
#   - the camera-visible glow halo around the emitter (emission attenuated by
#     the fog on the camera segment)
#   - NESTED media on a sphere-traced boundary: rays cross global-fog -> glass
#     -> interior fog -> glass -> global-fog; the IOR/medium stack must swap
#     correctly at marched crossings in BOTH directions
# If SDF surface sampling or boundary tracking broke, the fog goes black, the
# glow vanishes, or the glass blob renders black/blown-out.

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples		160
}

file_rasterizeroutput
{
	pattern		rendered/sdf_luminaire_fog
	type		PNG
	bpp			8
	color_space	sRGB
}

film
{
	width		360
	height		270
}

pinhole_camera
{
	location	0 4.5 14
	lookat		0 2.2 0
	up			0 1 0
	fov			45.0
}

homogeneous_medium
{
	name		fog
	absorption	0.008 0.010 0.014
	scattering	0.055 0.055 0.050
	phase		isotropic
}

> set global_medium fog

homogeneous_medium
{
	name		blob_brew
	absorption	0.30 0.85 1.6
	scattering	0.15 0.15 0.15
	phase		hg 0.0
}

uniformcolor_painter
{
	name		pwhite
	color		0.70 0.70 0.70
}

uniformcolor_painter
{
	name		pred
	color		0.68 0.16 0.12
}

uniformcolor_painter
{
	name		pemit
	color		1.0 0.88 0.70
}

uniformcolor_painter
{
	name		pglass_tau
	color		0.99 0.99 0.99
}

lambertian_material
{
	name		mwhite
	reflectance	pwhite
}

lambertian_material
{
	name		mred
	reflectance	pred
}

lambertian_luminaire_material
{
	name		memit
	exitance	pemit
	scale		22.0
	material	none
}

perfectrefractor_material
{
	name		mglass
	refractance	pglass_tau
	ior			1.5
}

clippedplane_geometry
{
	name		floorgeom
	pta			-14 0 -14
	ptb			 14 0 -14
	ptc			 14 0  14
	ptd			-14 0  14
}

sphere_geometry
{
	name		refspheregeom
	radius		1.1
}

# the glowing blob: two spheres melded by a smooth-min (the "peanut")
sdf_geometry
{
	name			glowblobgeom
	part			sphere union 0  -0.75 0 0  0 0 0  1 1 1  1.05 0 0  0
	part			sphere smin 0.7  0.75 0 0  0 0 0  1 1 1  1.05 0 0  0
	sampling_detail	64
}

# the glass blob: roundbox smin sphere, bounding its own interior medium
sdf_geometry
{
	name		glassblobgeom
	part		roundbox union 0  0 2 0  0 0 0  1 1 1  2 2 2  0.5
	part		sphere smin 1.6  2.6 3.2 0  0 0 0  1 1 1  1.7 0 0  0
}

standard_object
{
	name		grnd
	geometry	floorgeom
	material	mwhite
	position	0 0 0
}

standard_object
{
	name		glowblob
	geometry	glowblobgeom
	material	memit
	position	0 4.6 0
	orientation	0 0 90
}

standard_object
{
	name			glassblob
	geometry		glassblobgeom
	material		mglass
	position		-4.6 1.3 1.5
	interior_medium	blob_brew
}

standard_object
{
	name		refsphere
	geometry	refspheregeom
	material	mred
	position	4.4 1.1 1.0
}
