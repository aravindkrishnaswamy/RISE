RISE ASCII SCENE 6
# SDF + participating-medium test.  A glass SDF "peanut" (two spheres melded by a
# smooth-min) bounds a colored fog interior.  Camera rays refract through the
# ray-marched dielectric boundary; the IOR-stack medium tracking relies on the
# sphere-tracer reporting correct front (entry) AND back (exit) crossings.  A
# small red diffuse sphere sits behind it (no medium) for reference.

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples		256
}

file_rasterizeroutput
{
	pattern		rendered/sdf_volume
	type		PNG
	bpp			8
	color_space	sRGB
}

film
{
	width		640
	height		512
}

pinhole_camera
{
	location	0 0 -5.5
	lookat		0 0 0
	up			0 1 0
	fov			45.0
}

homogeneous_medium
{
	name		blob_fog
	absorption	0.25 0.7 1.35
	scattering	0.12 0.12 0.12
	phase		hg 0.0
}

uniformcolor_painter
{
	name		pnt_light
	color		1.0 0.95 0.9
}

uniformcolor_painter
{
	name		pnt_white
	color		0.73 0.73 0.73
}

uniformcolor_painter
{
	name		pnt_red
	color		0.63 0.06 0.04
}

uniformcolor_painter
{
	name		pnt_glass_tau
	color		0.99 0.99 0.99
}

lambertian_material
{
	name		white
	reflectance	pnt_white
}

lambertian_material
{
	name		red
	reflectance	pnt_red
}

perfectrefractor_material
{
	name		glass
	refractance	pnt_glass_tau
	ior			1.5
}

lambertian_luminaire_material
{
	name		light_mat
	exitance	pnt_light
	scale		100.0
	material	none
}

clippedplane_geometry
{
	name		floorgeom
	pta			4 -1.8 -2
	ptb			-4 -1.8 -2
	ptc			-4 -1.8 6
	ptd			4 -1.8 6
}

clippedplane_geometry
{
	name		backwallgeom
	pta			-4 -1.8 4
	ptb			-4 4 4
	ptc			4 4 4
	ptd			4 -1.8 4
}

clippedplane_geometry
{
	name		lightgeom
	pta			1.5 3.99 -1
	ptb			1.5 3.99 2
	ptc			-1.5 3.99 2
	ptd			-1.5 3.99 -1
}

sdf_geometry
{
	name		blobgeom
	part		sphere union 0  -0.75 0 0  0 0 0  1 1 1  1.05 0 0  0
	part		sphere smin 0.7  0.75 0 0  0 0 0  1 1 1  1.05 0 0  0
}

sphere_geometry
{
	name		smallspheregeom
	radius		0.4
}

standard_object
{
	name		floor
	geometry	floorgeom
	material	white
}

standard_object
{
	name		backwall
	geometry	backwallgeom
	material	white
}

standard_object
{
	name		light
	geometry	lightgeom
	material	light_mat
}

standard_object
{
	name			glass_blob
	geometry		blobgeom
	position		0 0 0
	material		glass
	interior_medium	blob_fog
}

standard_object
{
	name		ref_sphere
	geometry	smallspheregeom
	position	-1.9 -1.4 1.0
	material	red
}
