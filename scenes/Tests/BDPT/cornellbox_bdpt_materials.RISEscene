RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           cornellbox_bdpt_materials.RISEscene                                                     #
#   Description:    Cornell box with many different material types to validate BDPT handles all of them.    #
#                   Nine spheres arranged in a 3x3 grid, each with a different material.                   #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 20, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

bdpt_pel_rasterizer
{
	max_eye_depth		10
	max_light_depth		8
	samples				64
	oidn_denoise		true
}

file_rasterizeroutput
{
	pattern				rendered/cornellbox_bdpt_materials
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

pinhole_camera
{
	location			278 273 -800
	lookat				278 273 200
	up					0 1 0
	width				512
	height				512
	fov					39.0
}

##################################################
# Painters
##################################################
> run scenes/colors.RISEscript

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_grey
	color				0.6 0.6 0.6
}

uniformcolor_painter
{
	name				pnt_blue
	color				0.15 0.15 0.8
}

uniformcolor_painter
{
	name				pnt_gold
	color				0.85 0.7 0.2
}

uniformcolor_painter
{
	name				pnt_copper
	color				0.75 0.45 0.2
}

uniformcolor_painter
{
	name				pnt_silver
	color				0.85 0.85 0.9
}

uniformcolor_painter
{
	name				pnt_glass_tau
	color				0.9997 0.9997 0.9999
	colorspace			RISERGB
}

uniformcolor_painter
{
	name				pnt_translucent_tau
	color				0.35 0.35 0.35
}

uniformcolor_painter
{
	name				pnt_orange
	color				0.8 0.4 0.1
}

##################################################
# Materials - 9 different material types
##################################################

# Row 1 (top): Lambertian, Oren-Nayar, Translucent

# 1. Lambertian diffuse - classic matte surface
lambertian_material
{
	name				mat_lambertian
	reflectance			pnt_blue
}

# 2. Oren-Nayar - rough diffuse (visible difference from Lambertian at grazing angles)
orennayar_material
{
	name				mat_orennayar
	reflectance			pnt_orange
	roughness			0.8
}

# 3. Translucent - light passes through
translucent_material
{
	name				mat_translucent
	ref					pnt_grey
	tau					pnt_translucent_tau
	ext					color_white
	N					1.3
	scattering			0.0
}

# Row 2 (middle): Isotropic Phong, Cook-Torrance, Schlick

# 4. Isotropic Phong - glossy highlight
isotropic_phong_material
{
	name				mat_phong
	rd					pnt_copper
	rs					color_white
	N					60.0
}

# 5. Cook-Torrance - physically based metallic
cooktorrance_material
{
	name				mat_cooktorrance
	rd					pnt_gold
	rs					color_white
	facets				0.15
	ior					2.5
	extinction			3.0
}

# 6. Schlick - anisotropic glossy
schlick_material
{
	name				mat_schlick
	rd					pnt_grey
	rs					color_white
	roughness			0.05
	isotropy			0.3
}

# Row 3 (bottom): Perfect mirror, Dielectric glass, Ward Anisotropic

# 7. Perfect reflector - mirror
perfectreflector_material
{
	name				mat_mirror
	reflectance			pnt_silver
}

# 8. Dielectric - glass sphere
dielectric_material
{
	name				mat_glass
	tau					pnt_glass_tau
	ior					1.5
	scattering			100000.0
}

# 9. Ward Anisotropic - brushed metal effect
ward_anisotropic_material
{
	name				mat_ward_aniso
	rd					pnt_copper
	rs					color_white
	alphax				0.05
	alphay				0.3
}

# Wall and light materials
lambertian_material
{
	name				white
	reflectance			color_white
}

lambertian_material
{
	name				green
	reflectance			color_cornellgreen
}

lambertian_material
{
	name				red
	reflectance			color_cornellred
}

lambertian_luminaire_material
{
	name				white_lum
	exitance			pnt_light
	scale				70.0
	material			none
}

##################################################
# Objects - walls (slightly larger box to fit 9 spheres)
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					552.8 0 0
	ptb					0 0 0
	ptc					0 0 559.2
	ptd					549.6 0 559.2
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					556.0 548.8 0.0
	ptb					556.0 548.8 559.2
	ptc					0 548.8 559.2
	ptd					0.0 548.8 0.0
}

clippedplane_geometry
{
	name				bwallgeom
	pta					549.6 0 559.2
	ptb					0 0 559.2
	ptc					0 548.8 559.2
	ptd					556.0 548.8 559.2
}

clippedplane_geometry
{
	name				rwallgeom
	pta					0 0 559.2
	ptb					0 0 0
	ptc					0 548.8 0.0
	ptd					0 548.8 559.2
}

clippedplane_geometry
{
	name				lwallgeom
	pta					552.8 0 0
	ptb					549.6 0 559.2
	ptc					556.0 548.8 559.2
	ptd					556.0 548.8 0
}

clippedplane_geometry
{
	name				lightgeom
	pta					393.0 548.7999 177.0
	ptb					393.0 548.7999 382.0
	ptc					163.0 548.7999 382.0
	ptd					163.0 548.7999 177.0
}

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				bwall
	geometry			bwallgeom
	material			white
}

standard_object
{
	name				rwall
	geometry			rwallgeom
	material			green
}

standard_object
{
	name				lwall
	geometry			lwallgeom
	material			red
}

standard_object
{
	name				light
	geometry			lightgeom
	material			white_lum
}

##################################################
# Sphere geometry (shared by all material spheres)
##################################################

sphere_geometry
{
	name				spheregeom
	radius				65.0
}

##################################################
# Row 1 (top, y=415): Lambertian, Oren-Nayar, Translucent
##################################################

standard_object
{
	name				sphere_lambertian
	geometry			spheregeom
	position			140 415 280
	material			mat_lambertian
}

standard_object
{
	name				sphere_orennayar
	geometry			spheregeom
	position			278 415 280
	material			mat_orennayar
}

standard_object
{
	name				sphere_translucent
	geometry			spheregeom
	position			416 415 280
	material			mat_translucent
}

##################################################
# Row 2 (middle, y=275): Phong, Cook-Torrance, Schlick
##################################################

standard_object
{
	name				sphere_phong
	geometry			spheregeom
	position			140 275 280
	material			mat_phong
}

standard_object
{
	name				sphere_cooktorrance
	geometry			spheregeom
	position			278 275 280
	material			mat_cooktorrance
}

standard_object
{
	name				sphere_schlick
	geometry			spheregeom
	position			416 275 280
	material			mat_schlick
}

##################################################
# Row 3 (bottom, y=135): Mirror, Glass, Ward Anisotropic
##################################################

standard_object
{
	name				sphere_mirror
	geometry			spheregeom
	position			140 135 280
	material			mat_mirror
}

standard_object
{
	name				sphere_glass
	geometry			spheregeom
	position			278 135 280
	material			mat_glass
}

standard_object
{
	name				sphere_ward_aniso
	geometry			spheregeom
	position			416 135 280
	material			mat_ward_aniso
}
