RISE ASCII SCENE 5
#############################################################################################################
#   CSG all-operations dielectric test for BDPT                                                             #
#   Tests union, intersection, and subtraction with glass materials.                                        #
#   Left:   CSG union (two overlapping spheres merged)                                                      #
#   Center: CSG intersection (lens shape from sphere overlap)                                               #
#   Right:  CSG subtraction (sphere with spherical cavity)                                                  #
#   Far right: Reference plain sphere (control)                                                             #
#############################################################################################################

> set accelerator B 10 8

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

bdpt_pel_rasterizer
{
	max_eye_depth		10
	max_light_depth		10
	samples				64
}

file_rasterizeroutput
{
	pattern				rendered/bdpt_csg_all_ops_test
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera
##################################################

pinhole_camera
{
	location			0 3.5 7.5
	lookat				0 1.0 0
	up					0 1 0
	width				640
	height				320
	fov					58.0
}

##################################################
# Painters
##################################################

uniformcolor_painter
{
	name				pnt_white
	color				0.85 0.85 0.85
}

uniformcolor_painter
{
	name				pnt_left_wall
	color				0.85 0.35 0.35
}

uniformcolor_painter
{
	name				pnt_right_wall
	color				0.35 0.35 0.85
}

uniformcolor_painter
{
	name				pnt_emit
	color				1.0 1.0 0.95
}

uniformcolor_painter
{
	name				pnt_glass_tau
	color				0.997 0.997 0.997
	colorspace			RISERGB
}

uniformcolor_painter
{
	name				pnt_tinted_tau
	color				0.95 0.98 0.95
	colorspace			RISERGB
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white_mat
	reflectance			pnt_white
}

lambertian_material
{
	name				left_mat
	reflectance			pnt_left_wall
}

lambertian_material
{
	name				right_mat
	reflectance			pnt_right_wall
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_emit
	scale				55.0
	material			none
}

dielectric_material
{
	name				clear_glass
	tau					pnt_glass_tau
	ior					1.5
	scattering			100000.0
}

dielectric_material
{
	name				tinted_glass
	tau					pnt_tinted_tau
	ior					1.5
	scattering			100000.0
}

##################################################
# Geometry
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					-8.0 0.0 -5.0
	ptb					-8.0 0.0 5.0
	ptc					8.0 0.0 5.0
	ptd					8.0 0.0 -5.0
}

clippedplane_geometry
{
	name				backwallgeom
	pta					-8.0 8.0 0.0
	ptb					-8.0 0.0 0.0
	ptc					8.0 0.0 0.0
	ptd					8.0 8.0 0.0
}

clippedplane_geometry
{
	name				sidewallgeom
	pta					0.0 8.0 5.0
	ptb					0.0 0.0 5.0
	ptc					0.0 0.0 -5.0
	ptd					0.0 8.0 -5.0
}

circulardisk_geometry
{
	name				lightdiskgeom
	radius				1.2
	axis				y
}

sphere_geometry
{
	name				sphere_r048
	radius				0.48
}

sphere_geometry
{
	name				sphere_r042
	radius				0.42
}

sphere_geometry
{
	name				sphere_r035
	radius				0.35
}

sphere_geometry
{
	name				ref_sphere_geom
	radius				0.48
}

##################################################
# Room
##################################################

standard_object
{
	name				floor
	geometry			floorgeom
	material			white_mat
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	position			0 0 -4.0
	material			white_mat
}

standard_object
{
	name				leftwall
	geometry			sidewallgeom
	position			-7.0 0 0
	material			left_mat
}

standard_object
{
	name				rightwall
	geometry			sidewallgeom
	position			7.0 0 0
	orientation			0 180 0
	material			right_mat
}

standard_object
{
	name				ceiling_light
	geometry			lightdiskgeom
	position			0 5.5 -0.5
	orientation			180 0 0
	material			light_mat
}

##################################################
# CSG UNION (left): two overlapping glass spheres
##################################################

standard_object
{
	name				union_sphere_a
	geometry			sphere_r048
	position			-0.22 0 0
	material			clear_glass
}

standard_object
{
	name				union_sphere_b
	geometry			sphere_r048
	position			0.22 0 0
	material			clear_glass
}

csg_object
{
	name				csg_union_glass
	obja				union_sphere_a
	objb				union_sphere_b
	operation			union
	position			-4.0 1.0 0
}

##################################################
# CSG INTERSECTION (center-left): lens shape
##################################################

standard_object
{
	name				isect_sphere_a
	geometry			sphere_r048
	position			0 0.22 0
	material			clear_glass
}

standard_object
{
	name				isect_sphere_b
	geometry			sphere_r048
	position			0 -0.22 0
	material			clear_glass
}

csg_object
{
	name				csg_isect_glass
	obja				isect_sphere_a
	objb				isect_sphere_b
	operation			intersection
	position			-1.3 1.0 0
}

##################################################
# CSG SUBTRACTION (center-right): sphere with
# a spherical cavity carved out from the side
##################################################

standard_object
{
	name				sub_sphere_a
	geometry			sphere_r048
	position			0 0 0
	material			clear_glass
}

standard_object
{
	name				sub_sphere_b
	geometry			sphere_r042
	position			0.28 0 0
	material			clear_glass
}

csg_object
{
	name				csg_sub_glass
	obja				sub_sphere_a
	objb				sub_sphere_b
	operation			subtraction
	position			1.3 1.0 0
}

##################################################
# Torus (right): glass torus/ring
##################################################

torus_geometry
{
	name				torus_geom
	majorradius			0.34
	minorratio			0.28
}

standard_object
{
	name				glass_torus
	geometry			torus_geom
	position			3.0 1.0 0
	orientation			30 20 0
	material			clear_glass
}

##################################################
# Reference plain sphere (far right, control)
##################################################

standard_object
{
	name				ref_sphere
	geometry			ref_sphere_geom
	position			5.0 1.0 0
	material			clear_glass
}

