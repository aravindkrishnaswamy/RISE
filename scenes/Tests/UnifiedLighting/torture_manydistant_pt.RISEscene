RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           torture_manydistant_pt.RISEscene                                                        #
#   Description:    Torture test for global exitance-proportional light selection.                           #
#                   One point light 10 units above the floor center; 50 identical-power                     #
#                   point lights near the ceiling.  The floor receives ~2500x more                          #
#                   irradiance from the nearby light, but the alias table gives it                           #
#                   only 1/51 selection probability, wasting ~98% of NEE samples.                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 30, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

pathtracing_shaderop
{
	name		pt
}

standard_shader
{
	name		global
	shaderop	pt
}

pixelpel_rasterizer
{
	max_recursion		5
	samples				64
	lum_samples			1
}

file_rasterizeroutput
{
	pattern				rendered/torture_manydistant_pt
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera: low angle looking at floor near nearby light
##################################################

pinhole_camera
{
	location			278 273 -800
	lookat				278 273 200
	up					0 1 0
	width				512
	height				512
	fov					37.0
}

##################################################
# Painters
##################################################
> run scenes/colors.RISEscript

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			color_white
}

lambertian_material
{
	name				green
	reflectance			color_cornellgreen
}

lambertian_material
{
	name				red
	reflectance			color_cornellred
}

##################################################
# The nearby light: 10 units above floor center
# At d=10, irradiance ~ 100000/(10^2) = 1000
##################################################

omni_light
{
	name				nearby_light
	power				100000.0
	color				1.0 0.95 0.8
	position			278 50 280
}

##################################################
# 50 distant lights near ceiling (y=540)
# At d~530, irradiance ~ 100000/(530^2) ~ 0.36
# Ratio: nearby contributes ~2800x more per light
# But alias table gives nearby only 1/51 = 1.96%
##################################################

