RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           pool_caustics_vcm.RISEscene                                                              #
#   Description:    VCM render of the same swimming-pool caustic scene as                                   #
#                   scenes/FeatureBased/Caustics/pool_caustics.RISEscene.                                    #
#                   The water surface is a Gerstner-wave DisplacedGeometry — true vertex displacement,      #
#                   not a bump map — so refracting photons (via vertex merging) follow the real wavy        #
#                   geometry and produce the dense cellular caustic mesh on the pool floor.                  #
#                   VCM's merging handles the LS+DE caustic paths naturally; compare the output against     #
#                   the photon-map version in FeatureBased/Caustics/ — they should look equivalent.          #
#   Author:         Aravind Krishnaswamy                                                                    #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name				global
	shaderop			DefaultPathTracing
}


vcm_pel_rasterizer
{
	max_eye_depth		10
	max_light_depth		10
	samples				32
	merge_radius		0.0
	vc_enabled			true
	vm_enabled			true
}

/*
bdpt_pel_rasterizer
{
	max_eye_depth		10
	max_light_depth		10
	samples				64
	sms_enabled                   FALSE
	sms_max_iterations            30
	sms_threshold                 1e-4
	sms_max_chain_depth           10
	sms_biased                    TRUE
	sms_multi_trials              16
	sms_photon_count              100000
}
*/

/*
pathtracing_pel_rasterizer
{
	samples                       4
	oidn_denoise                  FALSE
	sms_enabled                   TRUE
	sms_max_iterations            30
	sms_threshold                 1e-4
	sms_max_chain_depth           10
	sms_biased                    TRUE
	sms_multi_trials              16
	sms_photon_count              100000
}
*/

file_rasterizeroutput
{
	pattern				rendered/pool_caustics_vcm
	type				EXR
	bpp					16
	color_space			ROMMRGB_Linear
	multiple			TRUE
}

DEFINE FRAMES 120

# Animation: 120 frames over normalized time [0, 1].  Only the Gerstner
# painter's `time` parameter is keyframed (see timeline block at the bottom).
animation_options
{
	time_start			0.0
	time_end			1.0
	num_frames			@FRAMES
}

##################################################
# Camera - high oblique view across the courtyard into the pool
##################################################

pinhole_camera
{
	location			0 4.0 6.5
	lookat				0 0 0.5
	up					0 1 0
	width				800
	height				600
	fov					70.0
}

##################################################
# Painters
##################################################

> run scenes/colors.RISEscript

# Water tint - near-white, very faint blue-green for realism
uniformcolor_painter
{
	name				pnt_water
	color				0.92 0.97 0.99
}

# Surrounding courtyard - two-tone sandstone checker
uniformcolor_painter
{
	name				pnt_courtyard_a
	color				0.70 0.66 0.58
}

uniformcolor_painter
{
	name				pnt_courtyard_b
	color				0.52 0.48 0.42
}

checker_painter
{
	name				pnt_courtyard_floor
	colora				pnt_courtyard_a
	colorb				pnt_courtyard_b
	size				0.08
}

# Stone pillar color - warm sandstone
uniformcolor_painter
{
	name				pnt_stone
	color				0.72 0.68 0.60
}

# Submerged-object colors — saturated enough to read clearly through 4 units of water.
uniformcolor_painter
{
	name				pnt_obj_crimson
	color				0.88 0.12 0.18
}

uniformcolor_painter
{
	name				pnt_obj_cerulean
	color				0.18 0.50 0.95
}

uniformcolor_painter
{
	name				pnt_obj_gold
	color				0.96 0.75 0.15
}

uniformcolor_painter
{
	name				pnt_obj_emerald
	color				0.14 0.68 0.32
}

uniformcolor_painter
{
	name				pnt_obj_violet
	color				0.55 0.18 0.75
}

##################################################
# Water surface wave function - SUM-OF-SINES GERSTNER DISPLACEMENT
# (identical to the photon-map scene so the two outputs can be compared)
##################################################

gerstnerwave_painter
{
	name				pnt_waves
	colora				color_black
	colorb				color_white
	num_waves			24
	median_wavelength	0.07
	wavelength_range	3.0
	median_amplitude	0.003
	amplitude_power		0.8
	wind_dir			1.0 0.3
	directional_spread	1.8
	dispersion_speed	1.0
	seed				17
	time				0.0
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				tile_floor
	reflectance			color_white
}

lambertian_material
{
	name				pool_wall
	reflectance			color_darkturquoise
}

# Fresnel dielectric: reflects + refracts with energy-conserving Fresnel split.
# More physically accurate than perfectrefractor — adds the surface reflection
# of the sky / courtyard / pillars that real pool water shows, and handles TIR
# for below-surface rays.  VCM's merge step handles both the LS+DE caustic and
# the S reflection paths naturally, so this is the right choice here.
dielectric_material
{
	name				water
	tau					pnt_water
	ior					1.33
	scattering			10000
	henyey-greenstein	FALSE
}

lambertian_material
{
	name				courtyard_tile
	reflectance			pnt_courtyard_floor
}

lambertian_material
{
	name				stone_column
	reflectance			pnt_stone
}

# Submerged-object materials (pure diffuse, so caustics show cleanly on top).
lambertian_material
{
	name				obj_red
	reflectance			pnt_obj_crimson
}

lambertian_material
{
	name				obj_blue
	reflectance			pnt_obj_cerulean
}

lambertian_material
{
	name				obj_gold
	reflectance			pnt_obj_gold
}

lambertian_material
{
	name				obj_green
	reflectance			pnt_obj_emerald
}

lambertian_material
{
	name				obj_purple
	reflectance			pnt_obj_violet
}

##################################################
# Geometry - pool
##################################################

clippedplane_geometry
{
	name				floor_geom
	pta					-4.0 0.0 -4.0
	ptb					-4.0 0.0 4.0
	ptc					4.0 0.0 4.0
	ptd					4.0 0.0 -4.0
}

standard_object
{
	name				pool_floor
	geometry			floor_geom
	position			0 -2.0 0
	material			tile_floor
}

clippedplane_geometry
{
	name				bwall_geom
	pta					-4.0 0.0 0.0
	ptb					-4.0 -2.0 0.0
	ptc					4.0 -2.0 0.0
	ptd					4.0 0.0 0.0
}

standard_object
{
	name				back_wall
	geometry			bwall_geom
	position			0 0 -4.0
	material			pool_wall
}

clippedplane_geometry
{
	name				lwall_geom
	pta					0.0 0.0 4.0
	ptb					0.0 -2.0 4.0
	ptc					0.0 -2.0 -4.0
	ptd					0.0 0.0 -4.0
}

standard_object
{
	name				left_wall
	geometry			lwall_geom
	position			-4.0 0 0
	material			pool_wall
}

clippedplane_geometry
{
	name				rwall_geom
	pta					0.0 0.0 -4.0
	ptb					0.0 -2.0 -4.0
	ptc					0.0 -2.0 4.0
	ptd					0.0 0.0 4.0
}

standard_object
{
	name				right_wall
	geometry			rwall_geom
	position			4.0 0 0
	material			pool_wall
}

clippedplane_geometry
{
	name				fwall_geom
	pta					4.0 0.0 0.0
	ptb					4.0 -2.0 0.0
	ptc					-4.0 -2.0 0.0
	ptd					-4.0 0.0 0.0
}

standard_object
{
	name				front_wall
	geometry			fwall_geom
	position			0 0 4.0
	material			pool_wall
}

##################################################
# Geometry - water surface (Gerstner displacement)
##################################################

clippedplane_geometry
{
	name				water_base
	pta					-4.0 0.0 -4.0
	ptb					-4.0 0.0 4.0
	ptc					4.0 0.0 4.0
	ptd					4.0 0.0 -4.0
}

displaced_geometry
{
	name				water_disp
	base_geometry		water_base
	detail				192
	displacement		pnt_waves
	disp_scale			1.0
	maxpolygons			10
	maxdepth			14
	bsp					TRUE
}

standard_object
{
	name				water_surface
	geometry			water_disp
	position			0 -0.1 0
	material			water
}

##################################################
# Submerged decorative objects — five distinct primitives at staggered depths
# (identical to the photon-map scene for side-by-side comparison).
##################################################

sphere_geometry
{
	name				obj_sphere
	radius				0.55
}

torus_geometry
{
	name				obj_torus
	majorradius			0.70
	minorratio			0.22
}

cylinder_geometry
{
	name				obj_cylinder
	axis				y
	radius				0.30
	height				1.2
}

ellipsoid_geometry
{
	name				obj_ellipsoid
	radii				0.80 0.28 0.55
}

box_geometry
{
	name				obj_box
	width				0.70
	height				0.70
	depth				0.70
}

standard_object
{
	name				red_sphere
	geometry			obj_sphere
	position			-1.7 -1.0 1.0
	material			obj_red
}

standard_object
{
	name				gold_torus
	geometry			obj_torus
	position			0.0 -1.3 -1.5
	orientation			25 15 0
	material			obj_gold
}

standard_object
{
	name				blue_cylinder
	geometry			obj_cylinder
	position			2.5 -1.4 1.2
	material			obj_blue
}

standard_object
{
	name				green_ellipsoid
	geometry			obj_ellipsoid
	position			-2.3 -1.72 0.5
	orientation			0 20 0
	material			obj_green
}

standard_object
{
	name				purple_box
	geometry			obj_box
	position			2.2 -1.65 -2.5
	orientation			0 30 0
	material			obj_purple
}

##################################################
# Geometry - courtyard (outer tiled floor around the pool)
##################################################

clippedplane_geometry
{
	name				outer_n_geom
	pta					-10.0 0.0 -10.0
	ptb					-10.0 0.0 -4.0
	ptc					10.0 0.0 -4.0
	ptd					10.0 0.0 -10.0
}

standard_object
{
	name				courtyard_n
	geometry			outer_n_geom
	position			0 0 0
	material			courtyard_tile
}

clippedplane_geometry
{
	name				outer_s_geom
	pta					-10.0 0.0 4.0
	ptb					-10.0 0.0 10.0
	ptc					10.0 0.0 10.0
	ptd					10.0 0.0 4.0
}

standard_object
{
	name				courtyard_s
	geometry			outer_s_geom
	position			0 0 0
	material			courtyard_tile
}

clippedplane_geometry
{
	name				outer_e_geom
	pta					4.0 0.0 -4.0
	ptb					4.0 0.0 4.0
	ptc					10.0 0.0 4.0
	ptd					10.0 0.0 -4.0
}

standard_object
{
	name				courtyard_e
	geometry			outer_e_geom
	position			0 0 0
	material			courtyard_tile
}

clippedplane_geometry
{
	name				outer_w_geom
	pta					-10.0 0.0 -4.0
	ptb					-10.0 0.0 4.0
	ptc					-4.0 0.0 4.0
	ptd					-4.0 0.0 -4.0
}

standard_object
{
	name				courtyard_w
	geometry			outer_w_geom
	position			0 0 0
	material			courtyard_tile
}

##################################################
# Stone pillars (Veach-style pillars framing the pool)
##################################################

cylinder_geometry
{
	name				pillar_a_geom
	axis				y
	radius				0.35
	height				3.6
}

standard_object
{
	name				pillar_ne
	geometry			pillar_a_geom
	position			6.5 1.8 -5.5
	material			stone_column
}

cylinder_geometry
{
	name				pillar_b_geom
	axis				y
	radius				0.45
	height				2.8
}

standard_object
{
	name				pillar_nw
	geometry			pillar_b_geom
	position			-6.2 1.4 -5.2
	material			stone_column
}

cylinder_geometry
{
	name				pillar_c_geom
	axis				y
	radius				0.40
	height				2.4
}

standard_object
{
	name				pillar_nnw
	geometry			pillar_c_geom
	position			-3.0 1.2 -7.5
	material			stone_column
}

cylinder_geometry
{
	name				pillar_d_geom
	axis				y
	radius				0.38
	height				3.2
}

standard_object
{
	name				pillar_nne
	geometry			pillar_d_geom
	position			2.5 1.6 -8.0
	material			stone_column
}

##################################################
# Lights - spot lights punch the pool (good for concentrated photon density
# in VCM's light subpaths, which is what drives the caustic merge step)
##################################################

spot_light
{
	name				sun
	position			0 9 -2
	target				0 -2 -0.5
	color				1.0 0.96 0.86
	power				100.0
	inner				22
	outer				55
}

spot_light
{
	name				fill
	position			0 7 -8
	target				0 0 0
	color				1.0 0.96 0.92
	power				150.0
	inner				70
	outer				120
}

##################################################
# Animation timeline — keyframe the Gerstner painter's `time` parameter so the
# water surface evolves frame-to-frame.  Identical animation to the photon-map
# scene (0 → 1.5 over normalized animation time [0, 1]) so the two outputs
# can be compared frame-by-frame.
##################################################

timeline
{
	element_type	painter
	element			pnt_waves
	param			time

	time			0.0
	value			0.0

	time			1.0
	value			1.5
}
