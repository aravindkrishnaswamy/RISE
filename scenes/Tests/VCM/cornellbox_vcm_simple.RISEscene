RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           cornellbox_vcm_simple.RISEscene                                                         #
#   Description:    Minimal self-contained Cornell box rendered with Vertex Connection and Merging.        #
#                   Used by Step 0 of the VCM rollout to verify end-to-end pipeline wiring (parser ->      #
#                   Job -> factory -> rasterizer dispatch -> output) before any algorithmic code lands.   #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 14, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

vcm_pel_rasterizer
{
	max_eye_depth		6
	max_light_depth		6
	samples				4
	merge_radius		0.0
	vc_enabled			true
	vm_enabled			true
}

file_rasterizeroutput
{
	pattern				rendered/cornellbox_vcm_simple
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			278 273 -800
	lookat				278 273 200
	up					0 1 0
	width				128
	height				128
	fov					37.0
}

uniformcolor_painter
{
	name				vcm_white
	color				1.0 1.0 1.0
}

uniformcolor_painter
{
	name				vcm_green
	color				0.1 0.6 0.1
}

uniformcolor_painter
{
	name				vcm_red
	color				0.6 0.1 0.1
}

uniformcolor_painter
{
	name				vcm_lightcolor
	color				1.0 0.9 0.7
}

lambertian_material
{
	name				white
	reflectance			vcm_white
}

lambertian_material
{
	name				green
	reflectance			vcm_green
}

lambertian_material
{
	name				red
	reflectance			vcm_red
}

lambertian_luminaire_material
{
	name				white_lum
	exitance			vcm_lightcolor
	scale				100.0
	material			none
}

clippedplane_geometry
{
	name				floorgeom
	pta					552.8 0 0
	ptb					0 0 0
	ptc					0 0 559.2
	ptd					549.6 0 559.2
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					556.0 548.8 0.0
	ptb					556.0 548.8 559.2
	ptc					0 548.8 559.2
	ptd					0.0 548.8 0.0
}

clippedplane_geometry
{
	name				bwallgeom
	pta					549.6 0 559.2
	ptb					0 0 559.2
	ptc					0 548.8 559.2
	ptd					556.0 548.8 559.2
}

clippedplane_geometry
{
	name				rwallgeom
	pta					0 0 559.2
	ptb					0 0 0
	ptc					0 548.8 0.0
	ptd					0 548.8 559.2
}

clippedplane_geometry
{
	name				lwallgeom
	pta					552.8 0 0
	ptb					549.6 0 559.2
	ptc					556.0 548.8 559.2
	ptd					556.0 548.8 0
}

clippedplane_geometry
{
	name				lightgeom
	pta					343.0 548.7999 227.0
	ptb					343.0 548.7999 332.0
	ptc					213.0 548.7999 332.0
	ptd					213.0 548.7999 227.0
}

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				bwall
	geometry			bwallgeom
	material			white
}

standard_object
{
	name				rwall
	geometry			rwallgeom
	material			green
}

standard_object
{
	name				lwall
	geometry			lwallgeom
	material			red
}

standard_object
{
	name				light
	geometry			lightgeom
	material			white_lum
}
