RISE ASCII SCENE 5
#############################################################################################################
#   diacaustic_vcm.RISEscene                                                                                #
#   VCM variant of the diacaustic (reflective-tube caustic) regression scene.  Exercises VM merging         #
#   on an S-D-S-E caustic path (light → metal tube specular reflection → wood surface → camera) that       #
#   BDPT struggles to hit via vertex connection alone.  Auto-radius derives from the light-pass bbox.       #
#############################################################################################################

standard_shader
{
	name			global
	shaderop		DefaultPathTracing
}

vcm_pel_rasterizer
{
	max_eye_depth		10
	max_light_depth		10
	samples				64
	merge_radius		0.0
	vc_enabled			true
	vm_enabled			true
}

file_rasterizeroutput
{
	pattern				rendered/diacaustic_vcm
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			0 0 200
	lookat				0 0 0
	up					0 1 0
	width				640
	height				480
	fov					45.0
	theta				60
}

> run scenes/colors.RISEscript

png_painter
{
	name				pnt_tex
	file				textures/wood.png
	color_space			sRGB
}

uniformcolor_painter
{
	name				pnt_refl
	color				1.0 0.625 0.29
}

lambertian_material
{
	name				white
	reflectance			color_white
}

lambertian_material
{
	name				wood
	reflectance			pnt_tex
}

perfectreflector_material
{
	name				metal
	reflectance			pnt_refl
}

lambertian_luminaire_material
{
	name				light
	exitance			color_white
	scale				5000
	material			white
}

rawmesh2_geometry
{
	name				geom_box
	file				models/raw/ring-caustic01_box.rawmesh2
	maxpolygons			10
	maxdepth			6
}

rawmesh2_geometry
{
	name				geom_tube
	file				models/raw/ring-caustic01_tube.rawmesh2
	maxpolygons			10
	maxdepth			6
}

clippedplane_geometry
{
	name				geom_light
	pta					-10 -120 100
	ptb					10 -120 100
	ptc					10 -130 100
	ptd					-10 -130 100
}

standard_object
{
	name				box
	geometry			geom_box
	material			wood
	orientation			-90 0 0
}

standard_object
{
	name				tube
	geometry			geom_tube
	material			metal
	orientation			-90 0 0
}

standard_object
{
	name				light
	geometry			geom_light
	material			light
	orientation			-90 0 0
}
