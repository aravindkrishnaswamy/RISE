#############################################################################################################


uniformcolor_painter
{
	name		color_white
	color		1.0 1.0 1.0
}













#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           povray_colors.RISEscene                                                                 #
#   Description:    Contains colors taken from POV-Ray                                                      #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################






















	
	

	




































































png_painter
{
	name				pnt_tex
	file				textures/wood.png
	color_space			sRGB
}

uniformcolor_painter
{
	name				pnt_refl
	color				1.0 0.625 0.29
}

lambertian_material
{
	name				white
	reflectance			color_white
}

lambertian_material
{
	name				wood
	reflectance			pnt_tex
}

perfectreflector_material
{
	name				metal
	reflectance			pnt_refl
}

lambertian_luminaire_material
{
	name				light
	exitance			color_white
	scale				5000
	material			white
}

rawmesh2_geometry
{
	name				geom_box
	file				models/raw/ring-caustic01_box.rawmesh2
	maxpolygons			10
	maxdepth			6
}

rawmesh2_geometry
{
	name				geom_tube
	file				models/raw/ring-caustic01_tube.rawmesh2
	maxpolygons			10
	maxdepth			6
}

clippedplane_geometry
{
	name				geom_light
	pta					-10 -120 100
	ptb					10 -120 100
	ptc					10 -130 100
	ptd					-10 -130 100
}

standard_object
{
	name				box
	geometry			geom_box
	material			wood
	orientation			-90 0 0
}

standard_object
{
	name				tube
	geometry			geom_tube
	material			metal
	orientation			-90 0 0
}

standard_object
{
	name				light
	geometry			geom_light
	material			light
	orientation			-90 0 0
}


