RISE ASCII SCENE 6
#############################################################################################################
#   diacaustic_vcm.RISEscene                                                                                #
#   VCM variant of the diacaustic (reflective-tube caustic) regression scene.  Exercises VM merging         #
#   on an S-D-S-E caustic path (light → metal tube specular reflection → wood surface → camera) that       #
#   BDPT struggles to hit via vertex connection alone.  Auto-radius derives from the light-pass bbox.       #
#############################################################################################################

standard_shader
{
	name			global
	shaderop		DefaultPathTracing
}

vcm_pel_rasterizer
{
	max_eye_depth		10
	max_light_depth		10
	samples				64
	merge_radius		0.0
	vc_enabled			true
	vm_enabled			true
}

/*
pathtracing_pel_rasterizer
{
	samples				512
	pathguiding				TRUE
	pathguiding_iterations	6
	pathguiding_spp			4
	pathguiding_alpha		0.5
	pathguiding_max_depth	3
    pathguiding_light_max_depth 0
	pathguiding_sampling_type	ris
	sms_enabled			FALSE
	sms_max_iterations	20
	sms_threshold		1e-3
	sms_max_chain_depth	20
	sms_biased			TRUE
}
*/

file_rasterizeroutput
{
	pattern				rendered/diacaustic_vcm
	type				PNG
	bpp					8
	color_space			sRGB
}

film
{
	width			640
	height			480
}

pinhole_camera
{
	location			0 0 200
	lookat				0 0 0
	up					0 1 0
	fov					45.0
	theta				60
}

# === RISE editor overrides (managed by interactive editor) ===
pinhole_camera
{
  name Side view
  fov 45
  location 0 0 123.822
  lookat 0 0 0
  up 0 1 0
  exposure 0
  scanning_rate 0
  pixel_rate 0
  orientation 0 0 0
  theta 30.4283
  phi -56.106
  iso 0
  fstop 0
}
# === end RISE editor overrides ===
