RISE ASCII SCENE 5
#############################################################################################################
#   triplecaustic_vcm.RISEscene                                                                             #
#   VCM Pel variant of the canonical three-sphere dielectric caustic scene.  Red/green/blue glass spheres  #
#   each cast an SDS caustic onto the white floor and back wall, overlapping to form a white caustic      #
#   where all three coincide.  VCM catches these via VM merging that BDPT alone misses.  Auto-radius.     #
#############################################################################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

vcm_pel_rasterizer
{
	max_eye_depth		10
	max_light_depth		10
	samples				64
	merge_radius		0.0
	vc_enabled			true
	vm_enabled			true
}

file_rasterizeroutput
{
	pattern				rendered/triplecaustic_vcm
	type				EXR
	color_space			ROMMRGB_Linear
}

pinhole_camera
{
	location			0 0.0 3.0
	lookat				0 0 0
	up					0 1 0
	width				512
	height				512
	fov					30.0
}

> run scenes/colors.RISEscript

perfectrefractor_material
{
	name				red_glass
	refractance			color_red
	ior					1.47
}

perfectrefractor_material
{
	name				green_glass
	refractance			color_green
	ior					1.47
}

perfectrefractor_material
{
	name				blue_glass
	refractance			color_blue
	ior					1.47
}

lambertian_material
{
	name				white
	reflectance			color_white
}

lambertian_luminaire_material
{
	name				white_lum
	exitance			color_white
	scale				90.0
	material			white
}

infiniteplane_geometry
{
	name				planegeom
	xtile				0.5
	ytile				0.5
}

standard_object
{
	name				planeA
	geometry			planegeom
	position			0.0 -0.5 0.0
	orientation			-90.0 0.0 0.0
	material			white
}

standard_object
{
	name				planeB
	geometry			planegeom
	position			0.0	 0.0 -0.8
	orientation			0.0 0.0 0.0
	material			white
}

sphere_geometry
{
	name				spheregeom
	radius				0.2
}

standard_object
{
	name				sphereA
	geometry			spheregeom
	position			-0.4 -0.3 0.1
	material			red_glass
}

standard_object
{
	name				sphereB
	geometry			spheregeom
	position			0 -0.3 -0.3
	material			green_glass
}

standard_object
{
	name				sphereC
	geometry			spheregeom
	position			0.4 -0.3 0.1
	material			blue_glass
}

clippedplane_geometry
{
	name				lightgeom
	pta					0.0 0.1 -0.1
	ptb					0.0 -0.1 -0.1
	ptc					0.0 -0.1 0.1
	ptd					0.0 0.1 0.1
}

clippedplane_geometry
{
	name				light2geom
	pta					0.0 0.1 -0.1
	ptb					0.0 -0.1 -0.1
	ptc					0.0 -0.1 0.1
	ptd					0.0 0.1 0.1
}

clippedplane_geometry
{
	name				light3geom
	pta					-0.1 0.1 0.0
	ptb					-0.1 -0.1 0.0
	ptc					0.1 -0.1 0.0
	ptd					0.1 0.1	0.0
}

standard_object
{
	name				light
	geometry			lightgeom
	position			0.8 0.0 0.1
	orientation			0 0 25
	material			white_lum
}

standard_object
{
	name				light2
	geometry			light2geom
	position			-0.8 0.0 0.1
	orientation			0 180 25
	material			white_lum
}

standard_object
{
	name				light3
	geometry			light3geom
	position			0 0 -0.7
	orientation			25 0 0
	material			white_lum
}
