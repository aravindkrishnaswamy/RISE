RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           loops.RISEscene                                                                         #
#   Description:    Tests the looping, macro substitution and math expression evaluation features           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 23, 2004                                                                          #
#                                                                                                           #
#############################################################################################################

# Be sure to set the object manager for BSP
> set accelerator B 10 8

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name				global
	shaderop			DefaultDirectLighting
}


pixelpel_rasterizer
{
	max_recursion		10
	samples				1
	lum_samples			1
}

file_rasterizeroutput
{
	pattern				rendered/loops
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

film
{
	width			500
	height			500
}

pinhole_camera
{
	location			0 0 0.5
	lookat				0 0 0
	up					0 1 0
	fov					30.0
}

##################################################
# Painters
##################################################

#############################################################################################################
#									RISE Ascii Scene File													#
#																											#
#	File: 			colors.scn																				#
#   Description:	Contains commonly used colors from all scenes											#
#	Author: 		Aravind Krishnaswamy																	#
#	Birthdate:		November 14, 2003																		#
#																											#
#############################################################################################################
