#############################################################################################################

##################################################
# Setup a renderer — standard power heuristic (no optimal MIS)
##################################################

pathtracing_shaderop
{
	name		pt
}

standard_shader
{
	name		global
	shaderop	pt
}

pixelpel_rasterizer
{
	max_recursion		5
	min_importance		0.01
	samples				64
	lum_samples			1
}

file_rasterizeroutput
{
	pattern				rendered/optimal_mis_test_baseline
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

pinhole_camera
{
	location			278 273 -800
	lookat				278 273 200
	up					0 1 0
	width				512
	height				512
	fov					37.0
}


##################################################
# Painters
##################################################
> run scenes/colors.RISEscript

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.9 0.7
}

uniformcolor_painter
{
	name				pnt_glossy
	color				0.8 0.8 0.8
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white
	reflectance			color_white
}

lambertian_material
{
	name				green
	reflectance			color_cornellgreen
}

lambertian_material
{
	name				red
	reflectance			color_cornellred
}

lambertian_luminaire_material
{
	name				white_lum
	exitance			pnt_light
	scale				300.0
	material			none
}

uniformcolor_painter
{
	name				pnt_phong_N
	color				100.0 100.0 100.0
}

isotropic_phong_material
{
	name				glossy
	rd					pnt_glossy
	rs					pnt_glossy
	N					pnt_phong_N
}

##################################################
# Objects - walls
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					552.8 0 0
	ptb					0 0 0
	ptc					0 0 559.2
	ptd					549.6 0 559.2
}

