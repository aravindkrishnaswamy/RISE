RISE ASCII SCENE 6
# Coverage: keyframe (single object-parameter keyframe).
# Legacy quirks preserved by the parser: (1) the target object must be named `object` (the
# element name is ignored; element_type doubles as the element name); (2) `element_type` is
# OMITTED here on purpose -- when present it overrides `param` to "object" and the keyframe fails.

film
{
	width		64
	height		64
}

uniformcolor_painter
{
	name		cc_gray
	color		0.5 0.5 0.5
}

lambertian_material
{
	name		cc_base
	reflectance	cc_gray
}

sphere_geometry
{
	name		cc_kf_sph
	radius		1.0
}

standard_object
{
	name		object
	geometry	cc_kf_sph
	material	cc_base
	position	0 0 0
}

keyframe
{
	param		position
	value		1 2 3
	time		1.0
	interpolator	linear
}
