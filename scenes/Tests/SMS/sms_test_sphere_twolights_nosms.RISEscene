RISE ASCII SCENE 5
#############################################################################################################
#   SMS Test (no-SMS reference): Glass sphere on diffuse floor with TWO area lights.
#   Purpose: Reference render without SMS for comparison with sms_test_sphere_twolights.
#   At convergence, this and the SMS variant should produce the same image.
#############################################################################################################

> set accelerator B 10 8

pathtracing_shaderop
{
	name		pt
}

standard_shader
{
	name		global
	shaderop	pt
}

bdpt_pel_rasterizer
{
	max_recursion		8
	min_importance		0.003
	max_eye_depth		8
	max_light_depth		6
	samples				256
	lum_samples			1
	ior_stack			TRUE
	sms_enabled			FALSE
}

file_rasterizeroutput
{
	pattern				rendered/sms_test_sphere_twolights_nosms
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			0 4 8
	lookat				0 0.5 0
	up					0 1 0
	width				200
	height				200
	fov					45.0
}

# Painters
uniformcolor_painter
{
	name				pnt_floor
	color				0.7 0.7 0.7
}

uniformcolor_painter
{
	name				pnt_light_warm
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_light_cool
	color				0.85 0.92 1.0
}

uniformcolor_painter
{
	name				pnt_glass_tau
	color				0.999 0.999 0.999
}

uniformcolor_painter
{
	name				pnt_glass_ior
	color				1.5 1.5 1.5
}

uniformcolor_painter
{
	name				pnt_scatter
	color				100000.0 100000.0 100000.0
}

# Materials
lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_luminaire_material
{
	name				light_warm_mat
	exitance			pnt_light_warm
	scale				500.0
	material			none
}

lambertian_luminaire_material
{
	name				light_cool_mat
	exitance			pnt_light_cool
	scale				350.0
	material			none
}

dielectric_material
{
	name				glass_mat
	tau					pnt_glass_tau
	ior					1.5
	scattering			pnt_scatter
}

# Geometry
sphere_geometry
{
	name				sphere_geom
	radius				1.0
}

clippedplane_geometry
{
	name				floor_geom
	pta					-5.0 0.0 -5.0
	ptb					-5.0 0.0 5.0
	ptc					5.0 0.0 5.0
	ptd					5.0 0.0 -5.0
}

clippedplane_geometry
{
	name				light_warm_geom
	pta					-1.5 0.0 -1.5
	ptb					1.5 0.0 -1.5
	ptc					1.5 0.0 1.5
	ptd					-1.5 0.0 1.5
}

clippedplane_geometry
{
	name				light_cool_geom
	pta					-1.0 0.0 -1.0
	ptb					1.0 0.0 -1.0
	ptc					1.0 0.0 1.0
	ptd					-1.0 0.0 1.0
}

# Objects
standard_object
{
	name				floor
	geometry			floor_geom
	material			floor_mat
}

standard_object
{
	name				glass_sphere
	geometry			sphere_geom
	position			0 1.5 0
	material			glass_mat
}

# Warm area light (directly above, larger and brighter)
standard_object
{
	name				warm_light
	geometry			light_warm_geom
	position			0 5.0 0
	material			light_warm_mat
}

# Cool area light (offset to the right, smaller and dimmer)
standard_object
{
	name				cool_light
	geometry			light_cool_geom
	position			2.5 4.5 -1.0
	material			light_cool_mat
}
