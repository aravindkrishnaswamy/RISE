RISE ASCII SCENE 5
# VCM reference for sms_k2_flatslab.RISEscene.  Identical geometry,
# VCM rasterizer instead of pathtracing+SMS.

> set accelerator B 10 8

> run scenes/colors.RISEscript

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

vcm_pel_rasterizer
{
	max_eye_depth		8
	max_light_depth		8
	samples				128
	merge_radius		0.0
	vc_enabled			true
	vm_enabled			true
	pixel_filter                  box
}

file_rasterizeroutput
{
	pattern				rendered/sms_k2_flatslab_ref
	type				PNG
	bpp					8
	color_space			sRGB
}

file_rasterizeroutput
{
	pattern				rendered/sms_k2_flatslab_ref
	type				EXR
	bpp					32
	color_space			Rec709RGB_Linear
}

pinhole_camera
{
	location			0 2.0 3
	lookat				0 0.2 0
	up					0 1 0
	width				200
	height				150
	fov					45.0
}

uniformcolor_painter
{
	name				pnt_floor
	color				0.8 0.75 0.65
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_glass
	color				1.0 1.0 1.0
}

perlin2d_painter
{
	name				pnt_bumps
	colora				color_black
	colorb				color_white
	persistence			0.5
	octaves				2
	scale				3.0 3.0
	shift				0 0
}

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				2000.0
	material			none
}

perfectrefractor_material
{
	name				glass_mat
	refractance			pnt_glass
	ior					2.2
}

clippedplane_geometry
{
	name				plane_base
	pta					-0.5 -0.5 0
	ptb					 0.5 -0.5 0
	ptc					 0.5  0.5 0
	ptd					-0.5  0.5 0
}

displaced_geometry
{
	name				top_plane_disp
	base_geometry		plane_base
	detail				64
	displacement		pnt_bumps
	disp_scale			0.0
	maxpolygons			10
	maxdepth			10
	bsp					TRUE
}

displaced_geometry
{
	name				bot_plane_disp
	base_geometry		plane_base
	detail				64
	displacement		pnt_bumps
	disp_scale			0.0
	maxpolygons			10
	maxdepth			10
	bsp					TRUE
}

clippedplane_geometry
{
	name				floor_geom
	pta					-4.0 0.0 -4.0
	ptb					-4.0 0.0 4.0
	ptc					4.0 0.0 4.0
	ptd					4.0 0.0 -4.0
}

clippedplane_geometry
{
	name				light_geom
	pta					-0.1 0.0 -0.1
	ptb					0.1 0.0 -0.1
	ptc					0.1 0.0 0.1
	ptd					-0.1 0.0 0.1
}

standard_object
{
	name				floor
	geometry			floor_geom
	material			floor_mat
}

standard_object
{
	name				top_plane
	geometry			top_plane_disp
	orientation			-90 0 0
	position			0 0.55 0
	material			glass_mat
}

standard_object
{
	name				bot_plane
	geometry			bot_plane_disp
	orientation			90 0 0
	position			0 0.45 0
	material			glass_mat
}

standard_object
{
	name				area_light
	geometry			light_geom
	position			0 1.5 0
	scale				0.4 0.4 0.4
	material			light_mat
}
