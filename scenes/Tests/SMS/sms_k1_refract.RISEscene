RISE ASCII SCENE 5
# k=1 SMS debug: single refractive plane with smooth displacement.
# Light above plane, floor below plane.  Light refracts through plane
# and produces a caustic on the floor.  If SMS can't render this, the
# pipeline is fundamentally broken at the simplest possible case.

> set accelerator B 10 8

> run scenes/colors.RISEscript

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       32
	oidn_denoise                  FALSE
	sms_enabled                   TRUE
	sms_max_iterations            30
	sms_threshold                 1e-4
	sms_max_chain_depth           5
	sms_biased                    TRUE
}

file_rasterizeroutput
{
	pattern				rendered/sms_k1_sms
	type				PNG
	bpp					8
	color_space			sRGB
}

file_rasterizeroutput
{
	pattern				rendered/sms_k1_sms
	type				EXR
	bpp					32
	color_space			Rec709RGB_Linear
}

pinhole_camera
{
	location			0 2.0 3
	lookat				0 0.2 0
	up					0 1 0
	width				200
	height				150
	fov					45.0
}

uniformcolor_painter
{
	name				pnt_floor
	color				0.8 0.75 0.65
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_glass
	color				1.0 1.0 1.0
}

perlin2d_painter
{
	name				pnt_bumps
	colora				color_black
	colorb				color_white
	persistence			0.5
	octaves				2
	scale				3.0 3.0
	shift				0 0
}

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				2000.0
	material			none
}

perfectrefractor_material
{
	name				glass_mat
	refractance			pnt_glass
	ior					2.2
}

# Base flat plane, 1x1 in XY, facing +Z (normal toward viewer initially).
# Positioned via the standard_object's orientation/position so it lies
# horizontally at y=0.5 between light and floor.
clippedplane_geometry
{
	name				plane_base
	pta					-0.5 -0.5 0
	ptb					 0.5 -0.5 0
	ptc					 0.5  0.5 0
	ptd					-0.5  0.5 0
}

displaced_geometry
{
	name				plane_disp
	base_geometry		plane_base
	detail				64
	displacement		pnt_bumps
	disp_scale			0.05
	maxpolygons			10
	maxdepth			10
	bsp					TRUE
}

clippedplane_geometry
{
	name				floor_geom
	pta					-4.0 0.0 -4.0
	ptb					-4.0 0.0 4.0
	ptc					4.0 0.0 4.0
	ptd					4.0 0.0 -4.0
}

clippedplane_geometry
{
	name				light_geom
	pta					-0.1 0.0 -0.1
	ptb					0.1 0.0 -0.1
	ptc					0.1 0.0 0.1
	ptd					-0.1 0.0 0.1
}

standard_object
{
	name				floor
	geometry			floor_geom
	material			floor_mat
}

# Horizontal refractive plane at y=0.5.  Orient -90° around X rotates
# the plane from (XY facing +Z) to (XZ facing -Y... actually let's
# verify) — we want it horizontal facing the light.
standard_object
{
	name				plane
	geometry			plane_disp
	orientation			-90 0 0
	position			0 0.5 0
	material			glass_mat
}

standard_object
{
	name				area_light
	geometry			light_geom
	position			0 1.5 0
	scale				0.4 0.4 0.4
	material			light_mat
}
