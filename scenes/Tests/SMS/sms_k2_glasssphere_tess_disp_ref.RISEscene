RISE ASCII SCENE 5
# VCM reference for sms_k2_glasssphere_tess_disp — same displaced tessellated
# sphere as the SMS variant, rendered with VCM instead of SMS so we can
# compare caustic energy and structure.

> set accelerator B 10 8

> run scenes/colors.RISEscript

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

vcm_pel_rasterizer
{
	max_eye_depth		8
	max_light_depth		8
	samples				128
	merge_radius		0.0
	vc_enabled			true
	vm_enabled			true
	pixel_filter		box
}

file_rasterizeroutput
{
	pattern				rendered/sms_k2_glasssphere_tess_disp_ref
	type				PNG
	bpp					8
	color_space			sRGB
}

file_rasterizeroutput
{
	pattern				rendered/sms_k2_glasssphere_tess_disp_ref
	type				EXR
	bpp					32
	color_space			Rec709RGB_Linear
}

pinhole_camera
{
	location			0 2.0 3
	lookat				0 0.2 0
	up					0 1 0
	width				200
	height				150
	fov					45.0
}

uniformcolor_painter
{
	name				pnt_floor
	color				0.8 0.75 0.65
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_glass
	color				1.0 1.0 1.0
}

perlin2d_painter
{
	name				pnt_bumps
	colora				color_black
	colorb				color_white
	persistence			0.5
	octaves				2
	scale				3.0 3.0
	shift				0 0
}

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				2000.0
	material			none
}

perfectrefractor_material
{
	name				glass_mat
	refractance			pnt_glass
	ior					2.2
}

sphere_geometry
{
	name				sphere_base
	radius				0.3
}

# Same displaced sphere as the SMS variant.
displaced_geometry
{
	name				sphere_tess_disp
	base_geometry		sphere_base
	detail				64
	displacement		pnt_bumps
	disp_scale			0.02
	maxpolygons			10
	maxdepth			14
	bsp					TRUE
}

clippedplane_geometry
{
	name				floor_geom
	pta					-4.0 0.0 -4.0
	ptb					-4.0 0.0 4.0
	ptc					4.0 0.0 4.0
	ptd					4.0 0.0 -4.0
}

clippedplane_geometry
{
	name				light_geom
	pta					-0.1 0.0 -0.1
	ptb					0.1 0.0 -0.1
	ptc					0.1 0.0 0.1
	ptd					-0.1 0.0 0.1
}

standard_object
{
	name				floor
	geometry			floor_geom
	material			floor_mat
}

standard_object
{
	name				glass_ball
	geometry			sphere_tess_disp
	position			0 0.6 0
	material			glass_mat
}

standard_object
{
	name				area_light
	geometry			light_geom
	position			0 1.5 0
	scale				0.4 0.4 0.4
	material			light_mat
}
