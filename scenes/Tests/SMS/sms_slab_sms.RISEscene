RISE ASCII SCENE 5
#############################################################################################################
#   Double-Refractive Slab with SMS: A displaced glass slab (watertight mesh) above a diffuse floor.       #
#   Light refracts through the bumpy slab creating intricate caustic patterns on the floor.                 #
#   This is the scenario where SMS excels — standard path tracing cannot find these SDS paths.              #
#############################################################################################################

> set accelerator B 10 8

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       128
	oidn_denoise                  FALSE
	sms_enabled                   TRUE
	sms_max_iterations            20
	sms_threshold                 1e-4
	sms_max_chain_depth           10
	sms_biased                    TRUE
}

file_rasterizeroutput
{
	pattern				rendered/sms_slab_sms
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			0 4 5
	lookat				0 0.3 0
	up					0 1 0
	width				800
	height				600
	fov					45.0
}

uniformcolor_painter
{
	name				pnt_floor
	color				0.8 0.75 0.65
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_glass
	color				1.0 1.0 1.0
}

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				500.0
	material			none
}

perfectrefractor_material
{
	name				glass_mat
	refractance			pnt_glass
	ior					1.75
}

rawmesh2_geometry
{
	name				slab_geom
	file				models/raw/displaced_slab.raw
	maxpolygons			10
	maxdepth			24
	double_sided		TRUE
}

clippedplane_geometry
{
	name				floor_geom
	pta					-6.0 0.0 -6.0
	ptb					-6.0 0.0 6.0
	ptc					6.0 0.0 6.0
	ptd					6.0 0.0 -6.0
}

clippedplane_geometry
{
	name				light_geom
	pta					-0.4 0.0 -0.4
	ptb					0.4 0.0 -0.4
	ptc					0.4 0.0 0.4
	ptd					-0.4 0.0 0.4
}

standard_object
{
	name				floor
	geometry			floor_geom
	material			floor_mat
}

standard_object
{
	name				glass_slab
	geometry			slab_geom
	position			0 1.5 0
	material			glass_mat
}

standard_object
{
	name				area_light
	geometry			light_geom
	position			0 5.0 0
	material			light_mat
}
