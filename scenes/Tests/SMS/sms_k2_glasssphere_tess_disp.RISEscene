RISE ASCII SCENE 5
# Displaced tessellated sphere SMS test.  Same scene as sms_k2_glasssphere_tess
# but with an actual non-zero displacement applied to the sphere via a perlin
# noise painter.  This exercises the FULL displaced-geometry pipeline:
# displacement moves vertices, RecomputeVertexNormalsFromTopology regenerates
# per-vertex normals from the new topology, and the UV-Jacobian inversion in
# the mesh intersection code translates barycentric-edge derivatives into
# the stored (u,v) parameterisation.
#
# Purpose: verify SMS remains within acceptable agreement against a VCM
# reference when vertices are genuinely displaced (not just disp_scale=0
# used as a "force tessellation" idiom).

> set accelerator B 10 8

> run scenes/colors.RISEscript

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       128
	oidn_denoise                  FALSE
	sms_enabled                   TRUE
	sms_max_iterations            30
	sms_threshold                 1e-4
	sms_max_chain_depth           10
	sms_biased                    TRUE
	sms_multi_trials              32
	sms_photon_count              100000
	pixel_filter                  box
}

file_rasterizeroutput
{
	pattern				rendered/sms_k2_glasssphere_tess_disp
	type				PNG
	bpp					8
	color_space			sRGB
}

file_rasterizeroutput
{
	pattern				rendered/sms_k2_glasssphere_tess_disp
	type				EXR
	bpp					32
	color_space			Rec709RGB_Linear
}

pinhole_camera
{
	location			0 2.0 3
	lookat				0 0.2 0
	up					0 1 0
	width				200
	height				150
	fov					45.0
}

uniformcolor_painter
{
	name				pnt_floor
	color				0.8 0.75 0.65
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_glass
	color				1.0 1.0 1.0
}

perlin2d_painter
{
	name				pnt_bumps
	colora				color_black
	colorb				color_white
	persistence			0.5
	octaves				2
	scale				3.0 3.0
	shift				0 0
}

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				2000.0
	material			none
}

perfectrefractor_material
{
	name				glass_mat
	refractance			pnt_glass
	ior					2.2
}

sphere_geometry
{
	name				sphere_base
	radius				0.3
}

# Displaced, tessellated sphere — perlin bumps push the surface along the
# local normal.  disp_scale=0.02 is small relative to r=0.3 so we keep a
# recognisable sphere with gentle deformations (caustic structure stays).
displaced_geometry
{
	name				sphere_tess_disp
	base_geometry		sphere_base
	detail				64
	displacement		pnt_bumps
	disp_scale			0.02
	maxpolygons			10
	maxdepth			14
	bsp					TRUE
}

clippedplane_geometry
{
	name				floor_geom
	pta					-4.0 0.0 -4.0
	ptb					-4.0 0.0 4.0
	ptc					4.0 0.0 4.0
	ptd					4.0 0.0 -4.0
}

clippedplane_geometry
{
	name				light_geom
	pta					-0.1 0.0 -0.1
	ptb					0.1 0.0 -0.1
	ptc					0.1 0.0 0.1
	ptd					-0.1 0.0 0.1
}

standard_object
{
	name				floor
	geometry			floor_geom
	material			floor_mat
}

standard_object
{
	name				glass_ball
	geometry			sphere_tess_disp
	position			0 0.6 0
	material			glass_mat
}

standard_object
{
	name				area_light
	geometry			light_geom
	position			0 1.5 0
	scale				0.4 0.4 0.4
	material			light_mat
}
