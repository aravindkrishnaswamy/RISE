RISE ASCII SCENE 5
# Tessellated-sphere SMS test.  Identical scene to sms_k2_glasssphere_boxfilter
# except the glass_ball uses displaced_geometry(sphere, disp_scale=0) so we
# force a triangle-mesh representation of a PERFECTLY closed sphere — no
# actual displacement, but the tessellation discretizes the smooth surface.
#
# Purpose: isolate whether BuildSeedChain / Newton solver degradation is
# caused by the tessellated-triangle surface derivatives (dpdu, dpdv, dndu,
# dndv) vs the analytic sphere's smooth derivatives.  If this render matches
# the analytic sphere render, the tessellation isn't the problem.  If it
# diverges, we have the clue we're after.

> set accelerator B 10 8

> run scenes/colors.RISEscript

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       32
	oidn_denoise                  FALSE
	sms_enabled                   TRUE
	sms_max_iterations            30
	sms_threshold                 1e-4
	sms_max_chain_depth           10
	sms_biased                    TRUE
	pixel_filter                  box
}

file_rasterizeroutput
{
	pattern				rendered/sms_k2_glasssphere_tess
	type				PNG
	bpp					8
	color_space			sRGB
}

file_rasterizeroutput
{
	pattern				rendered/sms_k2_glasssphere_tess
	type				EXR
	bpp					32
	color_space			Rec709RGB_Linear
}

pinhole_camera
{
	location			0 2.0 3
	lookat				0 0.2 0
	up					0 1 0
	width				200
	height				150
	fov					45.0
}

uniformcolor_painter
{
	name				pnt_floor
	color				0.8 0.75 0.65
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_glass
	color				1.0 1.0 1.0
}

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				2000.0
	material			none
}

perfectrefractor_material
{
	name				glass_mat
	refractance			pnt_glass
	ior					2.2
}

sphere_geometry
{
	name				sphere_base
	radius				0.3
}

# Tessellated sphere — identical closed sphere, but forced to triangle mesh.
displaced_geometry
{
	name				sphere_tess
	base_geometry		sphere_base
	detail				64
	disp_scale			0.0
	maxpolygons			10
	maxdepth			14
	bsp					TRUE
}

clippedplane_geometry
{
	name				floor_geom
	pta					-4.0 0.0 -4.0
	ptb					-4.0 0.0 4.0
	ptc					4.0 0.0 4.0
	ptd					4.0 0.0 -4.0
}

clippedplane_geometry
{
	name				light_geom
	pta					-0.1 0.0 -0.1
	ptb					0.1 0.0 -0.1
	ptc					0.1 0.0 0.1
	ptd					-0.1 0.0 0.1
}

standard_object
{
	name				floor
	geometry			floor_geom
	material			floor_mat
}

standard_object
{
	name				glass_ball
	geometry			sphere_tess
	position			0 0.6 0
	material			glass_mat
}

standard_object
{
	name				area_light
	geometry			light_geom
	position			0 1.5 0
	scale				0.4 0.4 0.4
	material			light_mat
}
