RISE ASCII SCENE 5
# k=2 SMS test: single closed GLASS SPHERE.
#
# Replaces the two-plane bumpy slab with a closed sphere of smooth
# continuously-varying curvature.  Eye rays that hit the sphere
# refract at the front surface, traverse the interior, refract at
# the back surface, and land on the floor.  The caustic is the
# focused image of the light through the sphere (lens action).
#
# Goal: separate "bumpy-displacement effect" from "k=2 chain per se"
# — a sphere has non-zero smooth curvature (dpdu / dpdv / dndu /
# dndv all well-defined analytically) and is a closed volume (one
# object, not two interpenetrating planes).

> set accelerator B 10 8

> run scenes/colors.RISEscript

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       32
	oidn_denoise                  FALSE
	sms_enabled                   TRUE
	sms_max_iterations            30
	sms_threshold                 1e-4
	sms_max_chain_depth           10
	sms_biased                    TRUE
	pixel_filter                  box
}

file_rasterizeroutput
{
	pattern				rendered/sms_k2_glasssphere
	type				PNG
	bpp					8
	color_space			sRGB
}

file_rasterizeroutput
{
	pattern				rendered/sms_k2_glasssphere
	type				EXR
	bpp					32
	color_space			Rec709RGB_Linear
}

pinhole_camera
{
	location			0 2.0 3
	lookat				0 0.2 0
	up					0 1 0
	width				200
	height				150
	fov					45.0
}

uniformcolor_painter
{
	name				pnt_floor
	color				0.8 0.75 0.65
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_glass
	color				1.0 1.0 1.0
}

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				2000.0
	material			none
}

perfectrefractor_material
{
	name				glass_mat
	refractance			pnt_glass
	ior					2.2
}

sphere_geometry
{
	name				sphere_geom
	radius				0.3
}

clippedplane_geometry
{
	name				floor_geom
	pta					-4.0 0.0 -4.0
	ptb					-4.0 0.0 4.0
	ptc					4.0 0.0 4.0
	ptd					4.0 0.0 -4.0
}

clippedplane_geometry
{
	name				light_geom
	pta					-0.1 0.0 -0.1
	ptb					0.1 0.0 -0.1
	ptc					0.1 0.0 0.1
	ptd					-0.1 0.0 0.1
}

standard_object
{
	name				floor
	geometry			floor_geom
	material			floor_mat
}

standard_object
{
	name				glass_ball
	geometry			sphere_geom
	position			0 0.6 0
	material			glass_mat
}

standard_object
{
	name				area_light
	geometry			light_geom
	position			0 1.5 0
	scale				0.4 0.4 0.4
	material			light_mat
}
