RISE ASCII SCENE 5
#############################################################################################################
#   Double-Refractive Slab (Close, Photon Map): Light and camera closer to slab for better photon           #
#   efficiency.  The slab subtends ~7x larger solid angle from the light compared to the far version.       #
#############################################################################################################

> set accelerator B 10 8

standard_shader
{
	name		global
 	shaderop	DefaultDirectLighting
	shaderop	DefaultCausticPelPhotonMap
	shaderop	DefaultReflection
	shaderop	DefaultRefraction
}

pixelpel_rasterizer
{
	max_recursion                 10
	samples                       4
	lum_samples                   1
	oidn_denoise                  FALSE
	pixel_filter                  box
}

file_rasterizeroutput
{
	pattern				rendered/sms_slab_close_photonmap
	type				PNG
	bpp					8
	color_space			sRGB
}

file_rasterizeroutput
{
	pattern				rendered/sms_slab_close_photonmap
	type				EXR
	bpp					32
	color_space			Rec709RGB_Linear
}

pinhole_camera
{
	location			0 2.0 3
	lookat				0 0.2 0
	up					0 1 0
	width				400
	height				300
	fov					45.0
}

uniformcolor_painter
{
	name				pnt_floor
	color				0.8 0.75 0.65
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_glass
	color				1.0 1.0 1.0
}

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				2000.0
	material			none
}

perfectrefractor_material
{
	name				glass_mat
	refractance			pnt_glass
	ior					2.2
}

rawmesh2_geometry
{
	name				slab_geom
	file				models/raw/displaced_slab.raw
	maxpolygons			10
	maxdepth			24
	double_sided		TRUE
}

clippedplane_geometry
{
	name				floor_geom
	pta					-4.0 0.0 -4.0
	ptb					-4.0 0.0 4.0
	ptc					4.0 0.0 4.0
	ptd					4.0 0.0 -4.0
}

clippedplane_geometry
{
	name				light_geom
	pta					-0.1 0.0 -0.1
	ptb					0.1 0.0 -0.1
	ptc					0.1 0.0 0.1
	ptd					-0.1 0.0 0.1
}

standard_object
{
	name				floor
	geometry			floor_geom
	material			floor_mat
}

standard_object
{
	name				glass_slab
	geometry			slab_geom
	orientation			-45 0 0 
	position			0 0.5 0
	material			glass_mat
}

standard_object
{
	name				area_light
	geometry			light_geom
	position			0 1.2 -0.1
	orientation 		-45 0 0
	scale				0.4 0.4 0.4
	material			light_mat
}

caustic_pel_photonmap
{
	num					1000000
	max_recursion		10
	min_importance		0.001
	branch				TRUE
	reflect				TRUE
	refract				TRUE
	regenerate			FALSE
}

caustic_pel_gather
{
	max_photons			500
	ellipse_ratio		0.05
}
