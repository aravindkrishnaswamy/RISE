RISE ASCII SCENE 5
# SMS Test: Polished material sphere with very high Phong exponent (delta mode)
# High scattering exponent (>=1e6) triggers near-delta specular behavior

> set accelerator B 10 8

pathtracing_shaderop
{
	name		pt
}

standard_shader
{
	name		global
	shaderop	pt
}

bdpt_pel_rasterizer
{
	max_recursion		8
	min_importance		0.003
	max_eye_depth		8
	max_light_depth		6
	samples				256
	lum_samples			1
	ior_stack			TRUE
	sms_enabled			TRUE
	sms_max_iterations	20
	sms_threshold		1e-5
	sms_max_chain_depth	10
	sms_biased			TRUE
}

file_rasterizeroutput
{
	pattern				rendered/sms_test_polished
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			0 4 8
	lookat				0 0.5 0
	up					0 1 0
	width				200
	height				200
	fov					45.0
}

uniformcolor_painter
{
	name				pnt_floor
	color				0.7 0.7 0.7
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 1.0 1.0
}

uniformcolor_painter
{
	name				pnt_reflectance
	color				0.95 0.95 0.95
}

uniformcolor_painter
{
	name				pnt_tau
	color				0.999 0.999 0.999
}

uniformcolor_painter
{
	name				pnt_ior
	color				1.5 1.5 1.5
}

uniformcolor_painter
{
	name				pnt_scatter
	color				1e6 1e6 1e6
}

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				500.0
	material			none
}

polished_material
{
	name				polished_mat
	reflectance			pnt_reflectance
	tau					pnt_tau
	ior					1.5
	scattering			pnt_scatter
}

sphere_geometry
{
	name				sphere_geom
	radius				1.0
}

clippedplane_geometry
{
	name				floor_geom
	pta					-5.0 0.0 -5.0
	ptb					-5.0 0.0 5.0
	ptc					5.0 0.0 5.0
	ptd					5.0 0.0 -5.0
}

clippedplane_geometry
{
	name				light_geom
	pta					-1.5 0.0 -1.5
	ptb					1.5 0.0 -1.5
	ptc					1.5 0.0 1.5
	ptd					-1.5 0.0 1.5
}

standard_object
{
	name				floor
	geometry			floor_geom
	material			floor_mat
}

standard_object
{
	name				polished_sphere
	geometry			sphere_geom
	position			0 1.5 0
	material			polished_mat
}

standard_object
{
	name				area_light
	geometry			light_geom
	position			0 5.0 0
	material			light_mat
}
