RISE ASCII SCENE 5
# k=1 SMS debug: smoothly-displaced plane as a single specular surface
# (using perfectreflector as the simplest k=1 case).  The plane is
# tilted so that a small area light above it reflects onto the floor
# below (classic "mirror caustic" geometry).  Camera looks down at the
# floor — the caustic should be clearly visible.
#
# If SMS doesn't render this case correctly, the pipeline is broken at
# the simplest possible level.  Fast 80x60 render for tight iteration.

> set accelerator B 10 8

> run scenes/colors.RISEscript

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       512
	oidn_denoise                  FALSE
	sms_enabled                   FALSE
}

file_rasterizeroutput
{
	pattern				rendered/sms_k1_mirror_ref
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			0 2.0 3
	lookat				0 0.2 0
	up					0 1 0
	width				200
	height				150
	fov					45.0
}

uniformcolor_painter
{
	name				pnt_floor
	color				0.8 0.75 0.65
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_mirror
	color				0.9 0.9 0.9
}

perlin2d_painter
{
	name				pnt_bumps
	colora				color_black
	colorb				color_white
	persistence			0.5
	octaves				2
	scale				3.0 3.0
	shift				0 0
}

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				2000.0
	material			none
}

perfectreflector_material
{
	name				mirror_mat
	reflectance			pnt_mirror
}

# Tilted plane acting as the mirror.  Base is in the X-Y plane; tilted
# -45° around X via object orientation so the normal is (0, cos45, sin45)
# and it reflects light from above-rear onto the floor in front.
clippedplane_geometry
{
	name				mirror_base
	pta					-0.6 -0.6 0
	ptb					 0.6 -0.6 0
	ptc					 0.6  0.6 0
	ptd					-0.6  0.6 0
}

displaced_geometry
{
	name				mirror_disp
	base_geometry		mirror_base
	detail				48
	displacement		pnt_bumps
	disp_scale			0.0
	maxpolygons			10
	maxdepth			10
	bsp					TRUE
}

clippedplane_geometry
{
	name				floor_geom
	pta					-4.0 0.0 -4.0
	ptb					-4.0 0.0 4.0
	ptc					4.0 0.0 4.0
	ptd					4.0 0.0 -4.0
}

clippedplane_geometry
{
	name				light_geom
	pta					-0.1 0.0 -0.1
	ptb					0.1 0.0 -0.1
	ptc					0.1 0.0 0.1
	ptd					-0.1 0.0 0.1
}

standard_object
{
	name				floor
	geometry			floor_geom
	material			floor_mat
}

# Tilted mirror at y=0.7, facing up-toward-camera.  Displaced by Perlin.
standard_object
{
	name				mirror
	geometry			mirror_disp
	orientation			-45 0 0
	position			0 0.7 -0.3
	material			mirror_mat
}

# Light placed BEHIND and ABOVE the mirror so reflection goes DOWN
# and FORWARD onto the floor in front of the mirror.  Mirror is tilted
# -45° around X so its normal is (0, 0.707, 0.707); light at (0, 2.3, -1.3)
# reflects to roughly (0, -0.8, 0.5) hitting the floor at z~+0.5.
standard_object
{
	name				area_light
	geometry			light_geom
	position			0 2.3 -1.3
	scale				0.4 0.4 0.4
	material			light_mat
}
