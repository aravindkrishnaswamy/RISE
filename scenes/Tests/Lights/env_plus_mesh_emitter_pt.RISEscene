RISE ASCII SCENE 6
#############################################################################################################
#   File:           env_plus_mesh_emitter_pt.RISEscene
#   Description:    PT oracle for the mixed HDRI + mesh-emitter MIS fix (Codex review Finding 3).
#
#                   A SEALED Cornell box (6 walls, camera inside) is lit ONLY by an interior mesh
#                   emitter.  A very bright GLOBAL uniform environment also exists but is BLOCKED by
#                   the walls -- it never lights the interior and is never seen by a camera ray.  Its
#                   sole effect is to drive cachedEnvSelectProb -> ~1 (env luminance >> alias total),
#                   which is exactly the regime that exposes the bug.
#
#                   THE BUG (pre-fix): PT samples the mesh emitter from the alias table
#                   INDEPENDENTLY (pdfAlias = aliasTable.Pdf, alias-only), but the BSDF-hit MIS
#                   competitor queried CachedPdfSelectLuminary, which the continuous-PMF work made
#                   return the JOINT (1-envSelectProb)-scaled pmf.  With envSelectProb -> 1 that pmf
#                   -> 0, so p_nee on the BSDF-hit side -> 0 and w_bsdf -> 1 (instead of ~0.5) =>
#                   the mesh emitter's contribution is OVERCOUNTED by up to ~1.5x.  The bright env
#                   never touches the interior, so the overcount is NOT diluted -- the whole interior
#                   reads too bright vs a BDPT / VCM reference.
#
#                   THE FIX: CachedPdfSelectLuminary returns the ALIAS-ONLY pmf, matching PT's
#                   independent alias sampling.  PT then agrees with BDPT / VCM.  Env-only and
#                   mesh-only scenes are unaffected (the joint factor is 1 when one is absent).
#
#                   PASS criterion: PT mean agrees with BDPT / VCM; PT-pre-fix is visibly brighter.
#############################################################################################################

> set accelerator B 10 8

uniformcolor_painter
{
	name				pnt_env
	color				1.0 1.0 1.0
}

uniformcolor_painter
{
	name				pnt_white
	color				0.73 0.73 0.73
}

uniformcolor_painter
{
	name				pnt_red
	color				0.63 0.06 0.04
}

uniformcolor_painter
{
	name				pnt_green
	color				0.12 0.45 0.15
}

uniformcolor_painter
{
	name				pnt_emit
	color				1.0 1.0 1.0
}

standard_shader
{
	name		global
	shaderop	DefaultDirectLighting
}

# radiance_scale 1000 => env total luminance >> mesh alias total =>
# cachedEnvSelectProb -> ~1.  radiance_background FALSE: the sealed box
# means no camera ray ever escapes, but make it explicit.
pathtracing_pel_rasterizer
{
	samples				256
	pixel_filter		box
	radiance_map		pnt_env
	radiance_scale		1000.0
	radiance_background	FALSE
}

file_rasterizeroutput
{
	pattern				rendered/env_plus_mesh_emitter_pt
	type				EXR
	bpp					16
	color_space			Rec709RGB_Linear
}

file_rasterizeroutput
{
	pattern				rendered/env_plus_mesh_emitter_pt
	type				PNG
	bpp					8
	color_space			sRGB
}

film
{
	width			128
	height			128
}

# Camera sealed INSIDE the box (front wall at z=0 is behind it), looking +Z.
pinhole_camera
{
	location			278 273 40
	lookat				278 273 560
	up					0 1 0
	fov					55.0
}

lambertian_material
{
	name				white
	reflectance			pnt_white
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_luminaire_material
{
	name				emit_mat
	exitance			pnt_emit
	scale				8.0
	material			none
}

clippedplane_geometry
{
	name				floorgeom
	pta					556 0 0
	ptb					0 0 0
	ptc					0 0 560
	ptd					556 0 560
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					556 549 0
	ptb					556 549 560
	ptc					0 549 560
	ptd					0 549 0
}

clippedplane_geometry
{
	name				backwallgeom
	pta					0 0 560
	ptb					0 549 560
	ptc					556 549 560
	ptd					556 0 560
}

clippedplane_geometry
{
	name				frontwallgeom
	pta					0 0 0
	ptb					556 0 0
	ptc					556 549 0
	ptd					0 549 0
}

clippedplane_geometry
{
	name				leftwallgeom
	pta					0 0 560
	ptb					0 0 0
	ptc					0 549 0
	ptd					0 549 560
}

clippedplane_geometry
{
	name				rightwallgeom
	pta					556 0 0
	ptb					556 0 560
	ptc					556 549 560
	ptd					556 549 0
}

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	material			white
}

standard_object
{
	name				frontwall
	geometry			frontwallgeom
	material			white
}

standard_object
{
	name				leftwall
	geometry			leftwallgeom
	material			red
}

standard_object
{
	name				rightwall
	geometry			rightwallgeom
	material			green
}

# Bright interior mesh emitter (the ONLY light reaching the interior).
sphere_geometry
{
	name				emit_geom
	radius				55
}

standard_object
{
	name				meshlight
	geometry			emit_geom
	position			278 440 280
	material			emit_mat
}
