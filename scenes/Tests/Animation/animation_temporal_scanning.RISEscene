RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           animation_temporal_scanning.RISEscene                                                   #
#   Description:    Demonstrates the temporal scanning abilities of cameras                                 #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 8, 2005                                                                           #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name			global
	shaderop		DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion		10
	samples				16
	lum_samples			1
}

/*
file_rasterizeroutput
{
	pattern				rendered/animation_temporal_scanning
	type				PNG
	bpp					8
	color_space			sRGB
	multiple			TRUE
}
*/


animation_options
{
	time_start			0
	time_end			1
	num_frames			30.000000000000
	do_fields			TRUE
}

##################################################
# Cameras
##################################################

# Shutter time is amount of time per frame the entire shutter isopen

# Frame exposure gives the total amount of time a frame is exposed

# Total number of scanlines

# Each scanline is scanned individually and all pixels in a scanline
# are recorded instantaneously


# This is just arbritary non-physically based settings, but they look cool

film
{
	width			600
	height			200.000000000000
}

pinhole_camera
{
	location			0 0 0.5
	lookat				0 0 0
	up					0 1 0
	fov					20.0
	exposure			0.050000000000
	scanning_rate		0.001000000000
}

##################################################
# Painters
##################################################

#############################################################################################################
#									RISE Ascii Scene File													#
#																											#
#	File: 			colors.scn																				#
#   Description:	Contains commonly used colors from all scenes											#
#	Author: 		Aravind Krishnaswamy																	#
#	Birthdate:		November 14, 2003																		#
#																											#
#############################################################################################################
#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           standard_colors.RISEscene                                                               #
#   Description:    Contains some standard colors                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################


uniformcolor_painter
{
	name		color_white
	color		1.0 1.0 1.0
}













#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           povray_colors.RISEscene                                                                 #
#   Description:    Contains colors taken from POV-Ray                                                      #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################
















uniformcolor_painter
{
	name		color_gold
	color		0.8 0.498039 0.196078 
}






	
	

	




































































##################################################
# Materials
##################################################

lambertian_material
{
	name				gold
	reflectance			color_gold
}

lambertian_material
{
	name				white
	reflectance			color_white
}

##################################################
# Objects
##################################################

box_geometry
{
	name			boxgeom
	width			0.06
	height			0.06
	depth			0.00000001
}

standard_object
{
	name				box
	geometry			boxgeom
	position			0 0 0.0
	orientation			0 0 0
	material			gold
}

infiniteplane_geometry
{
	name				planegeom
	xtile				1.0
	ytile				1.0
}

standard_object
{
	name				plane
	geometry			planegeom
	position			0 -0.1 0
	orientation			-90 0 0
	material			white
}

omni_light
{
	name		lightA
	power		3.14159
	color		1.0 1.0 1.0
	position	0.0 0.1 0.1
}

##################################################
# Keyframes
##################################################

timeline
{
	element		box
	param		position
	
	time		0.0
	value		-0.2 0 0.0
	
	time		1.0
	value		0.2 0 0.0
}



