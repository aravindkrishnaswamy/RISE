RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           dof.RISEScene                                                                           #
#   Description:    Demonstrates depth of field effects via the thin lens camera.  Note the thin lens       #
#                   camera can be difficult to use.  Consider the realistic camera instead.                 #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      December 11, 2003                                                                       #
#                                                                                                           #
#############################################################################################################

##################################################
# Scene-level options.  Geometry is in metres (scene_unit defaults
# to 1.0): a 3 m painted cube at the origin, viewed from 8 m by a
# 100 mm f/1.4 telephoto.  At this distance + aperture the DOF span
# is only ~0.5 m — far narrower than the cube's 5 m corner-to-
# corner depth — so the focal plane VISIBLY sweeps through the cube
# as `focus_distance` changes.  Try sweeping focus_distance from 5
# (cube fully past focus) up through 8 (centre sharp, corners blur)
# to 30+ (cube fully past focus the other direction).
##################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion			10
	samples					64
	lum_samples				1
	adaptive_max_samples	500
	adaptive_threshold		0.0005
#	show_adaptive_map		true
}

file_rasterizeroutput
{
	pattern				rendered/thinlens
	type				PNG
	bpp					8
	color_space			sRGB
}


##################################################
# Cameras
##################################################

thinlens_camera
{
	location			0 0 8
	lookat				0 0 0
	up					0 1 0
	width				1024
	height				512
	sensor_size			36              # mm — full-frame 35mm
	focal_length		100             # mm — short telephoto
	fstop				1.4             # cinema-prime fast aperture
	focus_distance		8               # metres — onto cube centre; near and far corners fall out of DOF
}

##################################################
# Painters
##################################################

> run scenes/colors.RISEscript

png_painter
{
	name				pnt_texture
	file				textures/paradise.png
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				texture
	reflectance			pnt_texture
}

##################################################
# Objects - 
##################################################

box_geometry
{
	name				boxgeom
	width				3.0
	height				3.0
	depth				3.0
}

standard_object
{
	name				box
	geometry			boxgeom
	orientation			45 45 0
	material			texture
}

##################################################
# Lights
##################################################

directional_light
{
	name		light
	power		3.14
	color		1.0 1.0 1.0
	direction	0.0 0.0 1.0
}

