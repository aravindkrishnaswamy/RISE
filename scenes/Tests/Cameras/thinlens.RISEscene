RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           dof.RISEScene                                                                           #
#   Description:    Demonstrates depth of field effects via the thin lens camera.  Note the thin lens       #
#                   camera can be difficult to use.  Consider the realistic camera instead.                 #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      December 11, 2003                                                                       #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion			10
	samples					64
	lum_samples				1
	adaptive_max_samples	500
	adaptive_threshold		0.0005
#	show_adaptive_map		true
}

file_rasterizeroutput
{
	pattern				rendered/thinlens
	type				PNG
	bpp					8
	color_space			sRGB
}


##################################################
# Cameras
##################################################

thinlens_camera
{
	location			0 0 30
	lookat				0 0 0
	up					0 1 0
	width				1024
	height				512
	sensor_size			4.94			# matches the previous fov=20 with focal=14
	focal_length		14				# 14mm
	fstop				2.8				# f/2.8
	focus_distance		28.0			# focus distance
}

##################################################
# Painters
##################################################

> run scenes/colors.RISEscript

png_painter
{
	name				pnt_texture
	file				textures/paradise.png
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				texture
	reflectance			pnt_texture
}

##################################################
# Objects - 
##################################################

box_geometry
{
	name				boxgeom
	width				5.0
	height				5.0
	depth				5.0
}

standard_object
{
	name				box
	geometry			boxgeom
	orientation			45 45 0
	material			texture
}

##################################################
# Lights
##################################################

directional_light
{
	name		light
	power		3.14
	color		1.0 1.0 1.0
	direction	0.0 0.0 1.0
}

