RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           fisheye.RISEscene                                                                       #
#   Description:    Demonstrates the use of the fisheye camera                                              #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      February 25, 2005                                                                       #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

hdr_painter
{
	name				pnt_rad
	file				lightprobes/uffizi_probe.hdr
}

standard_shader
{
	name			global
	shaderop		DefaultReflection
}

pixelpel_rasterizer
{
	max_recursion		10
	samples			64
	pixel_filter		tent
	pixel_filter_width	2
	pixel_filter_height	2
	radiance_map		pnt_rad
	radiance_background	TRUE
}

file_rasterizeroutput
{
	pattern				rendered/fisheye
	type				PNG
	bpp				16	
	color_space			ProPhotoRGB
}

##################################################
# Cameras
##################################################

film
{
	width			500
	height			500
}

fisheye_camera
{
	location			0 -55 650
	lookat				0 -55 0
	up					0 1 0
	scale				1.6
}

##################################################
# Painters
##################################################

#############################################################################################################
#									RISE Ascii Scene File													#
#																											#
#	File: 			colors.scn																				#
#   Description:	Contains commonly used colors from all scenes											#
#	Author: 		Aravind Krishnaswamy																	#
#	Birthdate:		November 14, 2003																		#
#																											#
#############################################################################################################
#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           standard_colors.RISEscene                                                               #
#   Description:    Contains some standard colors                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################















#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           povray_colors.RISEscene                                                                 #
#   Description:    Contains colors taken from POV-Ray                                                      #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################






















	
	

	













uniformcolor_painter
{
	name		color_orangered
	color		1.0 0.25 0.0 
}









uniformcolor_painter
{
	name		color_slateblue
	color		0.0 0.498039 1.0 
}












































uniformcolor_painter
{
	name		color_light_purple
	color		0.87 0.58 0.98 
}


iridescent_painter
{
	name				pnt_iri
	colora				color_light_purple
	colorb				color_slateblue
}

##################################################
# Materials
##################################################

perfectreflector_material
{
	name				iridescent_mirror
	reflectance			pnt_iri
}

perfectreflector_material
{
	name				mirror
	reflectance			color_orangered
}

##################################################
# Objects - 
##################################################

clippedplane_geometry
{
	name				planegeom
	pta					-350.0 400.0 0.0
	ptb					-350 -400 0.0
	ptc					350 -400 0.0
	ptd					350 400 0.0
}

risemesh_geometry
{
	name				meshgeom
	file				models/risemesh/creature.risemesh
}
								
standard_object
{
	name				plane
	geometry			planegeom
	position			0.0 -420.0 0.0
	orientation			-90.0 0.0 0.0
	material			mirror
}

standard_object
{
	name				mesh
	geometry			meshgeom
	position			150.0 150.0 200.0
	orientation			-90.0 0.0 -45.0
	material			iridescent_mirror
}


