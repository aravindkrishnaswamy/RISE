RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           realistic.RISEScene                                                                     #
#   Description:    Demonstrates the photographic thin-lens camera with full-frame 35mm settings.            #
#                   (Was previously the `realistic_camera` stub; migrated when the keyword was reserved      #
#                   for the future multi-element lens camera. See docs/CAMERAS_ROADMAP.md Phase 4.)         #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      May 5, 2006                                                                             #
#                                                                                                           #
#############################################################################################################

##################################################
# Scene-level options.  Geometry is in metres (scene_unit defaults
# to 1.0).  A 15 m painted box at the origin, viewed from 30 m by
# a 50 mm "normal" lens wide-open at f/1.4.  Focus pulled to 8 m
# (well in front of the box) so the box defocuses to a soft bokeh
# field — full-frame 35mm cinematic DOF on a normal lens.
##################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion			10
	samples					32
	lum_samples				1
	adaptive_max_samples	2000
	adaptive_threshold		0.0005
#	show_adaptive_map		true
}

file_rasterizeroutput
{
	pattern				rendered/realisic
	type				PNG
	bpp					8
	color_space			sRGB
}


##################################################
# Cameras
##################################################

thinlens_camera
{
	location			0 0 30
	lookat				0 0 0
	up					0 1 0
	width				512
	height				512
	sensor_size			36              # mm — full-frame 35mm-still
	focal_length		50              # mm — normal lens
	fstop				1.4             # cinema-prime fast aperture
	focus_distance		8               # metres — pulled in front of the cube
}

##################################################
# Painters
##################################################

> run scenes/colors.RISEscript

png_painter
{
	name				pnt_texture
	file				textures/paradise.png
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				texture
	reflectance			pnt_texture
}

##################################################
# Objects - 
##################################################

box_geometry
{
	name				boxgeom
	width				15.0
	height				15.0
	depth				15.0
}

standard_object
{
	name				box
	geometry			boxgeom
	orientation			45 45 0
	material			texture
}

##################################################
# Lights
##################################################

directional_light
{
	name		light
	power		3.14
	color		1.0 1.0 1.0
	direction	0.0 0.0 1.0
}

