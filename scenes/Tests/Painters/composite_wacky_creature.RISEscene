RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           composite_wacky_creature.RISEscene                                                      #
#   Description:    Two wacky displaced creatures rendered side-by-side, each built from a deep cascade of  #
#                   `composite_function2d_painter` chunks driving a `displaced_geometry`.  The two share    #
#                   the file but are intentionally orthogonal in every way:                                 #
#                                                                                                           #
#                     Creature 1 (LEFT):  "honey-amber blob"                                                #
#                       Shape leaves: monkey_saddle, paraboloid, three radial bumps (eye-eye-mouth),        #
#                                     chin bulge, two Perlins                                               #
#                       Composite ops: sum, difference, sum, sum, difference, sum, sum (7 layers)           #
#                       Material: `subsurfacescattering_material` — honey-amber translucent SSS so          #
#                                 the lumpy mass GLOWS, with absorption tinted toward warm wavelengths      #
#                                                                                                           #
#                     Creature 2 (RIGHT): "spiky metallic shell"                                            #
#                       Shape leaves: BIVARIATE polynomial (rotated saddle x² + xy − y²), TWO Gerstner      #
#                                     wave fields (long + short wavelength), monomial cubic ridges,         #
#                                     three tight "spikes" (radial bumps with scale=0.05 — very pointy)     #
#                       Composite ops: sum, lerp, MAX × 3 (spikes), sum (6 layers).  The `max` op is the    #
#                                     key — it gives sharp pointy spikes rather than smooth additive bumps. #
#                       Material: `pbr_metallic_roughness_material` with metallic=1 and a Voronoi3D base    #
#                                 color of metallic-tinted patches (gold, copper, gunmetal, steel) for a    #
#                                 "patchwork meteorite" look                                                 #
#                                                                                                           #
#                   The two creatures together exercise every displacement op (sum / difference / lerp /    #
#                   max), every polynomial family except hyperbolic_saddle, plus Gerstner waves at two      #
#                   wavelengths, and demonstrate that the same composite painter system can drive both      #
#                   organic-SSS and inorganic-metallic looks.                                               #
#                                                                                                           #
#   Author:         RISE contributors                                                                       #
#   Birthdate:      2026-05-12                                                                              #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup
##################################################

# DefaultPathTracing (not DefaultDirectLighting) is required for the
# SSS volume to actually scatter — the direct-lighting shader op skips
# the volume integration entirely.  Path tracer + 64 spp gives the SSS
# enough samples to converge while keeping the metallic creature clean.
standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples		64
}

file_rasterizeroutput
{
	pattern		rendered/composite_wacky_creature
	type		PNG
	bpp			8
	color_space	sRGB
}

##################################################
# Camera — wide framing for two creatures side-by-side
##################################################

film
{
	width		1200
	height		600
}

pinhole_camera
{
	location	0 0.3 7
	lookat		0 0 0
	up			0 1 0
	fov			40.0
}

#############################################################################################################
#									RISE Ascii Scene File													#
#																											#
#	File: 			colors.scn																				#
#   Description:	Contains commonly used colors from all scenes											#
#	Author: 		Aravind Krishnaswamy																	#
#	Birthdate:		November 14, 2003																		#
#																											#
#############################################################################################################
#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           standard_colors.RISEscene                                                               #
#   Description:    Contains some standard colors                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################

uniformcolor_painter
{
	name		color_black
	color		0.0 0.0 0.0
}

uniformcolor_painter
{
	name		color_white
	color		1.0 1.0 1.0
}













