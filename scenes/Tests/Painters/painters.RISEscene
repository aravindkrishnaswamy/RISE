#############################################################################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name			global
	shaderop		DefaultDirectLighting
}
/*
pixelpel_rasterizer
{
	max_recursion		10
	samples				4
	lum_samples			1
}
*/

bdpt_pel_rasterizer
{
	samples				16
}


file_rasterizeroutput
{
	pattern				rendered/painters
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

film
{
	width			900
	height			800
}

pinhole_camera
{
	location			0 0 40
	lookat				0 0 0
	up					0 1 0
	fov					20.0
}

##################################################
# Painters
##################################################

#############################################################################################################
#									RISE Ascii Scene File													#
#																											#
#	File: 			colors.scn																				#
#   Description:	Contains commonly used colors from all scenes											#
#	Author: 		Aravind Krishnaswamy																	#
#	Birthdate:		November 14, 2003																		#
#																											#
#############################################################################################################
#############################################################################################################
#                                   RISE Ascii Scene File                                                   #
#                                                                                                           #
#   File:           standard_colors.RISEscene                                                               #
#   Description:    Contains some standard colors                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 22, 2004                                                                          #
#                                                                                                           #
#############################################################################################################

uniformcolor_painter
{
	name		color_black
	color		0.0 0.0 0.0
}

uniformcolor_painter
{
	name		color_white
	color		1.0 1.0 1.0
}

uniformcolor_painter
{
	name		color_red
	color		1.0 0.0 0.0
}

uniformcolor_painter
{
	name		color_green
	color		0.0 1.0 0.0
}

uniformcolor_painter
{
	name		color_blue
	color		0.0 0.0 1.0
}










