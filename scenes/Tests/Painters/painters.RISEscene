}






















uniformcolor_painter
{
	name		color_darkpurple
	color		0.53 0.12 0.47 
}
























mandelbrot_painter
{
	name				pnt_mandelbrot
	colora				color_orange
	colorb				color_black
	xstart				-1.75
	xend				0.75
	ystart				-1.25
	yend				1.25
	exponent			1.0
}

perlin2d_painter
{
	name				pnt_perlin2d
	colora				color_white
	colorb				color_black
	persistence			0.5
	scale				25 25
	shift				0 0
	octaves				4
}

voronoi3d_painter
{
	name				pnt_voronoi3d
	border				color_white
	bordersize			0.02

#	gen					0.15 0.15 0.0 color_red
#	gen					0.01 0.0 0.1 color_blue
#	gen					-0.2 0.1 -0.15 color_green
#	gen					0.3 0.3 0.0 color_gold
#	gen					-0.2 -0.1 0.1 color_coral

	gen					0.00000000000000000	0.00000000000000000	0.00000000000000000	color_indianred
	gen					0.00000000000000000	0.66666666666666663	1.20000000000000018	color_cadetblue
	gen					0.00000000000000000	1.33333333333333326	0.80000000000000004	color_forestgreen
	gen					0.00000000000000000	0.22222222222222221	0.40000000000000002	color_gold
	gen					0.00000000000000000	0.88888888888888884	1.60000000000000009	color_coral
	gen					0.00000000000000000	1.55555555555555536	0.24000000000000005	color_aquamarine
	gen					0.00000000000000000	0.44444444444444442	1.44000000000000017	color_lightsteelblue
	gen					0.00000000000000000	1.11111111111111116	1.04000000000000004	color_limegreen
	gen					0.00000000000000000	1.77777777777777768	0.64000000000000012	color_firebrick
	gen					0.00000000000000000	0.07407407407407406	1.84000000000000008	color_maroon
}

checker_painter
{
	name				pnt_checker
	colora				color_brown
	colorb				color_indianred
	size				0.05
}

png_painter
{
	name				pnt_tex
	file				textures/paradise.png
}

iridescent_painter
{
	name				pnt_iri
	colora				color_darkpurple
	colorb				color_slateblue
	bias				-0.5
}

blend_painter
{
	name				pnt_blend
	colora				pnt_voronoi3d
	colorb				pnt_tex
	mask				pnt_perlin2d
}

lines_painter
{
	name				pnt_lines
	colora				color_maroon
	colorb				color_orange
	size				0.1
}

blackbody_painter
{
	name				pnt_blackbody
	temperature			3500
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				red
	reflectance			color_red
}

lambertian_material
{
	name				fractal
	reflectance			pnt_mandelbrot
}

lambertian_material
{
	name				perlin
	reflectance			pnt_perlin2d
}

lambertian_material
{
	name				voronoi
	reflectance			pnt_voronoi3d
}

lambertian_material
{
	name				checker
	reflectance			pnt_checker
}

lambertian_material
{
	name				texture
	reflectance			pnt_tex
}

lambertian_material
{
	name				iridescent
	reflectance			pnt_iri
}

lambertian_material
{
	name				blended
	reflectance			pnt_blend
}

lambertian_material
{
	name				lines
	reflectance			pnt_lines
}

lambertian_material
{
	name				blackbody
	reflectance			pnt_blackbody
}


