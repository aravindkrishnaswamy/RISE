RISE ASCII SCENE 5
#############################################################################################################
#  Stability Controls Test: Indirect clamp - PT
#
#  Cornell box with a glass sphere and glossy gold sphere to drive
#  multi-bounce indirect paths.  indirect_clamp 5.0 should suppress
#  fireflies from caustic/glossy inter-reflections without noticeably
#  affecting direct lighting.
#############################################################################################################

> set accelerator B 10 8

pathtracing_shaderop
{
	name		pt
	branch		false
}

standard_shader
{
	name		global
	shaderop	pt
}

pixelpel_rasterizer
{
	max_recursion		10
	min_importance		0.001
	samples				64
	lum_samples			1
	ior_stack			TRUE
	indirect_clamp		5.0
}

file_rasterizeroutput
{
	pattern				rendered/clamp_indirect_pt
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			278 273 -800
	lookat				278 273 0
	up					0 1 0
	width				256
	height				256
	fov					39.0
}

> run scenes/colors.RISEscript

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_warm_white
	color				0.73 0.71 0.68
}

uniformcolor_painter
{
	name				pnt_green
	color				0.12 0.45 0.15
}

uniformcolor_painter
{
	name				pnt_red
	color				0.63 0.06 0.04
}

uniformcolor_painter
{
	name				pnt_black
	color				0.0 0.0 0.0
}

uniformcolor_painter
{
	name				pnt_gold_spec
	color				1.0 0.85 0.35
}

uniformcolor_painter
{
	name				pnt_glass_ior
	color				1.5 1.5 1.5
}

lambertian_material
{
	name				white
	reflectance			pnt_warm_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

dielectric_material
{
	name				glass
	tau					pnt_warm_white
	ior					pnt_glass_ior
	scattering			none
}

cooktorrance_material
{
	name				gold
	rd					pnt_black
	rs					pnt_gold_spec
	facets				0.08
	ior					2.5
	extinction			3.0
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				200.0
	material			none
}

clippedplane_geometry
{
	name				floorgeom
	pta					556 0 0
	ptb					0 0 0
	ptc					0 0 556
	ptd					556 0 556
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					556 549 0
	ptb					556 549 556
	ptc					0 549 556
	ptd					0 549 0
}

clippedplane_geometry
{
	name				backwallgeom
	pta					556 0 556
	ptb					556 549 556
	ptc					0 549 556
	ptd					0 0 556
}

clippedplane_geometry
{
	name				leftwallgeom
	pta					0 0 556
	ptb					0 0 0
	ptc					0 549 0
	ptd					0 549 556
}

clippedplane_geometry
{
	name				rightwallgeom
	pta					556 0 0
	ptb					556 0 556
	ptc					556 549 556
	ptd					556 549 0
}

clippedplane_geometry
{
	name				lightgeom
	pta					343 548.8 213
	ptb					343 548.8 343
	ptc					213 548.8 343
	ptd					213 548.8 213
}

sphere_geometry
{
	name				glass_spheregeom
	radius				65
}

sphere_geometry
{
	name				gold_spheregeom
	radius				65
}

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	material			white
}

standard_object
{
	name				leftwall
	geometry			leftwallgeom
	material			red
}

standard_object
{
	name				rightwall
	geometry			rightwallgeom
	material			green
}

standard_object
{
	name				light
	geometry			lightgeom
	material			light_mat
}

standard_object
{
	name				glass_sphere
	geometry			glass_spheregeom
	position			170 65 300
	material			glass
}

standard_object
{
	name				gold_sphere
	geometry			gold_spheregeom
	position			386 65 240
	material			gold
}
