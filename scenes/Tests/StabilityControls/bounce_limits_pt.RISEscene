RISE ASCII SCENE 5
#############################################################################################################
#  Stability Controls Test: Per-type bounce limits - PT
#
#  Cornell box with a glass sphere to test max_diffuse_bounce and
#  max_transmission_bounce independently.
#############################################################################################################

> set accelerator B 10 8

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       64
	max_diffuse_bounce            2
	max_transmission_bounce       50
}

file_rasterizeroutput
{
	pattern				rendered/bounce_limits_pt
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			278 273 -800
	lookat				278 273 0
	up					0 1 0
	width				256
	height				256
	fov					39.0
}

> run scenes/colors.RISEscript

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_warm_white
	color				0.73 0.71 0.68
}

uniformcolor_painter
{
	name				pnt_green
	color				0.12 0.45 0.15
}

uniformcolor_painter
{
	name				pnt_red
	color				0.63 0.06 0.04
}

uniformcolor_painter
{
	name				pnt_glass_ior
	color				1.5 1.5 1.5
}

lambertian_material
{
	name				white
	reflectance			pnt_warm_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

dielectric_material
{
	name				glass
	tau					pnt_warm_white
	ior					pnt_glass_ior
	scattering			none
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				200.0
	material			none
}

clippedplane_geometry
{
	name				floorgeom
	pta					556 0 0
	ptb					0 0 0
	ptc					0 0 556
	ptd					556 0 556
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					556 549 0
	ptb					556 549 556
	ptc					0 549 556
	ptd					0 549 0
}

clippedplane_geometry
{
	name				backwallgeom
	pta					556 0 556
	ptb					556 549 556
	ptc					0 549 556
	ptd					0 0 556
}

clippedplane_geometry
{
	name				leftwallgeom
	pta					0 0 556
	ptb					0 0 0
	ptc					0 549 0
	ptd					0 549 556
}

clippedplane_geometry
{
	name				rightwallgeom
	pta					556 0 0
	ptb					556 0 556
	ptc					556 549 556
	ptd					556 549 0
}

clippedplane_geometry
{
	name				lightgeom
	pta					343 548.8 213
	ptb					343 548.8 343
	ptc					213 548.8 343
	ptd					213 548.8 213
}

sphere_geometry
{
	name				spheregeom
	radius				80
}

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	material			white
}

standard_object
{
	name				leftwall
	geometry			leftwallgeom
	material			red
}

standard_object
{
	name				rightwall
	geometry			rightwallgeom
	material			green
}

standard_object
{
	name				light
	geometry			lightgeom
	material			light_mat
}

standard_object
{
	name				glass_sphere
	geometry			spheregeom
	position			278 80 278
	material			glass
}
