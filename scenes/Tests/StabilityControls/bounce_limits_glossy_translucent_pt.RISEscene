RISE ASCII SCENE 5
#############################################################################################################
#  Stability Controls Test: Glossy and translucent bounce limits - PT
#
#  Cornell box with a glossy gold sphere and two nested translucent
#  spheres.  max_glossy_bounce 2 limits glossy inter-reflections.
#  max_translucent_bounce 2 limits subsurface scattering depth.
#  The translucent material uses high scattering (0.9) so that each
#  surface intersection generates an eRayTranslucent event on both
#  entry and exit.  Two concentric spheres produce 4+ translucent
#  events per path, ensuring the limit of 2 actually engages.
#############################################################################################################

> set accelerator B 10 8

pathtracing_shaderop
{
	name		pt
	branch		false
}

standard_shader
{
	name		global
	shaderop	pt
}

pixelpel_rasterizer
{
	max_recursion			10
	min_importance			0.001
	samples					64
	lum_samples				1
	ior_stack				TRUE
	max_glossy_bounce		2
	max_translucent_bounce	2
}

file_rasterizeroutput
{
	pattern				rendered/bounce_limits_glossy_translucent_pt
	type				PNG
	bpp					8
	color_space			sRGB
}

pinhole_camera
{
	location			278 273 -800
	lookat				278 273 0
	up					0 1 0
	width				256
	height				256
	fov					39.0
}

> run scenes/colors.RISEscript

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
}

uniformcolor_painter
{
	name				pnt_warm_white
	color				0.73 0.71 0.68
}

uniformcolor_painter
{
	name				pnt_green
	color				0.12 0.45 0.15
}

uniformcolor_painter
{
	name				pnt_red
	color				0.63 0.06 0.04
}

uniformcolor_painter
{
	name				pnt_black
	color				0.0 0.0 0.0
}

uniformcolor_painter
{
	name				pnt_gold_spec
	color				1.0 0.85 0.35
}

uniformcolor_painter
{
	name				pnt_trans_ref
	color				0.9 0.85 0.8
}

uniformcolor_painter
{
	name				pnt_trans_ext
	color				0.1 0.1 0.1
}

lambertian_material
{
	name				white
	reflectance			pnt_warm_white
}

lambertian_material
{
	name				green
	reflectance			pnt_green
}

lambertian_material
{
	name				red
	reflectance			pnt_red
}

cooktorrance_material
{
	name				gold
	rd					pnt_black
	rs					pnt_gold_spec
	facets				0.08
	ior					2.5
	extinction			3.0
}

translucent_material
{
	name				trans
	ref					pnt_trans_ref
	tau					pnt_trans_ref
	ext					pnt_trans_ext
	N					2.0
	scattering			0.9
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_light
	scale				200.0
	material			none
}

clippedplane_geometry
{
	name				floorgeom
	pta					556 0 0
	ptb					0 0 0
	ptc					0 0 556
	ptd					556 0 556
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					556 549 0
	ptb					556 549 556
	ptc					0 549 556
	ptd					0 549 0
}

clippedplane_geometry
{
	name				backwallgeom
	pta					556 0 556
	ptb					556 549 556
	ptc					0 549 556
	ptd					0 0 556
}

clippedplane_geometry
{
	name				leftwallgeom
	pta					0 0 556
	ptb					0 0 0
	ptc					0 549 0
	ptd					0 549 556
}

clippedplane_geometry
{
	name				rightwallgeom
	pta					556 0 0
	ptb					556 0 556
	ptc					556 549 556
	ptd					556 549 0
}

clippedplane_geometry
{
	name				lightgeom
	pta					343 548.8 213
	ptb					343 548.8 343
	ptc					213 548.8 343
	ptd					213 548.8 213
}

sphere_geometry
{
	name				gold_spheregeom
	radius				65
}

sphere_geometry
