RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           sss_comparison_dragon.RISEscene                                                        #
#   Description:    Side-by-side comparison of diffusion BSSRDF (left) vs random-walk SSS (right)          #
#                   using the small dragon mesh.  A large area light is placed BEHIND the dragons          #
#                   so that light transmits through thin regions (ears, wings, tail).  The random           #
#                   walk should show more accurate translucency in thin parts because it traces             #
#                   the actual volumetric path, whereas the diffusion profile assumes a semi-               #
#                   infinite slab and overestimates attenuation in thin geometry.                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 7, 2026                                                                           #
#                                                                                                           #
#############################################################################################################

##################################################
# Renderer setup
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       512
	lum_samples                   1
	ior_stack                     TRUE
}

file_rasterizeroutput
{
	pattern				rendered/sss_comparison_dragon
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera
#
# Looking at both dragons from the front.
# The backlight is behind them (negative Z).
##################################################

pinhole_camera
{
	location			0 -1.5 20
	lookat				0 -1.5 0
	up					0 1 0
	width				960
	height				480
	fov					30.0
}

##################################################
# Painters
##################################################

uniformcolor_painter
{
	name				pnt_floor
	color				0.15 0.15 0.15
	colorspace			ROMMRGB_Linear
}

uniformcolor_painter
{
	name				pnt_backwall
	color				0.05 0.05 0.05
	colorspace			ROMMRGB_Linear
}

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.95 0.85
	colorspace			ROMMRGB_Linear
}

# Waxy/skin-like SSS coefficients — moderate scattering,
# warm absorption.  Same for both materials so the only
# difference is the transport model.
uniformcolor_painter
{
	name				pnt_absorption
	color				0.8 0.4 0.04
	colorspace			ROMMRGB_Linear
}

uniformcolor_painter
{
	name				pnt_scattering
	color				3.0 3.5 4.0
	colorspace			ROMMRGB_Linear
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_material
{
	name				wall_mat
	reflectance			pnt_backwall
}

lambertian_luminaire_material
{
	name				lum
	exitance			pnt_light
	scale				8
	material			none
}

# LEFT dragon: analytical diffusion BSSRDF
subsurfacescattering_material
{
	name				diffusion_sss
	ior					1.3
	absorption			pnt_absorption
	scattering			pnt_scattering
	g					0.0
	roughness			0.1
}

# RIGHT dragon: volumetric random-walk SSS
randomwalk_sss_material
{
	name				randomwalk_sss
	ior					1.3
	absorption			pnt_absorption
	scattering			pnt_scattering
	g					0.0
	roughness			0.1
	max_bounces			64
}

##################################################
# Geometry
##################################################

risemesh_geometry
{
	name				dragon_mesh
	file				models/risemesh/dragon_small.risemesh
}

clippedplane_geometry
{
	name				floorgeom
	pta					-20 -20 0
	ptb					20 -20 0
	ptc					20 20 0
	ptd					-20 20 0
}

clippedplane_geometry
{
	name				lightgeom
	pta					-15 -15 0
	ptb					15 -15 0
	ptc					15 15 0
	ptd					-15 15 0
}

##################################################
# Objects
##################################################

# LEFT dragon — diffusion BSSRDF
standard_object
{
	name				dragon_diffusion
	geometry			dragon_mesh
	orientation			0 30 0
	position			-3.8 -5.6 0
	scale				40 40 40
	material			diffusion_sss
}

# RIGHT dragon — random-walk SSS
standard_object
{
	name				dragon_randomwalk
	geometry			dragon_mesh
	orientation			0 30 0
	position			3.8 -5.6 0
	scale				40 40 40
	material			randomwalk_sss
}

# Floor
standard_object
{
	name				floor
	geometry			floorgeom
	position			0 -5.6 0
	orientation			-90 0 0
	material			floor_mat
}

##################################################
# Lighting
#
# Large area light BEHIND the dragons (negative Z)
# to show translucency through thin regions.
# A small fill from above/front keeps the front
# surfaces from going completely black.
##################################################

# Main backlight — large panel behind the dragons
standard_object
{
	name				backlight
	geometry			lightgeom
	material			lum
	position			0 0 -7
	orientation			0 0 0
}

# Subtle top fill light (smaller, dimmer)
clippedplane_geometry
{
	name				fillgeom
	pta					-3 -3 0
	ptb					3 -3 0
	ptc					3 3 0
	ptd					-3 3 0
}

lambertian_luminaire_material
{
	name				lum_fill
	exitance			pnt_light
	scale				0.5
	material			none
}

standard_object
{
	name				filllight
	geometry			fillgeom
	material			lum_fill
	position			0 6 5
	orientation			60 0 0
}
