RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           furnace_sss_zero_absorption.RISEscene                                                   #
#   Description:    BSSRDF furnace test baseline: zero absorption (A=1.0 all channels).                     #
#                   Sphere should match background exactly (ratio = 1.0).                                   #
#                   Any deficit measures systematic loss from probe failures and                             #
#                   recursion limits, and can be used to normalize the absorption test.                      #
#                                                                                                           #
#   Expected:       sphere/background ~ 0.96 (3-4% loss from max_recursion=16                                #
#                   and probe failures).  All three channels                                                #
#                   should be equal.                                                                        #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 31, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

pathtracing_shaderop
{
	name		pt
}

standard_shader
{
	name		global
	shaderop	pt
}

pixelpel_rasterizer
{
	max_recursion		16
	samples				4000
	lum_samples			1
	ior_stack			TRUE
}

file_rasterizeroutput
{
	pattern				rendered/furnace_sss_zero_absorption
	type				HDR
	bpp					32
	color_space			ROMMRGB_Linear
}

pinhole_camera
{
	location			0 0 60
	lookat				0 0 0
	up					0 1 0
	width				200
	height				150
	fov					30.0
}

uniformcolor_painter
{
	name				pnt_emit
	color				0.31831 0.31831 0.31831
	colorspace			ROMMRGB_Linear
}

uniformcolor_painter
{
	name				pnt_absorption
	color				0.0 0.0 0.0
	colorspace			ROMMRGB_Linear
}

uniformcolor_painter
{
	name				pnt_scattering
	color				2.0 2.0 2.0
	colorspace			ROMMRGB_Linear
}

lambertian_luminaire_material
{
	name				emit
	exitance			pnt_emit
	scale				1
	material			none
}

subsurfacescattering_material
{
	name				wax
	ior					1.3
	absorption			pnt_absorption
	scattering			pnt_scattering
	g					0.0
	roughness			0.0
}

sphere_geometry
{
	name				spheregeom
	radius				10.0
}

standard_object
{
	name				sphere
	geometry			spheregeom
	position			0 0 0
	material			wax
}

clippedplane_geometry
{
	name				boxgeom
	pta					-200 -200 0
	ptb					200 -200 0
	ptc					200 200 0
	ptd					-200 200 0
}

standard_object
{
	name				top
	geometry			boxgeom
	position			0 100 0
	orientation			90 0 0
	material			emit
}

standard_object
{
	name				bottom
	geometry			boxgeom
	position			0 -100 0
	orientation			-90 0 0
	material			emit
}

standard_object
{
	name				back
	geometry			boxgeom
	position			0 0 -100
	orientation			0 0 0
	material			emit
}

standard_object
{
	name				front
	geometry			boxgeom
	position			0 0 100
	orientation			0 180 0
	material			emit
}

standard_object
{
	name				left
	geometry			boxgeom
	position			-100 0 0
	orientation			0 90 0
	material			emit
}

standard_object
{
	name				right
	geometry			boxgeom
	position			100 0 0
	orientation			0 -90 0
	material			emit
}
