RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           pt_jewel_vault_guided.RISEscene                                                              #
#   Description:    Path guiding benchmark: "The Jewel Vault" — an enclosed gallery lit only                #
#                   through a narrow horizontal slot window in the back wall.  Light enters                 #
#                   as a thin band and must bounce multiple times off walls and objects to                  #
#                   illuminate the space.  A partial divider wall creates a deep alcove where              #
#                   objects receive 3+ bounce indirect light only.                                          #
#                                                                                                           #
#                   This scene is specifically designed to benefit from path guiding:                       #
#                     - Tiny effective light source (narrow slot) = highly non-uniform illumination         #
#                     - Lambertian walls = hemispherical BSDF sampling wastes ~90% of samples              #
#                     - Divider alcove = 3+ bounce paths that are extremely hard to find                   #
#                     - Glossy floor and metallic objects = complex indirect light transport                #
#                                                                                                           #
#                   Expected: path guiding gives 3-5x effective sample count improvement                   #
#                   on the indirect illumination compared to unguided BDPT.                                 #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 28, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Renderer -- Unidirectional Path Tracing
##################################################

pathtracing_shaderop
{
	name		pt
	branch		false
}

standard_shader
{
	name		global
	shaderop	pt
}

pixelpel_rasterizer
{
	max_recursion		10
	min_importance		0.001
	samples				128
	lum_samples			1
	ior_stack			TRUE
	oidn_denoise		FALSE
	pathguiding			true
	pathguiding_iterations	6
	pathguiding_spp			4
	pathguiding_alpha		0.5
	pathguiding_max_depth	8
}

file_rasterizeroutput
{
	pattern				rendered/pt_jewel_vault_guided
	type				HDR
	bpp					16
	color_space			ROMMRGB_Linear
}

file_rasterizeroutput
{
	pattern				rendered/pt_jewel_vault_guided
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera
#
# Inside the vault, looking from the front-right
# toward the back-left alcove.  The slot window
# is visible as a bright band on the back wall,
# with dramatic light spilling across the scene.
##################################################

pinhole_camera
{
	location			2.0 3.8 11.5
	lookat				-1.0 2.0 3.5
	up					0 1 0
	width				512
	height				384
	fov					52.0
}

##################################################
# Painters
##################################################

> run scenes/colors.RISEscript

# ---- Floor ----
uniformcolor_painter
{
	name				pnt_floor_light
