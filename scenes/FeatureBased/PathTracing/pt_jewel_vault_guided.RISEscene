	name				col_back_left
	geometry			columngeom
	position			-5.8 4.0 0.5
	material			column_mat
}

standard_object
{
	name				col_back_right
	geometry			columngeom
	position			5.8 4.0 0.5
	material			column_mat
}

standard_object
{
	name				col_mid_left
	geometry			columngeom
	position			-5.8 4.0 5.0
	material			column_mat
}

standard_object
{
	name				col_mid_right
	geometry			columngeom
	position			5.8 4.0 5.0
	material			column_mat
}

standard_object
{
	name				col_front_left
	geometry			columngeom
	position			-5.8 4.0 9.5
	material			column_mat
}

standard_object
{
	name				col_front_right
	geometry			columngeom
	position			5.8 4.0 9.5
	material			column_mat
}

# Horizontal beams connecting column pairs (architectural trim)
standard_object
{
	name				beam_left
	geometry			archbeam_geom
	position			-5.8 7.6 4.75
	material			arch_trim_mat
}

standard_object
{
	name				beam_right
	geometry			archbeam_geom
	position			5.8 7.6 4.75
	material			arch_trim_mat
}

##################################################
# Pedestals
##################################################

# Copper sphere pedestal (bright zone, near slot light)
standard_object
{
	name				ped_copper
	geometry			pedestal_tall_geom
	position			2.5 0.6 3.0
	material			pedestal_white_mat
}

# Glass torus: sits directly on the floor (no pedestal)

# Gold ellipsoid pedestal (alcove, behind divider)
standard_object
{
	name				ped_gold
	geometry			pedestal_med_geom
	position			-3.8 0.45 8.5
	material			pedestal_dark_mat
}

# Amber sphere pedestal (deep in alcove)
standard_object
{
	name				ped_amber
	geometry			pedestal_round_geom
	position			-5.2 0.5 7.0
	material			pedestal_dark_mat
}

# CSG lens pedestal (bright zone)
standard_object
{
	name				ped_lens
	geometry			pedestal_short_geom
	position			-2.5 0.325 2.5
	material			pedestal_white_mat
}

# Bronze sphere pedestal (right side, moderate indirect)
standard_object
{
	name				ped_bronze
	geometry			pedestal_med_geom
	position			4.0 0.45 7.5
	material			pedestal_white_mat
}

##################################################
# Display objects
#
# BRIGHT ZONE (z < 6, near slot window):
#   - Copper sphere: large, glossy metallic, catches slot light
#   - CSG glass lens: focuses caustics on the floor
#   - Sapphire sphere: small accent, catches colored reflections
#
# ALCOVE ZONE (z > 6, behind divider):
#   - Gold ellipsoid: anisotropic highlights, deep indirect
#   - Amber glass sphere: warm colored glass in shadow
#   - Bronze sphere: darker metal, picks up wall color bounces
#
# TRANSITION (near divider):
#   - Glass torus: standing upright, creates refractive caustics
#   - Mirror sphere: reflects both zones, creates visual connection
##################################################

# ---- Bright zone ----

# Copper sphere on tall white pedestal
standard_object
{
	name				copper_sphere
	geometry			copper_sphere_geom
	position			2.5 1.95 3.0
	material			copper_mat
}

# CSG glass lens on short pedestal (focuses slot light into caustic)
csg_object
{
	name				glass_lens
	obja				lens_half_top
	objb				lens_half_bot
	operation			intersection
	position			-2.5 1.0 2.5
	orientation			15 0 10
}

# Small sapphire sphere directly on the floor (accent piece)
standard_object
{
	name				sapphire_sphere
	geometry			sapphire_sphere_geom
	position			0.5 0.38 1.5
	material			sapphire_glass_mat
}

# ---- Transition zone (near divider) ----

# Glass torus standing upright, slight lean
standard_object
{
	name				glass_torus
	geometry			glass_torus_geom
	position			-1.0 0.94 5.2
	orientation			90 20 0
	material			clear_glass_mat
}

# Mirror sphere on the floor (right side of divider gap)
standard_object
{
	name				mirror_sphere
	geometry			mirror_sphere_geom
	position			2.0 0.45 5.8
	material			mirror_mat
}

# ---- Alcove zone (behind divider, indirect light only) ----

# Gold ellipsoid on dark pedestal
standard_object
{
	name				gold_ellipsoid
	geometry			gold_ellipsoid_geom
	position			-3.8 1.75 8.5
	material			gold_mat
}

# Amber glass sphere on round pedestal
standard_object
{
	name				amber_sphere
	geometry			amber_sphere_geom
	position			-5.2 1.55 7.0
	material			amber_glass_mat
}

# Bronze sphere on white pedestal (right side, moderate indirect)
standard_object
{
	name				bronze_sphere
	geometry			copper_sphere_geom
	position			4.0 1.65 7.5
	material			bronze_mat
}
