##################################################
# Materials
##################################################

# Floor: glossy dark polished stone
ward_isotropic_material
{
	name				floor_mat
	rd					pnt_floor_checker
	rs					pnt_floor_spec
	alpha				0.07
}

# Room surfaces
lambertian_material
{
	name				ceiling_mat
	reflectance			pnt_ceiling
}

orennayar_material
{
	name				backwall_mat
	reflectance			pnt_backwall
	roughness			0.25
}

lambertian_material
{
	name				leftwall_mat
	reflectance			pnt_leftwall
}

lambertian_material
{
	name				rightwall_mat
	reflectance			pnt_rightwall
}

lambertian_material
{
	name				frontwall_mat
	reflectance			pnt_frontwall
}

lambertian_material
{
	name				divider_mat
	reflectance			pnt_divider
}

lambertian_material
{
	name				column_mat
	reflectance			pnt_column
}

lambertian_material
{
	name				arch_trim_mat
	reflectance			pnt_arch_trim
}

# Pedestals
lambertian_material
{
	name				pedestal_white_mat
	reflectance			pnt_pedestal_white
}

lambertian_material
{
	name				pedestal_dark_mat
	reflectance			pnt_pedestal_dark
}

# Copper: Ward isotropic, tight glossy
ward_isotropic_material
{
	name				copper_mat
	rd					pnt_copper_diff
	rs					pnt_copper_spec
	alpha				0.05
}

# Gold: Ashikmin-Shirley anisotropic (stretched highlights)
ashikminshirley_anisotropicphong_material
{
	name				gold_mat
	rd					pnt_gold_diff
	rs					pnt_gold_spec
	nu					250
	nv					60
}

# Bronze: Ward isotropic, slightly rougher
ward_isotropic_material
{
	name				bronze_mat
	rd					pnt_bronze_diff
	rs					pnt_bronze_spec
	alpha				0.10
}

# Clear glass
dielectric_material
{
	name				clear_glass_mat
	tau					pnt_clear_tau
	ior					1.52
	scattering			100000.0
}

# Amber glass
dielectric_material
{
	name				amber_glass_mat
	tau					pnt_amber_tau
	ior					1.58
	scattering			100000.0
}

# Sapphire glass
dielectric_material
{
	name				sapphire_glass_mat
	tau					pnt_sapphire_tau
	ior					1.77
	scattering			100000.0
}

# Mirror
perfectreflector_material
{
	name				mirror_mat
	reflectance			color_white
}

# Slot window emitter -- very bright to compensate for tiny area
lambertian_luminaire_material
{
	name				slot_light_mat
	exitance			pnt_slot_light
	scale				6000.0
	material			none
}

##################################################
# Geometry
##################################################

# Room: 14 wide x 8 tall x 14 deep
# x: [-7, 7], y: [0, 8], z: [-1, 13]

clippedplane_geometry
{
	name				floorgeom
	pta					-7.0 0.0 -1.0
	ptb					-7.0 0.0 13.0
	ptc					7.0 0.0 13.0
	ptd					7.0 0.0 -1.0
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					-7.0 0.0 13.0
	ptb					-7.0 0.0 -1.0
	ptc					7.0 0.0 -1.0
	ptd					7.0 0.0 13.0
}

# Back wall: split into lower + upper panels with slot gap
# Lower panel: y=0 to y=5.3 (full width)
clippedplane_geometry
{
	name				backwall_lower_geom
	pta					-7.0 5.3 -1.0
	ptb					-7.0 0.0 -1.0
	ptc					7.0 0.0 -1.0
	ptd					7.0 5.3 -1.0
}

# Upper panel: y=5.8 to y=8 (full width)
clippedplane_geometry
{
	name				backwall_upper_geom
	pta					-7.0 8.0 -1.0
	ptb					-7.0 5.8 -1.0
	ptc					7.0 5.8 -1.0
	ptd					7.0 8.0 -1.0
}

# Slot window gap: y=5.3 to y=5.8 at z=-1
# Light enters here from the emitter behind the wall

# Side wall (reused for left and right)
clippedplane_geometry
{
	name				sidewallgeom
	pta					0.0 8.0 13.0
	ptb					0.0 0.0 13.0
	ptc					0.0 0.0 -1.0
	ptd					0.0 8.0 -1.0
}

# Front wall (behind camera)
clippedplane_geometry
{
	name				frontwallgeom
	pta					7.0 8.0 13.0
	ptb					7.0 0.0 13.0
	ptc					-7.0 0.0 13.0
	ptd					-7.0 8.0 13.0
}

# Slot window emitter: behind the back wall, shining through the gap
# Panel at z=-1.5, spanning the gap height, angled to shine inward (+z)
clippedplane_geometry
{
	name				slot_emitter_geom
	pta					-5.5 5.35 -1.5
	ptb					5.5 5.35 -1.5
	ptc					5.5 5.75 -1.5
	ptd					-5.5 5.75 -1.5
}

# Light channel walls: box above and below the slot to contain
# light to the slot opening (prevents wrap-around leaking)
box_geometry
{
	name				light_channel_top_geom
	width				14.0
	height				2.5
	depth				0.6
}

box_geometry
{
	name				light_channel_bot_geom
	width				14.0
	height				5.5
	depth				0.6
}

# Divider wall (thin box creating the alcove)
box_geometry
{
	name				dividergeom
	width				7.5
	height				5.2
	depth				0.12
}

# Columns
cylinder_geometry
{
	name				columngeom
	axis				y
	radius				0.28
	height				8.0
}

# Decorative arch trim (thin horizontal beam between column pairs)
box_geometry
{
	name				archbeam_geom
	width				0.22
	height				0.22
	depth				8.0
}

# ---- Object geometries ----

sphere_geometry
{
	name				copper_sphere_geom
	radius				0.75
}

torus_geometry
{
	name				glass_torus_geom
	majorradius			0.80
	minorratio			0.17
}

ellipsoid_geometry
{
	name				gold_ellipsoid_geom
	radii				0.45 0.85 0.35
}

sphere_geometry
{
	name				mirror_sphere_geom
	radius				0.45
}

sphere_geometry
{
	name				amber_sphere_geom
	radius				0.55
}

sphere_geometry
{
	name				sapphire_sphere_geom
	radius				0.38
}

# CSG lens: intersection of two spheres
sphere_geometry
{
	name				lens_top_geom
	radius				0.50
}

sphere_geometry
{
	name				lens_bot_geom
	radius				0.50
}

standard_object
{
	name				lens_half_top
	geometry			lens_top_geom
	position			0 0.32 0
	material			clear_glass_mat
}

standard_object
{
	name				lens_half_bot
	geometry			lens_bot_geom
	position			0 -0.32 0
	material			clear_glass_mat
}

# Pedestal geometries
box_geometry
{
	name				pedestal_tall_geom
	width				1.1
	height				1.2
	depth				1.1
}

box_geometry
{
	name				pedestal_med_geom
	width				0.9
	height				0.9
	depth				0.9
}

box_geometry
{
	name				pedestal_short_geom
	width				0.7
	height				0.65
	depth				0.7
}

cylinder_geometry
{
	name				pedestal_round_geom
	axis				y
	radius				0.40
	height				1.0
}

##################################################
# Room structure
##################################################

standard_object
{
	name				floor
	geometry			floorgeom
	material			floor_mat
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	position			0 8.0 0
	material			ceiling_mat
}

standard_object
{
	name				backwall_lower
	geometry			backwall_lower_geom
	material			backwall_mat
}

standard_object
{
	name				backwall_upper
	geometry			backwall_upper_geom
	material			backwall_mat
}

standard_object
{
	name				leftwall
	geometry			sidewallgeom
	position			-7.0 0 0
	material			leftwall_mat
}

standard_object
{
	name				rightwall
	geometry			sidewallgeom
	position			7.0 0 0
	material			rightwall_mat
}

standard_object
{
	name				frontwall
	geometry			frontwallgeom
	material			frontwall_mat
}

##################################################
# Slot window light + channel
#
# The emitter sits behind the back wall (z=-1.5)
# and shines through the 0.5-unit slot gap.
# Channel walls above/below prevent light from
# wrapping around the wall edges.
##################################################

standard_object
{
	name				slot_emitter
	geometry			slot_emitter_geom
	material			slot_light_mat
}

standard_object
{
	name				light_channel_top
	geometry			light_channel_top_geom
	position			0 6.85 -1.25
	material			ceiling_mat
}

standard_object
{
	name				light_channel_bot
	geometry			light_channel_bot_geom
	position			0 2.65 -1.25
	material			ceiling_mat
}

##################################################
# Divider wall
#
# Partial-height wall creating a shadowed alcove.
# Extends from x=-7 to x=0.5, y=0 to y=5.2,
# positioned at z=6.
# Objects behind this wall (z > 6) are lit only
# by multi-bounce indirect light.
##################################################

standard_object
{
	name				divider
	geometry			dividergeom
	position			-3.25 2.6 6.0
	material			divider_mat
}

