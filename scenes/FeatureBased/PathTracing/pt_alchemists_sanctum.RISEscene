	color				0.42 0.32 0.22
}

uniformcolor_painter
{
	name				pnt_wall_side_warm
	color				0.48 0.35 0.20
}

uniformcolor_painter
{
	name				pnt_wall_side_cool
	color				0.28 0.30 0.34
}

uniformcolor_painter
{
	name				pnt_ceiling
	color				0.35 0.30 0.25
}

# ---- Pedestals ----
uniformcolor_painter
{
	name				pnt_ped_stone
	color				0.22 0.20 0.18
}

uniformcolor_painter
{
	name				pnt_ped_copper_diff
	color				0.08 0.03 0.01
}

uniformcolor_painter
{
	name				pnt_ped_copper_spec
	color				0.55 0.28 0.12
	colorspace			RISERGB
}

# ---- Pillars ----
uniformcolor_painter
{
	name				pnt_pillar_stone
	color				0.30 0.28 0.25
}

# ---- Glass ----
uniformcolor_painter
{
	name				pnt_clear_glass
	color				0.998 0.998 0.998
	colorspace			RISERGB
}

uniformcolor_painter
{
	name				pnt_tinted_glass
	color				0.96 0.98 0.96
	colorspace			RISERGB
}

# ---- Fog volume shell (near-invisible dielectric surface) ----
#      IOR 1.001 gives near-zero Fresnel reflectance so camera
#      rays transmit through and scatter in the interior medium.
uniformcolor_painter
{
	name				pnt_fog_shell
	color				0.999 0.999 0.999
	colorspace			RISERGB
}

# ---- Mirror ----
uniformcolor_painter
{
	name				pnt_mirror
	color				0.92 0.92 0.94
	colorspace			RISERGB
}

##################################################
# Materials
##################################################

# Polished stone floor
ward_isotropic_material
{
	name				floor_mat
	rd					pnt_floor_rd
	rs					pnt_floor_rs
	alpha				0.06
}

# Walls
orennayar_material
{
	name				backwall_mat
	reflectance			pnt_wall_back
	roughness			0.3
}

lambertian_material
{
	name				warmwall_mat
	reflectance			pnt_wall_side_warm
}

lambertian_material
{
	name				coolwall_mat
	reflectance			pnt_wall_side_cool
}

lambertian_material
{
	name				ceiling_mat
	reflectance			pnt_ceiling
}

# Stone pedestal
orennayar_material
{
	name				pedestal_mat
	reflectance			pnt_ped_stone
	roughness			0.2
}

# Copper pedestal
ward_isotropic_material
{
	name				copper_ped_mat
	rd					pnt_ped_copper_diff
	rs					pnt_ped_copper_spec
	alpha				0.08
}

# Stone pillars
orennayar_material
{
	name				pillar_stone_mat
	reflectance			pnt_pillar_stone
	roughness			0.15
}

# Clear glass (crystal orb shell, lens)
dielectric_material
{
	name				clear_glass
	tau					pnt_clear_glass
	ior					1.52
	scattering			100000.0
}

# Tinted glass (elixir flask)
dielectric_material
{
	name				green_glass
	tau					pnt_tinted_glass
	ior					1.48
	scattering			100000.0
}

# Fog volume shell: near-invisible dielectric (IOR 1.001).
# Camera rays transmit through with negligible reflection,
# enter the IOR stack, activate the interior medium, and
# volume scattering in CastRay produces visible fog.
dielectric_material
{
	name				fog_shell_mat
	tau					pnt_fog_shell
	ior					1.001
	scattering			100000.0
}

# Mirror sphere
perfectreflector_material
{
	name				mirror_mat
	reflectance			pnt_mirror
}

# Skylight emitter
lambertian_luminaire_material
{
	name				skylight_mat
	exitance			pnt_skylight
	scale				4000.0
	material			none
}

# Caustic light
lambertian_luminaire_material
{
	name				caustic_light_mat
	exitance			pnt_caustic_light
	scale				800.0
	material			none
}

