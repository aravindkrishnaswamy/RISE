##################################################
# Materials
##################################################

# Polished stone floor — subtle glossy reflection
ward_isotropic_material
{
	name				floor_mat
	rd					pnt_floor_rd
	rs					pnt_floor_rs
	alpha				0.06
}

# Walls
orennayar_material
{
	name				backwall_mat
	reflectance			pnt_wall_back
	roughness			0.3
}

lambertian_material
{
	name				warmwall_mat
	reflectance			pnt_wall_side_warm
}

lambertian_material
{
	name				coolwall_mat
	reflectance			pnt_wall_side_cool
}

lambertian_material
{
	name				ceiling_mat
	reflectance			pnt_ceiling
}

# Stone pedestal
orennayar_material
{
	name				pedestal_mat
	reflectance			pnt_ped_stone
	roughness			0.2
}

# Copper pedestal (decorative)
ward_isotropic_material
{
	name				copper_ped_mat
	rd					pnt_ped_copper_diff
	rs					pnt_ped_copper_spec
	alpha				0.08
}

# Clear glass (crystal orb shell, lens)
dielectric_material
{
	name				clear_glass
	tau					pnt_clear_glass
	ior					1.52
	scattering			100000.0
}

# Tinted glass (elixir vial)
dielectric_material
{
	name				green_glass
	tau					pnt_tinted_glass
	ior					1.48
	scattering			100000.0
}

# Mist surface (visible but shadow-transparent)
lambertian_material
{
	name				mist_mat
	reflectance			pnt_mist_surface
}

# Mirror sphere
perfectreflector_material
{
	name				mirror_mat
	reflectance			pnt_mirror
}

# Skylight emitter (bright narrow slot)
lambertian_luminaire_material
{
	name				skylight_mat
	exitance			pnt_skylight
	scale				4000.0
	material			none
}

# Caustic light (small bright omni emitter behind lens)
lambertian_luminaire_material
{
	name				caustic_light_mat
	exitance			pnt_caustic_light
	scale				800.0
	material			none
}

