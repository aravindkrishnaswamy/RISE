##################################################
# Artifacts
##################################################

# ---- Crystal orb (SPHERE): glass shell + amber fog ----
#
# Glass sphere with IOR 1.52 enclosing dense amber fog.
# Light refracts into the sphere, forward-scatters in
# the fog, producing a warm internal glow (volumetric
# caustic).  The primary glass-enclosed medium test.
standard_object
{
	name				crystal_orb
	geometry			orb_geom
	position			-1.2 2.3 3.5
	material			clear_glass
	interior_medium		orb_fog
}

# ---- Elixir flask (ELLIPSOID): tinted glass + emerald fog ----
#
# Elongated ellipsoidal glass vessel.  Tests non-spherical
# IOR-stack medium tracking — the ellipsoid entry/exit
# boundaries are computed differently from spheres, and
# the medium walk must handle the elongated shape correctly.
standard_object
{
	name				elixir_flask
	geometry			elixir_geom
	position			2.0 1.45 4.5
	material			green_glass
	interior_medium		elixir_fog
}

# ---- Glass lens (CSG intersection) ----
#
# Positioned between the caustic point light and the orb.
# Focuses light into a caustic beam visible in the haze.
csg_object
{
	name				glass_lens
	obja				lens_half_a
	objb				lens_half_b
	operation			intersection
	position			-4.0 0.95 2.0
	orientation			20 15 0
}

# ---- Caustic point light behind the lens ----
standard_object
{
	name				caustic_source
	geometry			caustic_light_geom
	position			-5.2 1.0 0.8
	material			caustic_light_mat
}

# ---- Fog ring (TORUS): blue-violet ethereal ring ----
#
# Pure volume (casts_shadows FALSE).  Hovers above and
# slightly behind center.  The toroidal boundary means
# shadow rays can enter and exit the tube section
# multiple times — a more complex crossing pattern than
# a sphere.  Floor shadow should show a ring-shaped
# blue-tinted pattern.
standard_object
{
	name				fog_ring
	geometry			ring_geom
	position			-1.0 4.2 5.5
	orientation			15 0 10
	material			fog_shell_mat
	interior_medium		ring_fog
	casts_shadows		FALSE
}

# ---- Fog pillar (CYLINDER): crimson column ----
#
# Pure volume rising from near the floor.  Cylindrical
# medium boundary — shadow rays from the floor beneath
# cross the cylinder walls and accumulate pillar_fog
# transmittance.  The rectangular shadow cross-section
# contrasts with the spherical shadows from other objects.
standard_object
{
	name				fog_pillar
	geometry			pillar_fog_geom
	position			3.0 1.25 7.0
	material			fog_shell_mat
	interior_medium		pillar_fog
	casts_shadows		FALSE
}

# ---- Pillar core (BOX): cyan fog nested inside cylinder ----
#
# Nested inside the fog pillar.  The shadow-walk boundary
# stack pushes pillar_fog on entering the cylinder, then
# pushes core_fog on entering this box (core becomes
# active), pops core on exit, then pops pillar on exiting
# the cylinder.  Tests nested media with mixed geometry
# types (box inside cylinder).
standard_object
{
	name				pillar_core
	geometry			core_box_geom
	position			3.0 1.25 7.0
	material			fog_shell_mat
	interior_medium		core_fog
	casts_shadows		FALSE
}

# ---- Aureole (ELLIPSOID): warm golden wisp ----
#
# Partially overlaps the torus fog ring.  The shadow
# walk enters the torus, then enters the aureole.  When
# the ray exits the aureole before the torus, the stack
# must do non-LIFO removal (remove aureole entry while
# torus stays active).  Ellipsoidal shape adds boundary
# variety to the overlap test.
standard_object
{
	name				aureole
	geometry			aureole_geom
	position			0.3 4.0 6.5
	material			fog_shell_mat
	interior_medium		aureole_fog
	casts_shadows		FALSE
}

# ---- Mirror sphere: reflects the fog volumes ----
#
# Sits on the floor, right side.  Reflects the glowing
# orb, the blue ring, the crimson pillar, and the light
# shaft — creating complex reflected-medium light paths.
standard_object
{
	name				mirror_sphere
	geometry			mirror_sphere_geom
	position			3.8 0.45 3.0
	material			mirror_mat
}
