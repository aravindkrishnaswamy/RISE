# Pedestals
##################################################

# Orb pedestal: tall copper, center-left of room
standard_object
{
	name				ped_orb
	geometry			ped_tall_geom
	position			-1.2 0.5 3.5
	material			copper_ped_mat
}

# Elixir pedestal: small stone, right of orb
standard_object
{
	name				ped_elixir
	geometry			ped_round_geom
	position			2.0 0.35 4.5
	material			pedestal_mat
}

# Lens pedestal: small stone, left of orb
standard_object
{
	name				ped_lens
	geometry			ped_small_geom
	position			-4.0 0.25 2.0
	material			pedestal_mat
}

##################################################
# Artifacts
##################################################

# ---- Crystal orb: glass shell + amber fog interior ----
#
# Glass sphere with IOR 1.52 enclosing dense amber fog.
# Light refracts into the sphere, scatters forward in the
# fog, and glows.  This is the primary volumetric caustic:
# the glass concentrates light inside, and the fog makes
# that concentration visible as a bright internal glow.
standard_object
{
	name				crystal_orb
	geometry			orb_geom
	position			-1.2 2.3 3.5
	material			clear_glass
	interior_medium		orb_fog
}

# ---- Elixir vial: green glass + emerald fog ----
standard_object
{
	name				elixir_vial
	geometry			elixir_geom
	position			2.0 1.25 4.5
	material			green_glass
	interior_medium		elixir_fog
}

# ---- Glass lens (CSG intersection) ----
#
# Positioned between the caustic point light and the orb.
# Focuses light into a caustic beam visible in the global
# haze.  Tilted slightly for visual interest.
csg_object
{
	name				glass_lens
	obja				lens_half_a
	objb				lens_half_b
	operation			intersection
	position			-4.0 0.95 2.0
	orientation			20 15 0
}

# ---- Caustic point light behind the lens ----
#
# Small bright emitter sphere positioned behind the lens.
# Light refracts through the lens and creates a focused
# beam through the haze toward the orb area.
standard_object
{
	name				caustic_source
	geometry			caustic_light_geom
	position			-5.2 1.0 0.8
	material			caustic_light_mat
}

# ---- Summoned mist: ethereal blue-violet fog ----
#
# Pure volume (casts_shadows FALSE).  Hovers above and
# to the left.  Shadow rays from floor points to the
# skylight must traverse this volume — the medium walk
# discovers it and applies mist_fog transmittance.
standard_object
{
	name				summoned_mist
	geometry			mist_geom
	position			-2.5 3.8 5.5
	material			mist_mat
	interior_medium		mist_fog
	casts_shadows		FALSE
}

# ---- Mist core: dense cyan, nested inside summoned mist ----
#
# Nested inside the mist sphere.  The shadow-walk boundary
# stack pushes mist_fog on entering the outer sphere, then
# pushes core_fog on entering this sphere (core becomes
# the active medium), pops core on exit, pops mist on exit.
# The floor shadow directly below shows a deeper, cyan-
# tinted patch within the broader blue shadow.
standard_object
{
	name				mist_core
	geometry			core_geom
	position			-2.5 3.9 5.3
	material			mist_mat
	interior_medium		core_fog
	casts_shadows		FALSE
}

# ---- Aureole: warm wisp overlapping the mist ----
#
# Partially overlaps the summoned mist sphere.  The shadow
# walk enters mist, then enters aureole.  When the ray exits
# the aureole before the mist, the stack must do non-LIFO
# removal (remove aureole entry, mist stays active).
# The floor shows a combined attenuation in the overlap zone.
standard_object
{
	name				aureole
	geometry			aureole_geom
	position			-1.5 3.5 6.3
	material			mist_mat
	interior_medium		aureole_fog
	casts_shadows		FALSE
}

# ---- Mirror sphere: reflects the fog volumes ----
#
# Sits on the floor, right side.  Reflects the glowing orb,
# the blue mist, and the light shaft, creating complex
# reflected-medium light paths.
standard_object
{
	name				mirror_sphere
	geometry			mirror_sphere_geom
	position			3.5 0.45 3.0
	material			mirror_mat
}
