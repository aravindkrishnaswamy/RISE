RISE ASCII SCENE 5
#############################################################################################################
#   Simple CSG dielectric lens test for BDPT                                                                #
#   A CSG intersection lens (two overlapping spheres) with dielectric glass material                        #
#   on a white floor with a single ceiling light.                                                           #
#############################################################################################################

> set accelerator B 10 8

pathtracing_shaderop
{
	name		pt
}

standard_shader
{
	name				global
	shaderop			DefaultDirectLighting
	shaderop			pt
}

bdpt_pel_rasterizer
{
	max_recursion		10
	min_importance		0.001
	max_eye_depth		10
	max_light_depth		10
	samples				256
	lum_samples			1
	ior_stack			TRUE
}

file_rasterizeroutput
{
	pattern				rendered/bdpt_csg_lens_test
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera
##################################################

pinhole_camera
{
	location			0 3.0 5.0
	lookat				0 1.0 0
	up					0 1 0
	width				320
	height				240
	fov					45.0
}

##################################################
# Painters
##################################################

uniformcolor_painter
{
	name				pnt_white
	color				0.9 0.9 0.9
}

uniformcolor_painter
{
	name				pnt_emit
	color				1.0 1.0 1.0
}

uniformcolor_painter
{
	name				pnt_glass_tau
	color				0.998 0.998 0.998
	colorspace			RISERGB
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				white_mat
	reflectance			pnt_white
}

lambertian_luminaire_material
{
	name				light_mat
	exitance			pnt_emit
	scale				60.0
	material			none
}

dielectric_material
{
	name				glass_mat
	tau					pnt_glass_tau
	ior					1.5
	scattering			100000.0
}

##################################################
# Geometry
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					-5.0 0.0 -5.0
	ptb					-5.0 0.0 5.0
	ptc					5.0 0.0 5.0
	ptd					5.0 0.0 -5.0
}

clippedplane_geometry
{
	name				backwallgeom
	pta					-5.0 5.0 0.0
	ptb					-5.0 0.0 0.0
	ptc					5.0 0.0 0.0
	ptd					5.0 5.0 0.0
}

circulardisk_geometry
{
	name				lightdiskgeom
	radius				0.6
	axis				y
}

sphere_geometry
{
	name				sphere_top
	radius				0.55
}

sphere_geometry
{
	name				sphere_bot
	radius				0.55
}

sphere_geometry
{
	name				ref_sphere_geom
	radius				0.45
}

##################################################
# Objects
##################################################

standard_object
{
	name				floor
	geometry			floorgeom
	material			white_mat
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	position			0 0 -3.0
	material			white_mat
}

standard_object
{
	name				ceiling_light
	geometry			lightdiskgeom
	position			0 4.5 -0.5
	material			light_mat
}

# CSG lens: intersection of two spheres offset along Y
standard_object
{
	name				lens_a
	geometry			sphere_top
	position			0 0.25 0
	material			glass_mat
}

standard_object
{
	name				lens_b
	geometry			sphere_bot
	position			0 -0.25 0
	material			glass_mat
}

csg_object
{
	name				test_lens
	obja				lens_a
	objb				lens_b
	operation			intersection
	position			-1.0 1.2 0
}

# Reference: a plain sphere with same glass material (should be transparent)
standard_object
{
	name				ref_sphere
	geometry			ref_sphere_geom
	position			1.0 1.2 0
	material			glass_mat
}
