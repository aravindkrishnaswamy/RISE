uniformcolor_painter
{
	name		color_silver
	color		0.90 0.91 0.98 
}






























uniformcolor_painter
{
	name				pnt_floor
	color				0.94 0.92 0.88
}

uniformcolor_painter
{
	name				pnt_ceiling
	color				0.98 0.97 0.94
}

uniformcolor_painter
{
	name				pnt_back_wall
	color				0.96 0.92 0.88
}

uniformcolor_painter
{
	name				pnt_left_wall
	color				0.90 0.56 0.38
}

uniformcolor_painter
{
	name				pnt_right_wall
	color				0.34 0.78 0.88
}

uniformcolor_painter
{
	name				pnt_emit
	color				1.0 0.96 0.92
}

uniformcolor_painter
{
	name				pnt_pedestal
	color				0.63 0.49 0.32
}


uniformcolor_painter
{
	name				pnt_emit_cool
	color				0.82 0.92 1.0
}

uniformcolor_painter
{
	name				pnt_caustic_floor
	color				0.98 0.96 0.92
}



##################################################
# Materials
##################################################

lambertian_material
{
	name				floor_mat
	reflectance			pnt_floor
}

lambertian_material
{
	name				ceiling_mat
	reflectance			pnt_ceiling
}

lambertian_material
{
	name				back_wall_mat
	reflectance			pnt_back_wall
}

lambertian_material
{
	name				left_wall_mat
	reflectance			pnt_left_wall
}

lambertian_material
{
	name				right_wall_mat
	reflectance			pnt_right_wall
}

lambertian_material
{
	name				caustic_floor_mat
	reflectance			pnt_caustic_floor
}

lambertian_luminaire_material
{
	name				ceiling_lum
	exitance			pnt_emit
	scale				20.0
	material			none
}

lambertian_luminaire_material
{
	name				ceiling_lum_cool
	exitance			pnt_emit_cool
	scale				20.0
	material			none
}

perfectreflector_material
{
	name				mirror_mat
	reflectance			color_silver
}

polished_material
{
	name				pedestal_mat
	reflectance			pnt_pedestal
	tau			1
	ior					1.5
	scattering			350.0
}

dielectric_material
{
	name				clear_glass
	tau			0.997 0.998 1
	ior					1.54
	scattering			100000.0
}

dielectric_material
{
	name				lens_glass
	tau			1 0.997 0.62
	ior					1.58
	scattering			100000.0
}

dielectric_material
{
	name				prism_glass
	tau			0.64 0.99 1
	ior					1.66
	scattering			100000.0
}

##################################################
# Geometry
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					-6.0 0.0 -6.0
	ptb					-6.0 0.0 6.0
	ptc					6.0 0.0 6.0
	ptd					6.0 0.0 -6.0
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					-6.0 0.0 6.0
	ptb					-6.0 0.0 -6.0
	ptc					6.0 0.0 -6.0
	ptd					6.0 0.0 6.0
}

clippedplane_geometry
{
	name				backwallgeom
	pta					-6.0 6.0 0.0
	ptb					-6.0 0.0 0.0
	ptc					6.0 0.0 0.0
	ptd					6.0 6.0 0.0
}

clippedplane_geometry
{
	name				sidewallgeom
	pta					0.0 6.0 6.0
	ptb					0.0 0.0 6.0
	ptc					0.0 0.0 -6.0
	ptd					0.0 6.0 -6.0
}

box_geometry
{
	name				mirrorgeom
	width				0.06
	height				2.8
	depth				2.6
}

box_geometry
{
	name				stepcapgeom
	width				1.25
	height				0.12
	depth				7.4
}

circulardisk_geometry
{
	name				lightdiskgeom
	radius				0.55
	axis				y
}

circulardisk_geometry
{
	name				causticdiskgeom
	radius				1.55
	axis				y
}

cylinder_geometry
{
	name				pedestalgeom
	axis				y
	radius				0.34
	height				0.9
}

sphere_geometry
{
	name				orbgeom
	radius				0.48
}

sphere_geometry
{
	name				lens_sphere_top
	radius				0.44
}

sphere_geometry
{
	name				lens_sphere_bot
	radius				0.44
}

ellipsoid_geometry
{
	name				lensgeom
	radii				0.19 0.09 0.19
}

torus_geometry
{
	name				torusgeom
	majorradius			0.26
	minorratio			0.24
}

standard_object
{
	name				lens_half_a
	geometry			lens_sphere_top
	position			0 0.30 0
	material			lens_glass
}

standard_object
{
	name				lens_half_b
	geometry			lens_sphere_bot
	position			0 -0.30 0
	material			lens_glass
}

##################################################
# Room shell
##################################################

