RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           bdpt_cloister.RISEscene                                                                 #
#   Description:    A BDPT torture test: cloister scene with glass caustics, mirrors, spotlights            #
#                   through refractive objects, and complex indirect illumination paths.                    #
#                   This scene is extremely difficult for unidirectional path tracers but                   #
#                   well-suited for bidirectional path tracing.                                             #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 20, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8


##################################################
# Setup a renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}


bdpt_pel_rasterizer
{
	max_eye_depth		10
	max_light_depth		10
	samples				64
}


/*
pathtracing_pel_rasterizer
{
	samples				64
	pathguiding				TRUE
	pathguiding_iterations	3
	pathguiding_spp			4
	pathguiding_alpha		0.5
	pathguiding_max_depth	3
    pathguiding_light_max_depth 0
	pathguiding_sampling_type	ris
	sms_enabled			FALSE
	sms_max_iterations	20
	sms_threshold		1e-3
	sms_max_chain_depth	20
	sms_biased			TRUE
	oidn_denoise 		TRUE
	blue_noise_sampler	TRUE
	adaptive_max_samples	256
	adaptive_threshold		0.1
}
*/

file_rasterizeroutput
{
	pattern				rendered/bdpt_cloister
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

film
{
	width			960
	height			720
}

pinhole_camera
{
	location			0 2.9 8.8
	lookat				0 1.8 -1.2
	up					0 1 0
	fov					42.0
}

##################################################
# Painters
##################################################

