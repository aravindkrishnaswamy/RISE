RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           bdpt_torus_chain_atrium.RISEscene                                                       #
#   Description:    BDPT torture test: a helical chain of 30 interlocking dielectric (glass) toruses        #
#                   spiraling through a procedurally generated columned atrium.  Each torus                 #
#                   has a unique colored Tau with at least one RGB component >= 0.999.  Light must          #
#                   traverse dozens of refractive boundaries to illuminate the scene.                       #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 21, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Renderer -- Bidirectional Path Tracing
#
# BDPT uses the shader chain to shade each eye subpath vertex.
# DefaultDirectLighting provides NEE at each bounce (the t>=2, s=1
# strategy), and PathTracingShaderOp continues the eye subpath.
# The BDPTIntegrator then adds its own light-subpath connections
# and SMS strategies on top — those are separate from the shader.
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}


bdpt_pel_rasterizer
{
	max_eye_depth		14
	max_light_depth		12
	samples				128
	pathguiding				FALSE
	pathguiding_iterations	4
	pathguiding_spp			4
	pathguiding_alpha		0.5
	pathguiding_max_depth	3
    pathguiding_light_max_depth 0
	pathguiding_sampling_type	ris
}


/*
vcm_pel_rasterizer
{
	max_eye_depth		10
	max_light_depth		10
	samples				128
	merge_radius		0.0
	vc_enabled			true
	vm_enabled			true
}
*/

/*
mlt_rasterizer
{
	max_eye_depth		12
	max_light_depth		12
	bootstrap_samples	100000
	chains				64
	mutations_per_pixel	10000
	large_step_prob		0.25
}
*/


##################################################
# Alternative: Unidirectional MIS Path Tracer
#
# MISPathTracingShaderOp is a self-contained integrator that
# handles NEE (both mesh and non-mesh lights), BSDF sampling,
# emission, and SMS all in one shaderop with proper MIS weights.
# It replaces the entire DefaultDirectLighting + PathTracing chain.
# Use with pixelpel_rasterizer instead of bdpt_pel_rasterizer.
#
# Note: for scenes like this one where all floor illumination must
# pass through glass, BDPT is fundamentally superior — its light
# subpaths directly carry energy through the glass, which the
# unidirectional PT cannot do.
##################################################
/*
pathtracing_pel_rasterizer
{
	samples				128
	pathguiding				TRUE
	pathguiding_iterations	6
	pathguiding_spp			4
	pathguiding_alpha		0.5
	pathguiding_max_depth	3
    pathguiding_light_max_depth 0
	pathguiding_sampling_type	ris
	sms_enabled			FALSE
	sms_max_iterations	20
	sms_threshold		1e-3
	sms_max_chain_depth	20
	sms_biased			TRUE
	oidn_denoise 		TRUE
	blue_noise_sampler	TRUE
#	adaptive_max_samples	4096
#	adaptive_threshold		0.01
	progressive_rendering          TRUE
	progressive_samples_per_pass   32
}
*/

file_rasterizeroutput
{
	pattern				rendered/bdpt_torus_chain_atrium
	type				HDR
	bpp					16
	color_space			ROMMRGB_Linear
}

##################################################
# Camera
##################################################

film
{
	width			400
	height			400
}

pinhole_camera
{
	location			0 5.5 19.0
	lookat				0 3.5 4.0
	up					0 1 0
	fov					50.0
}

