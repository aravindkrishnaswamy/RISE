##################################################
# Torus Chain -- 30 interlocking glass links
#
# The chain follows a helix (2 full turns) around
# the Y axis, centered at (0, -, 4).  Helix
# radius 2.5, rising from y=1.5 to y=5.4.
# Angular step per link: 4*pi/29 = 0.4333 rad
# (24.83 deg).  Chord distance between adjacent
# links ~1.07, matched to torus majorradius 1.0
# so they interlock.
#
# Even links: ring vertical, yawed to follow helix
# Odd links:  ring horizontal, yawed to follow helix
#
# Tau colors cycle R-B-G using cos^2 at 120-degree
# phase offsets, guaranteeing one component = 0.999
# at every link.
##################################################

# Shared torus geometry for all chain links
torus_geometry
{
	name				chain_torus_geom
	majorradius			1.0
	minorratio			0.18
}

# Generate 15 pairs (30 links total)
# Helix params:  R_h=2.5, center_z=4.0
#   angle per I step = 2 * 4*pi/29 = 0.8666 rad = 49.66 deg
#   angle offset for odd = 4*pi/29 = 0.4333 rad = 24.83 deg
#   y step per I = 2 * 3.9/29 = 0.2690


	# ==== EVEN LINK (K = 2*I) ====
	# Per-channel tau RGB inlined as a values triple (IScalarPainter
	# RGBScalarPainter form) — the previous named-uniformcolor_painter
	# binding no longer works for scalar slots after Phase 4.
	dielectric_material
	{
		name			glass_e0000
		tau				0.99900000000000000 0.36225360100285409 0.36224279805538595
		ior				1.33000000000000007
		scattering		100000.0
	}

	standard_object
	{
		name			link_e0000
		geometry		chain_torus_geom
		position		2.50000000000000000 1.50000000000000000 4.00000000000000000
		orientation		90 0.00000000000000000 0
		material		glass_e0000
	}

	# ==== ODD LINK (K = 2*I + 1) ====
	dielectric_material
	{
		name			glass_o0000
		tau				0.36225360100285409 0.36224279805538595 0.99899999981671883
		ior				1.36000000000000010
		scattering		100000.0
	}

	standard_object
	{
		name			link_o0000
		geometry		chain_torus_geom
		position		2.26896282302424890 1.63450000000000006 5.04967028524857753
		orientation		0 24.82999999999999829 0
		material		glass_o0000
