# Atrium surfaces
uniformcolor_painter
{
	name				pnt_floor
	color				0.5 0.5 0.5
}

uniformcolor_painter
{
	name				pnt_wall
	color				0.75 0.72 0.68
}

uniformcolor_painter
{
	name				pnt_ceiling
	color				0.80 0.78 0.75
}

uniformcolor_painter
{
	name				pnt_column
	color				0.92 0.89 0.84
}

# Area light colors
uniformcolor_painter
{
	name				pnt_warm_light
	color				1.0 0.75 0.65
}

uniformcolor_painter
{
	name				pnt_cool_light
	color				0.65 0.75 1.0
}

uniformcolor_painter
{
	name				pnt_neutral_light
	color				0.95 0.95 0.95
}

# Checker pattern for floor (to catch caustics nicely)
uniformcolor_painter
{
	name				pnt_checker_dark
	color				0.2 0.2 0.2
}

checker_painter
{
	name				pnt_floor_checker
	colora				pnt_floor
	colorb				pnt_checker_dark
	size				1.0
}

