RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           bdpt_jewel_vault_guided.RISEscene                                                       #
#   Description:    Path-guided variant of the Jewel Vault scene.  Identical geometry, materials,           #
#                   and lighting — only the rasterizer has path guiding enabled.                             #
#                                                                                                           #
#                   Compare rendered/bdpt_jewel_vault.hdr (unguided) against                                #
#                   rendered/bdpt_jewel_vault_guided.hdr (guided) to see the convergence                    #
#                   improvement from path guiding.  The alcove zone behind the divider wall                 #
#                   should show the most dramatic noise reduction.                                           #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      March 28, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Renderer -- Bidirectional Path Tracing + Path Guiding
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

bdpt_pel_rasterizer
{
	max_eye_depth		8
	max_light_depth		6
	samples				128
	lum_samples			1
	sms_enabled			FALSE
	oidn_denoise		FALSE
	pathguiding				true
	pathguiding_iterations	4
	pathguiding_spp			4
	pathguiding_alpha		0.5
	pathguiding_max_depth	3
}

file_rasterizeroutput
{
	pattern				rendered/bdpt_jewel_vault_guided
	type				HDR
	bpp					16
	color_space			ROMMRGB_Linear
}

file_rasterizeroutput
{
	pattern				rendered/bdpt_jewel_vault_guided
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Camera
##################################################

pinhole_camera
{
	location			2.0 3.8 11.5
	lookat				-1.0 2.0 3.5
	up					0 1 0
	width				512
	height				384
	fov					52.0
}

##################################################
# Painters
##################################################

> run scenes/colors.RISEscript

# ---- Floor ----
uniformcolor_painter
{
	name				pnt_floor_light
	color				0.20 0.19 0.22
}

uniformcolor_painter
{
	name				pnt_floor_dark
	color				0.07 0.07 0.08
}

checker_painter
{
	name				pnt_floor_checker
	colora				pnt_floor_light
	colorb				pnt_floor_dark
	size				1.2
}

uniformcolor_painter
{
	name				pnt_floor_spec
	color				0.05 0.05 0.06
	colorspace			RISERGB
}

# ---- Room surfaces ----
uniformcolor_painter
{
	name				pnt_ceiling
	color				0.78 0.75 0.68
}

uniformcolor_painter
{
	name				pnt_backwall
	color				0.50 0.10 0.08
}

uniformcolor_painter
{
	name				pnt_leftwall
	color				0.62 0.44 0.18
}

uniformcolor_painter
{
	name				pnt_rightwall
	color				0.15 0.33 0.44
}

uniformcolor_painter
{
	name				pnt_frontwall
	color				0.38 0.36 0.33
}

