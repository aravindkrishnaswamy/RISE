}

dielectric_material
{
	name				clear_glass_mat
	tau					pnt_clear_tau
	ior					1.52
	scattering			100000.0
}

dielectric_material
{
	name				amber_glass_mat
	tau					pnt_amber_tau
	ior					1.58
	scattering			100000.0
}

dielectric_material
{
	name				sapphire_glass_mat
	tau					pnt_sapphire_tau
	ior					1.77
	scattering			100000.0
}

perfectreflector_material
{
	name				mirror_mat
	reflectance			color_white
}

lambertian_luminaire_material
{
	name				slot_light_mat
	exitance			pnt_slot_light
	scale				6000.0
	material			none
}

