}

##################################################
# Row D: Aluminum brushed, strong anisotropy
##################################################

standard_object
{
	name				bg_03
	geometry			showcase_sphere
	position			100 130 410
	material			brushed_03
}

standard_object
{
	name				bg_04
	geometry			showcase_sphere
	position			220 130 410
	material			brushed_04
}

standard_object
