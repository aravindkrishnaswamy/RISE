##################################################

standard_object
{
	name				bg_005
	geometry			showcase_sphere
	position			100 230 330
	material			brushed_005
}

standard_object
{
	name				bg_01
	geometry			showcase_sphere
	position			220 230 330
	material			brushed_01
}

standard_object
{
	name				bg_015
	geometry			showcase_sphere
