##################################################
# Side accents: copper and chromium
##################################################

# Copper: IOR=0.21, k=3.6, moderate roughness
ggx_material
{
	name				copper_mid
	rd					pnt_black
	rs					pnt_copper
	alphax				0.15
	alphay				0.15
	ior					0.21
	extinction			3.6
}

# Chromium: IOR=3.18, k=3.32, low roughness
ggx_material
{
	name				chromium_low
	rd					pnt_black
	rs					pnt_chromium
	alphax				0.05
	alphay				0.05
	ior					3.18
	extinction			3.32
}

##################################################
# Wall materials
##################################################

lambertian_material
{
	name				white
	reflectance			color_white
}

lambertian_material
{
	name				green
	reflectance			color_cornellgreen
}

lambertian_material
{
	name				red
	reflectance			color_cornellred
}

lambertian_luminaire_material
{
	name				white_lum
	exitance			pnt_light
	scale				70.0
	material			none
}

##################################################
# Cornell box walls
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					552.8 0 0
	ptb					0 0 0
	ptc					0 0 559.2
	ptd					549.6 0 559.2
}

clippedplane_geometry
{
	name				ceilinggeom
	pta					556.0 548.8 0.0
	ptb					556.0 548.8 559.2
	ptc					0 548.8 559.2
	ptd					0.0 548.8 0.0
}

clippedplane_geometry
{
	name				bwallgeom
	pta					549.6 0 559.2
	ptb					0 0 559.2
	ptc					0 548.8 559.2
	ptd					556.0 548.8 559.2
}

clippedplane_geometry
{
	name				rwallgeom
	pta					0 0 559.2
	ptb					0 0 0
	ptc					0 548.8 0.0
	ptd					0 548.8 559.2
}

clippedplane_geometry
{
	name				lwallgeom
	pta					552.8 0 0
	ptb					549.6 0 559.2
	ptc					556.0 548.8 559.2
	ptd					556.0 548.8 0
}

clippedplane_geometry
{
	name				lightgeom
	pta					393.0 548.7999 177.0
	ptb					393.0 548.7999 382.0
	ptc					163.0 548.7999 382.0
	ptd					163.0 548.7999 177.0
}

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				bwall
	geometry			bwallgeom
	material			white
}

standard_object
{
	name				rwall
	geometry			rwallgeom
	material			green
}

standard_object
{
	name				lwall
	geometry			lwallgeom
	material			red
}

standard_object
{
	name				light
	geometry			lightgeom
	material			white_lum
	position			0 0 -40
}

##################################################
# Sphere geometry
##################################################

sphere_geometry
{
	name				showcase_sphere
	radius				42.0
}

sphere_geometry
{
	name				accent_sphere
	radius				50.0
}

##################################################
# Layout: 4 columns x 4 rows, floating mid-air
#
# 4 columns at x = 100, 220, 340, 460
# Row A (top):      y=430, z=170   gold 0.01-0.2
# Row B:            y=330, z=250   gold 0.3-1.0
# Row C:            y=230, z=330   aluminum brushed 0.05-0.2
# Row D (bottom):   y=130, z=410   aluminum brushed 0.3-0.8
#
# Accents flanking at x=70 and x=486
##################################################

##################################################
# Row A: Gold isotropic, low roughness (top row)
##################################################

standard_object
{
	name				fg_001
	geometry			showcase_sphere
	position			100 430 170
	material			gold_001
}

standard_object
{
	name				fg_005
	geometry			showcase_sphere
	position			220 430 170
	material			gold_005
}

standard_object
{
	name				fg_01
	geometry			showcase_sphere
	position			340 430 170
	material			gold_01
}

standard_object
{
	name				fg_02
	geometry			showcase_sphere
	position			460 430 170
	material			gold_02
}

##################################################
# Row B: Gold isotropic, high roughness
##################################################

standard_object
{
	name				fg_03
	geometry			showcase_sphere
	position			100 330 250
	material			gold_03
}

standard_object
{
	name				fg_05
	geometry			showcase_sphere
	position			220 330 250
	material			gold_05
}

standard_object
