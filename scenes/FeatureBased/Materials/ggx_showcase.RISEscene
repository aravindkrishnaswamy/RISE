##################################################
# Accent spheres: copper (left) and chromium (right)
# Floating at mid-height between rows B and C
##################################################

standard_object
{
	name				copper_accent
	geometry			accent_sphere
	position			70 150 80
	material			copper_mid
}

standard_object
{
	name				chromium_accent
