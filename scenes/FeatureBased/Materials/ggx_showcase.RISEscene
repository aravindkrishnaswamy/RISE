RISE ASCII SCENE 5
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           ggx_showcase.RISEscene                                                                 #
#   Description:    Comprehensive showcase of the GGX microfacet material with height-correlated G2,       #
#                   anisotropic roughness, and Kulla-Conty multiscattering compensation.                    #
#                                                                                                           #
#                   Rows A-B: 8 gold spheres, isotropic roughness gradient (0.01-1.0)                      #
#                   Rows C-D: 8 aluminum spheres, anisotropic brushed metal (alphay 0.05-0.8)              #
#                   Accents:  copper and chromium conductors flanking the grid                               #
#                                                                                                           #
#                   All spheres float mid-air in a 4x4+2 arrangement filling the box volume.               #
#                   Cornell box variant with ceiling area light, colored walls for interreflection.          #
#                                                                                                           #
#   Author:         Aravind Krishnaswamy                                                                    #
#   Birthdate:      April 6, 2026                                                                           #
#                                                                                                           #
#############################################################################################################

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_pel_rasterizer
{
	samples                       64
	lum_samples                   1
	ior_stack                     true
}

file_rasterizeroutput
{
	pattern				rendered/ggx_showcase
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

pinhole_camera
{
	location			278 310 -680
	lookat				278 260 290
	up					0 1 0
	width				512
	height				512
	fov					42.0
}

##################################################
# Painters
##################################################
> run scenes/colors.RISEscript

uniformcolor_painter
{
	name				pnt_light
	color				1.0 0.97 0.90
}

uniformcolor_painter
{
	name				pnt_black
	color				0.0 0.0 0.0
}

# Gold conductor specular color (Au at visible wavelengths)
uniformcolor_painter
{
	name				pnt_gold
	color				1.0 0.85 0.35
}

# Aluminum specular color (highly reflective, near-white)
uniformcolor_painter
{
	name				pnt_aluminum
	color				0.91 0.92 0.92
}

# Copper specular color
uniformcolor_painter
{
	name				pnt_copper
	color				0.98 0.72 0.52
}

# Chromium specular color
uniformcolor_painter
{
	name				pnt_chromium
	color				0.55 0.56 0.55
}

##################################################
# Gold isotropic roughness sweep (rows A and B)
# alpha: 0.01, 0.05, 0.1, 0.2, 0.3, 0.5, 0.7, 1.0
# Gold conductor: IOR=2.5, k=3.0
##################################################

ggx_material
{
	name				gold_001
	rd					pnt_black
	rs					pnt_gold
	alphax				0.01
	alphay				0.01
	ior					2.5
	extinction			3.0
}

ggx_material
{
	name				gold_005
	rd					pnt_black
	rs					pnt_gold
	alphax				0.05
	alphay				0.05
	ior					2.5
	extinction			3.0
}

ggx_material
{
	name				gold_01
	rd					pnt_black
	rs					pnt_gold
	alphax				0.1
	alphay				0.1
	ior					2.5
	extinction			3.0
}

ggx_material
{
	name				gold_02
	rd					pnt_black
	rs					pnt_gold
	alphax				0.2
	alphay				0.2
	ior					2.5
	extinction			3.0
}

ggx_material
{
	name				gold_03
	rd					pnt_black
	rs					pnt_gold
	alphax				0.3
	alphay				0.3
	ior					2.5
	extinction			3.0
}

ggx_material
{
	name				gold_05
	rd					pnt_black
	rs					pnt_gold
	alphax				0.5
	alphay				0.5
	ior					2.5
	extinction			3.0
}

ggx_material
{
	name				gold_07
	rd					pnt_black
	rs					pnt_gold
	alphax				0.7
	alphay				0.7
	ior					2.5
	extinction			3.0
}

ggx_material
{
	name				gold_10
	rd					pnt_black
	rs					pnt_gold
	alphax				1.0
	alphay				1.0
	ior					2.5
	extinction			3.0
}

##################################################
# Aluminum anisotropic brushed metal (rows C and D)
# alphax=0.05 (tight along tangent), alphay varies
# Aluminum: IOR=1.37, k=7.62
##################################################

ggx_material
{
	name				brushed_005
	rd					pnt_black
	rs					pnt_aluminum
	alphax				0.05
	alphay				0.05
	ior					1.37
	extinction			7.62
}

ggx_material
{
	name				brushed_01
	rd					pnt_black
	rs					pnt_aluminum
	alphax				0.05
	alphay				0.1
	ior					1.37
	extinction			7.62
}

ggx_material
{
	name				brushed_015
	rd					pnt_black
	rs					pnt_aluminum
	alphax				0.05
	alphay				0.15
	ior					1.37
	extinction			7.62
}

ggx_material
{
	name				brushed_02
	rd					pnt_black
	rs					pnt_aluminum
	alphax				0.05
	alphay				0.2
	ior					1.37
	extinction			7.62
}

ggx_material
{
	name				brushed_03
	rd					pnt_black
	rs					pnt_aluminum
	alphax				0.05
	alphay				0.3
	ior					1.37
	extinction			7.62
}

ggx_material
{
	name				brushed_04
	rd					pnt_black
