RISE ASCII SCENE 6
#############################################################################################################
#   File:           thinfilm_heattint_showcase.RISEscene
#   Description:    Canonical showcase for physically-based thin-film interference (heat-tint / anodized
#                   metal) on the GGX microfacet conductor BSDF (fresnel_mode thinfilm).  Rendered
#                   SPECTRALLY (per-hero-wavelength Airy reflectance of the air / oxide / metal stack).
#
#                   TOP ROW   - titanium anodization ladder: five Ti / TiO2 spheres, oxide thickness
#                               40..220 nm.  Reproduces the gold -> purple -> blue -> cyan -> green
#                               progression of the Ti anodizing chart (cf. the Phase-1 swatch,
#                               tests/ThinFilmAnodizeSwatchTest), each sphere also showing the
#                               angle-dependent (centre vs rim) hue shift of thin-film interference.
#                   BOTTOM ROW- substrate generality at a fixed 90 nm oxide: titanium (TiO2), steel
#                               (Fe3O4, an ABSORBING oxide -> duller/browner), tantalum (Ta2O5) and
#                               niobium (Nb2O5).  Same BSDF, data only (docs/THIN_FILM_INTERFERENCE.md
#                               sec 6) -- vivid Ti/Ta/Nb vs muted steel.
#
#                   Phase-2 piece E (docs/THIN_FILM_INTERFERENCE.md sec 10).
#   Author:         Aravind Krishnaswamy
#############################################################################################################

standard_shader
{
	name		global
	shaderop	DefaultPathTracing
}

pathtracing_spectral_rasterizer
{
	samples				48
	nmbegin				380
	nmend				720
	num_wavelengths			24
	spectral_samples		1
	oidn_denoise			true
	oidn_prefilter			accurate
}

file_rasterizeroutput
{
	pattern				rendered/thinfilm_heattint_showcase
	type				PNG
	bpp				8
	color_space			sRGB
}

film
{
	width			640
	height			480
}

pinhole_camera
{
	location			278 268 -760
	lookat				278 258 200
	up				0 1 0
	fov				42.0
}

uniformcolor_painter
{
	name				pnt_black
	color				0.0 0.0 0.0
}

uniformcolor_painter
{
	name				pnt_white
	color				1.0 1.0 1.0
}

##################################################
# Thin-film optical constants (Phase-1 data, colors/thinfilm/)
##################################################

scalar_painter
{
	name		Ti_n
	file		colors/thinfilm/substrates/Ti.n
}
scalar_painter
{
	name		Ti_k
	file		colors/thinfilm/substrates/Ti.k
}
scalar_painter
{
	name		TiO2_n
	file		colors/thinfilm/oxides/TiO2.n
}
scalar_painter
{
	name		TiO2_k
	file		colors/thinfilm/oxides/TiO2.k
}
scalar_painter
{
	name		Steel_n
	file		colors/thinfilm/substrates/Steel.n
}
scalar_painter
{
	name		Steel_k
	file		colors/thinfilm/substrates/Steel.k
}
scalar_painter
{
	name		Fe3O4_n
	file		colors/thinfilm/oxides/Fe3O4.n
}
scalar_painter
{
	name		Fe3O4_k
	file		colors/thinfilm/oxides/Fe3O4.k
}
scalar_painter
{
	name		Ta_n
	file		colors/thinfilm/substrates/Ta.n
}
scalar_painter
{
	name		Ta_k
	file		colors/thinfilm/substrates/Ta.k
}
scalar_painter
{
	name		Ta2O5_n
	file		colors/thinfilm/oxides/Ta2O5.n
}
scalar_painter
{
	name		Ta2O5_k
	file		colors/thinfilm/oxides/Ta2O5.k
}
scalar_painter
{
	name		Nb_n
	file		colors/thinfilm/substrates/Nb.n
}
scalar_painter
{
	name		Nb_k
	file		colors/thinfilm/substrates/Nb.k
}
scalar_painter
{
	name		Nb2O5_n
	file		colors/thinfilm/oxides/Nb2O5.n
}
scalar_painter
{
	name		Nb2O5_k
	file		colors/thinfilm/oxides/Nb2O5.k
}

##################################################
# Top row: Ti / TiO2 anodization ladder (40..220 nm)
##################################################

ggx_material
{
	name				tf_ti_040
	rd				pnt_black
	rs				pnt_white
	alphax				0.05
	alphay				0.05
	fresnel_mode			thinfilm
	ior				Ti_n
	extinction			Ti_k
	film_ior			TiO2_n
	film_extinction			TiO2_k
	film_thickness			40
}

ggx_material
{
	name				tf_ti_080
	rd				pnt_black
	rs				pnt_white
	alphax				0.05
	alphay				0.05
	fresnel_mode			thinfilm
	ior				Ti_n
	extinction			Ti_k
	film_ior			TiO2_n
	film_extinction			TiO2_k
	film_thickness			80
}

