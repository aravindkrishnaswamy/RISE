{
	name				tf_ti_120
	rd				pnt_black
	rs				pnt_white
	alphax				0.05
	alphay				0.05
	fresnel_mode			thinfilm
	ior				Ti_n
	extinction			Ti_k
	film_ior			TiO2_n
	film_extinction			TiO2_k
	film_thickness			120
}

ggx_material
{
	name				tf_ti_170
	rd				pnt_black
	rs				pnt_white
	alphax				0.05
	alphay				0.05
	fresnel_mode			thinfilm
	ior				Ti_n
	extinction			Ti_k
	film_ior			TiO2_n
	film_extinction			TiO2_k
	film_thickness			170
}

ggx_material
{
	name				tf_ti_220
	rd				pnt_black
	rs				pnt_white
	alphax				0.05
	alphay				0.05
	fresnel_mode			thinfilm
	ior				Ti_n
	extinction			Ti_k
	film_ior			TiO2_n
