##################################################
# Neutral enclosure (white) + area light
##################################################

lambertian_material
{
	name				white
	reflectance			pnt_white
}

lambertian_luminaire_material
{
	name				white_lum
	exitance			pnt_white
	scale				60.0
	material			none
}

clippedplane_geometry
{
	name				floorgeom
	pta				552.8 0 0
	ptb				0 0 0
	ptc				0 0 559.2
	ptd				549.6 0 559.2
}

clippedplane_geometry
{
	name				ceilinggeom
	pta				556.0 548.8 0.0
	ptb				556.0 548.8 559.2
	ptc				0 548.8 559.2
	ptd				0.0 548.8 0.0
}

clippedplane_geometry
{
	name				bwallgeom
	pta				549.6 0 559.2
	ptb				0 0 559.2
	ptc				0 548.8 559.2
	ptd				556.0 548.8 559.2
}

clippedplane_geometry
{
	name				lightgeom
	pta				403.0 548.7999 167.0
	ptb				403.0 548.7999 392.0
	ptc				153.0 548.7999 392.0
	ptd				153.0 548.7999 167.0
}

standard_object
{
	name				floor
	geometry			floorgeom
	material			white
}

standard_object
{
	name				ceiling
	geometry			ceilinggeom
	material			white
}

standard_object
{
	name				bwall
	geometry			bwallgeom
	material			white
}

standard_object
{
	name				light
	geometry			lightgeom
	material			white_lum
}

sphere_geometry
{
	name				spheregeom
	radius				44.0
}

