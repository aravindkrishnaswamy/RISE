RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           kaleidoscope_atrium.RISEscene                                                           #
#   Description:    A parser stress test that generates a luminous atrium from nested loops,               #
#                   expressions, macros, and embedded commands.                                             #
#   Author:         OpenAI Codex                                                                            #
#   Birthdate:      March 19, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

# Be sure to set the object manager for BSP
> set accelerator B 10 8
> echo event Generating the Kaleidoscope Atrium using nested loops, computed geometry, generated materials, and loop-built lights.


##################################################
# Setup a renderer
##################################################

standard_shader
{
	name				global
	shaderop			DefaultDirectLighting
}

/*
distributiontracing_shaderop
{
	name				dt
	samples				6
	diffuse				false
	reflections			TRUE
}
*/

pathtracing_shaderop
{
	name				pt
}

standard_shader
{
	# pathtracing_shaderop already does NEE direct lighting via MIS;
	# stacking DefaultDirectLighting on top double-counts every direct
	# illumination contribution.  Job::CreateStandardShader() emits a
	# warning about this combination -- keep the shader stack lean.
	name				glossy_shader
	shaderop			pt
}

standard_shader
{
	name				glass_shader
	shaderop			DefaultDirectLighting
	shaderop			DefaultReflection
	shaderop			DefaultRefraction
}

pixelpel_rasterizer
{
	max_recursion		6
	samples				16
	lum_samples			1
	adaptive_max_samples	512
	adaptive_threshold	0.05
}

file_rasterizeroutput
{
	pattern				rendered/kaleidoscope_atrium
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

film
{
	width			1024
	height			768
}

pinhole_camera
{
	location			-8.5 6.3 17.5
	lookat				0 2.2 0
	up					0 1 0
	fov					36.0
}

##################################################
# Painters
##################################################

#############################################################################################################
#									RISE Ascii Scene File													#
