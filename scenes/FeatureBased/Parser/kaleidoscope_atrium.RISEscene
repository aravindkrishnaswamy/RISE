#############################################################################################################






















	
	

	




































































uniformcolor_painter
{
	name				pnt_floor_dark
	color				0.18 0.22 0.28
}

uniformcolor_painter
{
	name				pnt_floor_light
	color				0.95 0.97 1.0
}

lines_painter
{
	name				pnt_floor
	colora				pnt_floor_dark
	colorb				pnt_floor_light
	size				0.05
}

uniformcolor_painter
{
	name				pnt_wall
	color				0.94 0.92 0.86
}

uniformcolor_painter
{
	name				pnt_ring
	color				0.72 0.52 0.36
}

uniformcolor_painter
{
	name				pnt_ring_spec
	color				0.98 0.86 0.70
}

uniformcolor_painter
{
	name				pnt_metal
	color				0.42 0.48 0.58
}

uniformcolor_painter
{
	name				pnt_metal_spec
	color				0.92 0.95 0.99
}



uniformcolor_painter
{
	name				pnt_jade
	color				0.45 0.76 0.66
}

##################################################
# Materials
##################################################

polished_material
{
	name				floor_mat
	reflectance			pnt_floor
	tau			1
	ior					1.45
	scattering			250.0
}

lambertian_material
{
	name				back_wall_mat
	reflectance			pnt_wall
}

cooktorrance_material
{
	name				ring_mat
	rd					pnt_ring
	rs					pnt_ring_spec
	facets				0.12
	ior					2.4
	extinction			1.6
}

ward_anisotropic_material
{
	name				pillar_mat
	rd					pnt_metal
	rs					pnt_metal_spec
	alphax				0.03
	alphay			0.22
}

dielectric_material
{
	name				crown_glass
	tau			0.94 0.98 1
	ior					1.52
	scattering			7000.0
}

translucent_material
{
	name				jade_core
	ref					pnt_jade
	tau					pnt_jade
	ext			0
	N					1.0
	scattering			0.6
}

##################################################
# Geometry
##################################################

clippedplane_geometry
{
	name				floorgeom
	pta					-12.0 0.0 -10.0
	ptb					-12.0 0.0 10.0
	ptc					12.0 0.0 10.0
	ptd					12.0 0.0 -10.0
}

clippedplane_geometry
{
	name				backwallgeom
	pta					-12.0 9.0 -9.0
	ptb					-12.0 0.0 -9.0
	ptc					12.0 0.0 -9.0
	ptd					12.0 9.0 -9.0
}

box_geometry
{
	name				plinthgeom
	width				1.4
	height				0.35
	depth				1.4
}

##################################################
# Structural objects
##################################################

standard_object
{
	name				floor
	geometry			floorgeom
	position			0 0 0
	material			floor_mat
	shader				glossy_shader
}

standard_object
{
	name				backwall
	geometry			backwallgeom
	position			0 0 0
	material			back_wall_mat
}

