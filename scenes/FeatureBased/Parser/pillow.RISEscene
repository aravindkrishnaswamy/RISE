#############################################################################################################






















	
	

	







































































uniformcolor_painter
{
	name				pnt_back_b
	color				0.27 0.14 0.11
}

uniformcolor_painter
{
	name				pnt_halo
	color				1.0 0.70 0.44
}

uniformcolor_painter
{
	name				pnt_halo_cool
	color				0.48 0.84 1.0
}

uniformcolor_painter
{
	name				pnt_support
	color				0.42 0.23 0.14
}

uniformcolor_painter
{
	name				pnt_support_pearl
	color				0.78 0.72 0.66
}

uniformcolor_painter
{
	name				pnt_panel
	color				0.14 0.07 0.10
}

##################################################
# Materials
##################################################

lambertian_material
{
	name				backdrop
	reflectance			pnt_back_b
}

polished_material
{
	name				support
	reflectance			pnt_support
	tau			0.96 0.97 0.94
	ior					1.45
	scattering			260.0
}

polished_material
{
	name				support_pearl
	reflectance			pnt_support_pearl
	tau			0.96 0.97 0.94
	ior					1.45
	scattering			320.0
}

lambertian_material
{
	name				panel
	reflectance			pnt_panel
}

lambertian_material
{
	name				halo_surface
	reflectance			pnt_halo
}

lambertian_material
{
	name				halo_cool_surface
	reflectance			pnt_halo_cool
}

lambertian_luminaire_material
{
	name				halo_lum
	exitance			pnt_halo
	scale				24.0
	material			none
}

lambertian_luminaire_material
{
	name				halo_cool_lum
	exitance			pnt_halo_cool
	scale				11.0
	material			none
}

##################################################
# Objects
##################################################

infiniteplane_geometry
{
	name				planegeom
	xtile				8
	ytile				8
}

clippedplane_geometry
{
	name				backwallgeom
	pta					-10.0 12.0 0.0
	ptb					-10.0 -8.0 0.0
	ptc					10.0 -8.0 0.0
	ptd					10.0 12.0 0.0
}

circulardisk_geometry
{
	name				halogeom
	radius				4.8
	axis				z
}

circulardisk_geometry
{
	name				smallhalogeom
	radius				2.2
	axis				z
}

torus_geometry
{
	name				supportgeom
	majorradius			2.25
	minorratio			0.22
}

torus_geometry
{
	name				smallsupportgeom
	majorradius			1.45
	minorratio			0.25
}

ellipsoid_geometry
{
	name				moongeom
	radii				0.925 1.325 0.17
}

box_geometry
{
	name				panelgeom
	width				2.8
	height				11.0
	depth				0.45
}

standard_object
{
	name				backdropobj
	geometry			backwallgeom
	position			0 0 -6.8
	material			backdrop
	receives_shadows	FALSE
}



