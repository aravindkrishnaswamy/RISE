RISE ASCII SCENE 6
#############################################################################################################
#                                      RISE Ascii Scene File                                                #
#                                                                                                           #
#   File:           pillow.RISEscene                                                                        #
#   Description:    A jewel-toned satin pillow study made up of spheres                                     #
#   Author:         OpenAI Codex                                                                            #
#   Birthdate:      March 19, 2026                                                                          #
#                                                                                                           #
#############################################################################################################

> set accelerator B 10 8

##################################################
# Setup a renderer
##################################################

standard_shader
{
	name				global
	shaderop			DefaultDirectLighting
}

distributiontracing_shaderop
{
	name				dt
	samples				12
	diffuse				false
	reflections			TRUE
}

standard_shader
{
	name				satin_shader
	shaderop			dt
	shaderop			DefaultDirectLighting
}

pixelpel_rasterizer
{
	max_recursion		6
	samples				6
	lum_samples			4
}

file_rasterizeroutput
{
	pattern				rendered/pillow
	type				PNG
	bpp					8
	color_space			sRGB
}

##################################################
# Cameras
##################################################

film
{
	width			860
	height			620
}

pinhole_camera
{
	location			0.0 0.0 12.6
	lookat				0.0 0.0 -1.0
	up					0 1 0
	fov					30.5
}

##################################################
# Painters
##################################################

#############################################################################################################
#									RISE Ascii Scene File													#
#																											#
#	File: 			colors.scn																				#
#   Description:	Contains commonly used colors from all scenes											#
#	Author: 		Aravind Krishnaswamy																	#
#	Birthdate:		November 14, 2003																		#
#																											#
