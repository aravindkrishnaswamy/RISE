	point				8.73298 86.00369 -7.06308
	point				8.38300 104.02306 -7.34326
	pitch				2.4
	slant				-16.0
	detail				24
}

standard_object
{
	name				stitch_12_l
	geometry			strapstitchgeom
	material			strap_thread
}

standard_object
{
	name				stitch_12_r
	geometry			strapstitchgeom6
